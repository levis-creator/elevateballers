---
// Clean-slate layout for the public redesign (PUBLIC_UI_VERSION=v2).
// Deliberately does NOT import the ~40 legacy WordPress stylesheets that
// Layout.astro pulls in — the v2 UI is built fresh on Tailwind. Keep the Props
// shape identical to Layout.astro so route files can swap between them with no
// prop changes.
// v2-only Tailwind entrypoint — NO v1 CSS (admin.css / design-system.css /
// legacy WordPress styles). See src/styles/v2.css.
import "@/styles/v2.css";
// v2 design fonts, self-hosted via Fontsource (no external Google Fonts request).
import "@fontsource/anton"; // 400 (display headings)
import "@fontsource/archivo/400.css";
import "@fontsource/archivo/500.css";
import "@fontsource/archivo/600.css";
import "@fontsource/archivo/700.css";
import "@fontsource/archivo/800.css";
import "@fontsource/space-mono/400.css";
import "@fontsource/space-mono/700.css";
import SEO from "@/components/SEO.astro";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	imageWidth?: number;
	imageHeight?: number;
	imageType?: string;
	canonicalURL?: string;
	type?: string;
	robots?: string;
	keywords?: string;
	publishedTime?: string;
	modifiedTime?: string;
	prevURL?: string;
	nextURL?: string;
	preloadImage?: string;
}

const {
	title,
	description,
	image,
	imageWidth,
	imageHeight,
	imageType,
	canonicalURL,
	type,
	robots,
	keywords,
	publishedTime,
	modifiedTime,
	prevURL,
	nextURL,
	preloadImage,
} = Astro.props;
---

<!doctype html>
<html lang="en-US">
	<head>
		<meta name="format-detection" content="telephone=no" />
		<SEO
			title={title}
			description={description}
			image={image}
			imageWidth={imageWidth}
			imageHeight={imageHeight}
			imageType={imageType}
			canonicalURL={canonicalURL}
			type={type}
			robots={robots}
			keywords={keywords}
			publishedTime={publishedTime}
			modifiedTime={modifiedTime}
			prevURL={prevURL}
			nextURL={nextURL}
		/>

		{preloadImage && (
			<link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
		)}

		<!-- Google Analytics -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-VVZ9P3XBLP"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-VVZ9P3XBLP');
		</script>

		<!-- Fonts are self-hosted via Fontsource (imported above) — no external
		     Google Fonts request. Supabase serves most images. -->
		<link rel="preconnect" href="https://zjnlvnyjsidnelgciqmz.supabase.co" crossorigin />

		<!-- Favicons -->
		<link rel="icon" href="/images/Elevate_Icon-32x32.png" sizes="32x32" />
		<link rel="icon" href="/images/Elevate_Icon-200x200.png" sizes="192x192" />
		<link rel="apple-touch-icon" href="/images/Elevate_Icon-200x200.png" />
	</head>
	<!-- Theme-neutral: each v2 page owns its own background/text colour on its
	     root wrapper (e.g. the home page uses cream #f5f3ef). -->
	<body class="min-h-screen antialiased">
		<slot />
	</body>
</html>
