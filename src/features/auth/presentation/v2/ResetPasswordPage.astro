---
// v2 admin reset-password — two-column: reusable BrandingPanel (left, reset
// copy/stats, shared with login + OTP) + set-new-password form (right island).
// Loads the v2 tokens/fonts + eb-* keyframes (spin/shake/pop).
import "@/styles/v2.css";
import "@fontsource/anton";
import "@fontsource/archivo/400.css";
import "@fontsource/archivo/600.css";
import "@fontsource/archivo/700.css";
import "@fontsource/space-mono/400.css";
import "@/features/loading/lib/loading.css";
import BrandingPanel, { type BrandingStat } from "./BrandingPanel.astro";
import ResetPasswordForm from "./ResetPasswordForm.tsx";

// Editorial stats — mirror the actual password policy (8-char minimum + mix).
const stats: BrandingStat[] = [
	{ big: "8+", small: "Characters" },
	{ big: "Aa1#", small: "Mix it up" },
	{ big: "One-time", small: "Reset link", accent: true },
];
---

<div class="grid min-h-screen grid-cols-[1.05fr_0.95fr] bg-night font-body text-cream max-[900px]:grid-cols-1">
	<BrandingPanel
		ghostWord="Reset"
		badge="Fresh Start"
		headlineTop="Lock it"
		headlineAccent="back down"
		description="Choose a strong new password for your admin console. Make it long, mix it up, and keep it to yourself — you run the whole league from here."
		stats={stats}
	/>

	<!-- RIGHT: reset form -->
	<div class="relative flex items-center justify-center bg-night2 px-12 py-14 max-[600px]:px-6 max-[600px]:py-10">
		<svg class="pointer-events-none absolute right-6 top-6 h-[90px] w-[150px]" viewBox="0 0 220 120" aria-hidden="true">
			<defs><pattern id="resetHt" width="16" height="16" patternUnits="userSpaceOnUse"><circle cx="4" cy="4" r="2.2" fill="rgba(255,255,255,0.06)"></circle></pattern></defs>
			<rect width="220" height="120" fill="url(#resetHt)"></rect>
		</svg>
		<ResetPasswordForm client:load />
	</div>
</div>
