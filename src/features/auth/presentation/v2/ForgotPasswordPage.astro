---
// v2 admin forgot-password — two-column: reusable BrandingPanel (left, shared
// with login/OTP/reset) + request-a-reset-link form (right island). Loads the
// v2 tokens/fonts + eb-* keyframes.
import "@/styles/v2.css";
import "@fontsource/anton";
import "@fontsource/archivo/400.css";
import "@fontsource/archivo/600.css";
import "@fontsource/archivo/700.css";
import "@fontsource/space-mono/400.css";
import "@/features/loading/lib/loading.css";
import BrandingPanel, { type BrandingStat } from "./BrandingPanel.astro";
import ForgotPasswordForm from "./ForgotPasswordForm.tsx";
import { getResetTtlMinutes, formatTtl } from "@/features/auth/lib/reset-ttl";

// Same runtime source as the API, so the advertised expiry matches the link
// actually issued (env-overridable, defaults to 60m).
const { short: ttlShort } = formatTtl(getResetTtlMinutes());

const stats: BrandingStat[] = [
	{ big: ttlShort, small: "Link expires in" },
	{ big: "Secure", small: "One-time link" },
	{ big: "Email", small: "Delivered to inbox", accent: true },
];
---

<div class="grid min-h-screen grid-cols-[1.05fr_0.95fr] bg-night font-body text-cream max-[900px]:grid-cols-1">
	<BrandingPanel
		ghostWord="Locked"
		badge="Account Recovery"
		headlineTop="Locked"
		headlineAccent="out?"
		description="Happens to the best of us. Give us the email on your admin account and we'll send a secure link to reset your password."
		stats={stats}
	/>

	<!-- RIGHT: forgot form -->
	<div class="relative flex items-center justify-center bg-night2 px-12 py-14 max-[600px]:px-6 max-[600px]:py-10">
		<svg class="pointer-events-none absolute right-6 top-6 h-[90px] w-[150px]" viewBox="0 0 220 120" aria-hidden="true">
			<defs><pattern id="forgotHt" width="16" height="16" patternUnits="userSpaceOnUse"><circle cx="4" cy="4" r="2.2" fill="rgba(255,255,255,0.06)"></circle></pattern></defs>
			<rect width="220" height="120" fill="url(#forgotHt)"></rect>
		</svg>
		<ForgotPasswordForm client:load />
	</div>
</div>
