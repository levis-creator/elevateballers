---
// v2 admin "check your email" confirmation — two-column: reusable BrandingPanel
// (left, shared with login/OTP/reset) + a static confirmation (right). No island:
// the page holds no interactive state. Loads v2 tokens/fonts + eb-* keyframes.
import "@/styles/v2.css";
import "@fontsource/anton";
import "@fontsource/archivo/400.css";
import "@fontsource/archivo/600.css";
import "@fontsource/archivo/700.css";
import "@fontsource/space-mono/400.css";
import "@/features/loading/lib/loading.css";
import BrandingPanel, { type BrandingStat } from "./BrandingPanel.astro";
import { getResetTtlMinutes, formatTtl } from "@/features/auth/lib/reset-ttl";

// Same runtime source as the forgot-password API, so the shown expiry always
// matches the link actually issued — and stays overridable via .env with no
// rebuild (process.env, resolved per request in SSR).
const { human: ttlHuman, short: ttlShort } = formatTtl(getResetTtlMinutes());

const stats: BrandingStat[] = [
	{ big: ttlShort, small: "Link expires in" },
	{ big: "Once", small: "Single use" },
	{ big: "Spam?", small: "Check junk", accent: true },
];
---

<div class="grid min-h-screen grid-cols-[1.05fr_0.95fr] bg-night font-body text-cream max-[900px]:grid-cols-1">
	<BrandingPanel
		ghostWord="Inbox"
		badge="Reset Requested"
		headlineTop="Check"
		headlineAccent="your inbox"
		description="If that email is on file, a reset link is on its way. Open it, set a new password, and you'll be back running the league in no time."
		stats={stats}
	/>

	<!-- RIGHT: confirmation -->
	<div class="relative flex items-center justify-center bg-night2 px-12 py-14 max-[600px]:px-6 max-[600px]:py-10">
		<svg class="pointer-events-none absolute right-6 top-6 h-[90px] w-[150px]" viewBox="0 0 220 120" aria-hidden="true">
			<defs><pattern id="checkEmailHt" width="16" height="16" patternUnits="userSpaceOnUse"><circle cx="4" cy="4" r="2.2" fill="rgba(255,255,255,0.06)"></circle></pattern></defs>
			<rect width="220" height="120" fill="url(#checkEmailHt)"></rect>
		</svg>

		<div class="relative w-full max-w-[400px]">
			<div class="mb-6 flex h-[68px] w-[68px] items-center justify-center rounded-2xl border border-brand/40 bg-brand/[0.12]" style="animation:eb-float 4s ease-in-out infinite;">
				<svg class="h-[32px] w-[32px]" viewBox="0 0 24 24" fill="none" stroke="#ff5a72" stroke-width="1.7" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2.5"></rect><path d="m3 7.5 9 6 9-6"></path></svg>
			</div>

			<div class="mb-1.5 font-mono text-[11px] uppercase tracking-[0.16em] text-brand">Admin Console</div>
			<h2 class="mb-3 font-display text-[40px] uppercase leading-none text-cream">Check Your Email</h2>
			<p class="mb-6 text-[15px] leading-[1.55] text-creamdim">If an account exists for the address you entered, we&rsquo;ve sent a password reset link to your inbox.</p>
			<p class="mb-8 text-[13.5px] leading-[1.5] text-muted2">Be sure to check your spam or junk folder. The link expires in {ttlHuman} and can only be used once.</p>

			<a href="/admin/login" class="group mb-4 flex w-full items-center justify-center gap-2.5 rounded-lg bg-brand py-[16px] font-display text-[17px] uppercase tracking-[0.08em] text-white no-underline transition-colors duration-150 hover:bg-brandlt">
				Back to Login
				<span class="font-mono text-[15px] font-normal transition-transform duration-150 group-hover:translate-x-1">&rarr;</span>
			</a>

			<div class="flex items-center justify-center gap-1.5 text-[13px] text-muted2">
				<span>Didn&rsquo;t get it?</span>
				<a href="/admin/forgot-password" class="font-body text-[13px] font-bold text-brandsoft no-underline hover:text-brand">Request again</a>
			</div>
		</div>
	</div>
</div>
