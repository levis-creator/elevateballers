---
import { ClientRouter } from 'astro:transitions';
import { checkAuth } from '../../cms/lib/auth-astro';
import AdminShell from './AdminShell';
import AdminShellV2 from '../presentation/v2/AdminShellV2';
import { hasPermission, hasAnyPermission, hasAllPermissions } from '../../rbac/permissions';
import { usePublicAdminV2 } from '@/lib/admin-ui-version';
import '../../../styles/admin.css';
import '../presentation/v2/admin-v2.css';
import '@fontsource/anton';
import '@fontsource/archivo/400.css';
import '@fontsource/archivo/600.css';
import '@fontsource/archivo/700.css';
import '@fontsource/space-mono/400.css';

interface Props {
  title?: string;
  permission?: string;
  permissionsAny?: string[];
  permissionsAll?: string[];
}

const {
  title = 'Admin - Elevate Ballers CMS',
  permission,
  permissionsAny,
  permissionsAll,
} = Astro.props;

const user = await checkAuth(Astro.request);

let redirectUrl: string | null = null;

if (!user) {
  redirectUrl = '/admin/login';
} else if (permission) {
  const allowed = await hasPermission(user.id, permission);
  if (!allowed) redirectUrl = '/unauthorized';
} else if (permissionsAny?.length) {
  const allowed = await hasAnyPermission(user.id, permissionsAny);
  if (!allowed) redirectUrl = '/unauthorized';
} else if (permissionsAll?.length) {
  const allowed = await hasAllPermissions(user.id, permissionsAll);
  if (!allowed) redirectUrl = '/unauthorized';
}

if (redirectUrl) {
  try {
    return Astro.redirect(redirectUrl, 302);
  } catch (e) {
    // Fall back to meta refresh if response stream already started
  }
}

// v2 admin shell is flag-gated (same PUBLIC_ADMIN_UI_VERSION as the auth pages).
// The redesigned dashboard lives at /admin; every other admin page keeps its v1
// content on a light surface inside the v2 chrome until individually redesigned.
const useV2 = usePublicAdminV2;
const isDashboard = Astro.url.pathname === '/admin' || Astro.url.pathname === '/admin/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    {redirectUrl && <meta http-equiv="refresh" content={`0;url=${redirectUrl}`} />}
    <title>{title}</title>
    <ClientRouter />

    <!-- Resolve sidebar collapsed state before paint. Stored preference wins; match-detail auto-hides by default. -->
    <script is:inline>
      (function () {
        try {
          var stored = null;
          try { stored = localStorage.getItem('admin-sidebar-collapsed'); } catch (e) {}
          var collapsed;
          if (stored === 'true') collapsed = true;
          else if (stored === 'false') collapsed = false;
          else {
            var match = /^\/admin\/matches\/([^/]+)\/?$/.exec(location.pathname);
            collapsed = !!match && match[1] !== 'new';
          }
          var isMobile = window.innerWidth <= 768;
          if (!isMobile && collapsed) {
            document.documentElement.style.setProperty('--admin-sidebar-width', '0px');
          }
        } catch (e) {}
      })();
    </script>

    <!-- Fonts -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css?family=Rubik:regular,bold|Teko:regular,700,300,400,500,600"
    />

    <style>
      :root {
        --admin-primary: #dd3333;
        --admin-primary-dark: #c02a2a;
        --admin-header-height: 4rem;
        --admin-sidebar-width: 260px;
      }

      *, *::before, *::after {
        box-sizing: border-box;
      }

      html, body {
        margin: 0;
        padding: 0;
        background: #f9fafb;
        font-family: 'Rubik', sans-serif;
      }

      .admin-page h1,
      .admin-page h2,
      .admin-page h3 {
        font-family: 'Teko', sans-serif;
        font-weight: 600;
        line-height: 1.2;
      }
    </style>
  </head>
  <body>
    {redirectUrl ? (
      <div style="display:flex;align-items:center;justify-content:center;height:100vh;font-family:sans-serif;">
        <p>Redirecting to <a href={redirectUrl} style="color:#dd3333;text-decoration:none;font-weight:bold;">{redirectUrl}</a>...</p>
      </div>
      <script is:inline define:vars={{ url: redirectUrl }}>
        window.location.href = url;
      </script>
    ) : useV2 ? (
      <div id="eb-admin-root" class="eb-root min-h-screen">
        <script is:inline>
          (function () {
            function applyAdminTheme() {
              try {
                var t = localStorage.getItem('eb-cms-theme');
                var light;
                if (t === 'light') light = true;
                else if (t === 'dark') light = false;
                // default = system: follow the OS colour-scheme preference
                else light = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;
                var el = document.getElementById('eb-admin-root');
                if (el) { el.classList.toggle('light', !!light); el.classList.toggle('dark', !light); }
              } catch (e) {}
            }
            // Apply before paint on this (full) load.
            applyAdminTheme();
            // Re-apply after every view-transition swap — the swapped-in page ships
            // a fresh #eb-admin-root with no theme class, so without this the theme
            // resets to default when moving between admin modules. Bind once to
            // `document` (survives swaps).
            if (!window.__ebAdminThemeBound) {
              window.__ebAdminThemeBound = true;
              document.addEventListener('astro:after-swap', applyAdminTheme);
            }
          })();
        </script>
        <AdminShellV2 client:load transition:persist />
        <main class="eb-content ml-[var(--admin-sidebar-width,260px)] min-h-screen pt-[57px] transition-[margin] duration-[280ms] ease-out max-md:ml-0">
          <div class={`mx-auto w-full ${isDashboard ? 'max-w-[1240px] px-6 py-6' : 'max-w-[1400px] p-8 max-md:p-4 max-[480px]:p-3'} max-md:px-4 admin-page scroll-smooth`}>
            <slot />
          </div>
        </main>
      </div>
    ) : (
      <div class="flex min-h-screen bg-[#f9fafb] relative w-full font-sans">
        <AdminShell client:load transition:persist />
        <main class="flex-1 ml-[var(--admin-sidebar-width)] pt-[var(--admin-header-height)] min-h-screen w-[calc(100%-var(--admin-sidebar-width))] transition-[margin,width] duration-[280ms] ease-out max-md:ml-0 max-md:w-full max-md:pt-14">
          <div class="p-8 max-w-[1400px] mx-auto w-full max-md:p-4 max-[480px]:p-3 admin-page scroll-smooth">
            <slot />
          </div>
        </main>
      </div>
    )}
  </body>
</html>
