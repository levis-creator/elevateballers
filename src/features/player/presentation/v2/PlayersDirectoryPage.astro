---
// v2 Players directory. Reuses the shared Header/Footer; the search, team +
// position filters, sort, card grid and pagination are a React+Zustand island.
import Header from "@/features/layout/presentation/v2/Header.astro";
import Footer from "@/features/layout/presentation/v2/Footer.astro";
import PlayersBoard from "./sections/PlayersBoard.tsx";
import { getPlayersDirectoryData } from "@/features/player/domain/usecases/get-players-directory-data";
import { getFooterData } from "@/features/layout/domain/usecases/get-footer-data";

const [data, footer] = await Promise.all([getPlayersDirectoryData(), getFooterData()]);
const totalLabel = `${data.total} registered player${data.total === 1 ? "" : "s"}`;
---

<div class="min-h-screen overflow-x-hidden bg-paper font-body text-ink2">
	<Header active="players" />

	<!-- HERO -->
	<section class="relative overflow-hidden border-b border-black/[0.08]">
		<div class="absolute inset-0" style="background:radial-gradient(120% 80% at 82% -10%,rgba(228,0,43,0.12),transparent 58%);"></div>
		<div class="absolute -top-20 right-[-140px] h-[520px] w-[520px] rounded-full border border-brand/[0.14]"></div>
		<div class="relative mx-auto flex max-w-[1280px] flex-wrap items-end justify-between gap-6 px-8 pb-[40px] pt-[52px] max-[960px]:px-6">
			<div>
				<div class="mb-[18px] inline-flex items-center gap-[10px] font-mono text-[12px] uppercase tracking-[0.14em] text-brand">
					<span class="h-px w-[26px] bg-brand"></span>The Players · Season 2026
				</div>
				<h1 class="font-display text-[clamp(52px,7.5vw,110px)] uppercase leading-[0.86] tracking-[0.01em] text-ink">Players</h1>
			</div>
			<div class="font-mono text-[12px] text-muted2">{totalLabel}</div>
		</div>
	</section>

	<PlayersBoard data={data} client:load />

	<Footer footer={footer} />
</div>
