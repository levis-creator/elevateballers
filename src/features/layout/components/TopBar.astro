---
// TopBar component - Top navigation bar with login, cart, and social links
import { prisma } from "../../../lib/prisma";

let isBannerActive = false;
let bannerText = '';
let bannerLink = '';
let bannerBgColor = '#dd3333'; // Default
let bannerTextColor = '#ffffff'; // Default
let bannerImageUrl = ''; // User uploaded image
let facebookUrl = 'https://www.facebook.com/Elevateballers';
let instagramUrl = 'https://www.instagram.com/elevateballers/';
let youtubeUrl = 'https://www.youtube.com/@elevateballers9389/featured';

try {
  const settings = await prisma.siteSetting.findMany({
    where: {
      key: {
        in: [
          'topbar_banner_active', 
          'topbar_banner_text', 
          'topbar_banner_link',
          'topbar_banner_bg_color',
          'topbar_banner_text_color',
          'topbar_banner_image_url',
          'social_facebook',
          'social_instagram',
          'social_youtube'
        ]
      }
    }
  });

  const settingsMap = settings.reduce((acc, curr) => {
    acc[curr.key] = curr.value;
    return acc;
  }, {} as Record<string, string>);

  isBannerActive = settingsMap['topbar_banner_active'] === 'true';
  bannerText = settingsMap['topbar_banner_text'] || '';
  bannerLink = settingsMap['topbar_banner_link'] || '';
  if (settingsMap['topbar_banner_bg_color']) bannerBgColor = settingsMap['topbar_banner_bg_color'];
  if (settingsMap['topbar_banner_text_color']) bannerTextColor = settingsMap['topbar_banner_text_color'];
  if (settingsMap['topbar_banner_image_url']) bannerImageUrl = settingsMap['topbar_banner_image_url'];
  if (Object.prototype.hasOwnProperty.call(settingsMap, 'social_facebook')) facebookUrl = settingsMap['social_facebook'];
  if (Object.prototype.hasOwnProperty.call(settingsMap, 'social_instagram')) instagramUrl = settingsMap['social_instagram'];
  if (Object.prototype.hasOwnProperty.call(settingsMap, 'social_youtube')) youtubeUrl = settingsMap['social_youtube'];
} catch (error) {
  console.error("Error fetching topbar settings:", error);
}
---

{isBannerActive && bannerText && (
  <div style={`background-color: ${bannerBgColor}; color: ${bannerTextColor}; border-bottom: 1px solid rgba(0,0,0,0.1);`} class="text-center py-2 px-4 w-full font-bold text-sm z-[9999] relative overflow-hidden min-h-[40px] flex items-center justify-center">
    
    {/* Background Image Layer */}
    <div 
      class="absolute inset-0 z-0 bg-cover bg-center"
      style={`
        background-image: url('${bannerImageUrl || '/images/basketball-game-concept-scaled.jpg'}');
        opacity: 0.3; 
      `}
    />

    <div class="container relative z-10">
      {bannerLink ? (
        <a href={bannerLink} style={`color: ${bannerTextColor};`} class="hover:opacity-80 transition-opacity no-underline inline-block">
          {bannerText}
        </a>
      ) : (
        <span>{bannerText}</span>
      )}
    </div>
  </div>
)}

<div id="stm-top-bar" style="background-color:#dd3333 !important;">
  <div class="container">
    <div class="row">
      <div class="col-md-6 col-sm-6">
        <div class="stm-top-bar_left">
          <div class="stm-top-switcher-holder"></div>
        </div>
      </div>
      <div class="col-md-6 col-sm-6">
        <div class="clearfix">
          <div class="stm-top-bar_right">
            <div class="clearfix">
              <div class="stm-top-profile-holder">
                <div class="stm-profile-wrapp">
                  <div class="stm-profile-img icon-mg-icon-ball"></div>
                  <a class="normal_font" href="/admin/login">Log In</a>
                </div>
              </div>
              <div class="stm-top-socials-holder">
                <ul class="top-bar-socials stm-list-duty">
                  {facebookUrl && (
                    <li>
                      <a
                        href={facebookUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <i class="fa fa-facebook"></i>
                      </a>
                    </li>
                  )}
                  {instagramUrl && (
                    <li>
                      <a
                        href={instagramUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <i class="fa fa-instagram"></i>
                      </a>
                    </li>
                  )}
                  {youtubeUrl && (
                    <li>
                      <a
                        href={youtubeUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <i class="fa fa-youtube-play"></i>
                      </a>
                    </li>
                  )}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
