---
// v2 404 — self-contained dark page (minimal nav + "Airball" hero with a
// bouncing-ball animation + quick links + slim footer). No data, no islands.
interface QuickLink {
	label: string;
	sub: string;
	href: string;
}
const quickLinks: QuickLink[] = [
	{ label: "Teams", sub: "All clubs", href: "/teams" },
	{ label: "Standings", sub: "League table", href: "/standings" },
	{ label: "Fixtures", sub: "Schedule", href: "/upcoming-fixtures" },
	{ label: "Results", sub: "Scores", href: "/matches" },
];
const year = new Date().getFullYear();
---

<div class="flex min-h-screen flex-col overflow-x-hidden bg-night font-body text-cream">
	<!-- MINIMAL NAV -->
	<header class="border-b border-white/[0.08]">
		<div class="mx-auto flex max-w-[1280px] items-center justify-between px-8 py-4 max-[960px]:px-6">
			<a href="/" class="flex flex-shrink-0 items-center gap-3 text-inherit no-underline">
				<img src="/images/Elevate_Icon.png" alt="Elevate Ballers" width="38" height="38" class="h-[38px] w-[38px] flex-shrink-0 object-contain" />
				<span class="font-display text-[22px] uppercase leading-[0.9] tracking-[0.02em] text-cream">Elevate<br /><span class="text-brand">Ballers</span></span>
			</a>
			<a href="/" class="rounded border border-white/20 px-5 py-2.5 text-[12px] font-bold uppercase tracking-[0.05em] text-cream no-underline hover:border-brand hover:text-brand">Home</a>
		</div>
	</header>

	<!-- HERO 404 -->
	<main class="relative flex flex-1 items-center overflow-hidden">
		<div class="absolute inset-0" style="background:radial-gradient(90% 90% at 50% 30%,rgba(228,0,43,0.18),transparent 60%);"></div>
		<div class="pointer-events-none absolute left-1/2 top-[64px] h-[420px] w-[420px] -translate-x-1/2 rounded-full border border-brand/[0.14] max-[600px]:hidden"></div>

		<div class="relative mx-auto w-full max-w-[820px] px-8 py-16 text-center max-[960px]:px-6">
			<!-- Backboard + rim + ball -->
			<div class="relative mx-auto mb-10 h-[150px] w-[220px] max-[600px]:mb-8 max-[600px]:scale-90">
				<div class="absolute left-1/2 top-0 h-[92px] w-[150px] -translate-x-1/2 rounded-md border-2 border-white/25 bg-white/[0.04]">
					<div class="absolute left-1/2 top-[26px] h-[42px] w-[54px] -translate-x-1/2 border-2 border-white/25"></div>
				</div>
				<div class="eb404-rim absolute left-1/2 top-[88px] h-[10px] w-[64px] rounded-b-full border-x-2 border-b-2 border-brand"></div>
				<div class="eb404-ball absolute left-1/2 top-[92px] flex h-[46px] w-[46px] items-center justify-center rounded-full bg-brand">
					<span class="absolute inset-0 rounded-full border-2 border-black/30"></span>
					<span class="absolute left-1/2 top-0 h-full w-[2px] -translate-x-1/2 bg-black/30"></span>
					<span class="absolute left-0 top-1/2 h-[2px] w-full -translate-y-1/2 bg-black/30"></span>
				</div>
			</div>

			<div class="mb-5 inline-flex items-center gap-[10px] font-mono text-[12px] uppercase tracking-[0.14em] text-brandsoft">
				<span class="h-px w-[26px] bg-brandsoft"></span>Error 404<span class="h-px w-[26px] bg-brandsoft"></span>
			</div>
			<h1 class="mb-5 font-display text-[clamp(64px,12vw,150px)] uppercase leading-[0.82] tracking-[0.01em] text-cream">Air<span class="text-brand">ball</span></h1>
			<p class="mx-auto mb-9 max-w-[440px] text-[16px] leading-[1.6] text-creamdim">
				That shot missed everything — the page you're looking for isn't on the court. It may have been moved, renamed, or never existed.
			</p>

			<div class="mb-12 flex flex-wrap items-center justify-center gap-3">
				<a href="/" class="rounded bg-brand px-7 py-4 text-[13px] font-extrabold uppercase tracking-[0.05em] text-white no-underline hover:bg-brandlt">Back to Home</a>
				<a href="/standings" class="rounded border border-white/20 px-7 py-4 text-[13px] font-bold uppercase tracking-[0.05em] text-cream no-underline hover:border-brand hover:text-brand">View Standings</a>
			</div>

			<!-- Quick links -->
			<div class="border-t border-white/[0.08] pt-8">
				<div class="mb-5 font-mono text-[11px] uppercase tracking-[0.12em] text-muted2">Try one of these instead</div>
				<div class="mx-auto grid max-w-[560px] grid-cols-4 gap-3 max-[600px]:grid-cols-2">
					{quickLinks.map((q) => (
						<a href={q.href} class="flex flex-col items-center gap-2 rounded-xl border border-white/[0.1] bg-white/[0.03] px-3 py-4 no-underline hover:border-brand/50 hover:bg-white/[0.06]">
							<span class="font-display text-[15px] uppercase text-cream">{q.label}</span>
							<span class="font-mono text-[10px] uppercase tracking-[0.08em] text-muted2">{q.sub}</span>
						</a>
					))}
				</div>
			</div>
		</div>
	</main>

	<!-- SLIM FOOTER -->
	<footer class="border-t border-white/[0.08]">
		<div class="mx-auto flex max-w-[1280px] flex-wrap items-center justify-between gap-3 px-8 py-5 font-mono text-[11px] tracking-[0.04em] text-[#6b635a] max-[960px]:px-6">
			<span>© 2024–{year} Elevate Ballers · All Rights Reserved</span>
			<span>Kenya's Premier Basketball League</span>
		</div>
	</footer>
</div>

<style is:global>
	@keyframes eb404-rimshake {
		0%, 100% { transform: translateX(-50%) rotate(0deg); }
		25% { transform: translateX(-50%) rotate(-3deg); }
		75% { transform: translateX(-50%) rotate(3deg); }
	}
	@keyframes eb404-ballbounce {
		0% { transform: translate(-50%, -140px) scale(1); }
		45% { transform: translate(-50%, 0) scale(1.02); }
		55% { transform: translate(-50%, 0) scale(0.94); }
		100% { transform: translate(-50%, -70px) scale(1); }
	}
	.eb404-rim { animation: eb404-rimshake 2.4s ease-in-out infinite; }
	.eb404-ball { animation: eb404-ballbounce 2.4s ease-in-out infinite; }
	@media (prefers-reduced-motion: reduce) {
		.eb404-rim, .eb404-ball { animation: none; }
	}
</style>
