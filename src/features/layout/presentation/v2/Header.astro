---
// v2 public site header — top utility bar + sticky nav + mobile menu.
// Tailwind utilities throughout (v2 config: brand/ink/paper/night tokens).
interface NavLink {
	label: string;
	href: string;
	key: string;
}

interface Props {
	/** Drives the nav CTA label/style. When false, registration reads "closed". */
	registrationOpen?: boolean;
	/** Key of the active nav link (matches NavLink.key). */
	active?: string;
}

const { registrationOpen = true, active = "home" } = Astro.props;

const navLinks: NavLink[] = [
	{ label: "Home", href: "/", key: "home" },
	{ label: "Teams", href: "/teams", key: "teams" },
	{ label: "Standings", href: "/standings", key: "standings" },
	{ label: "Fixtures", href: "/upcoming-fixtures", key: "fixtures" },
	{ label: "Results", href: "/matches", key: "results" },
	{ label: "About", href: "/about-club", key: "about" },
	{ label: "Rules", href: "/rules", key: "rules" },
	{ label: "Contacts", href: "/contacts", key: "contacts" },
];

const navCtaClass = registrationOpen
	? "flex-shrink-0 rounded bg-brand px-5 py-3 text-[12px] font-extrabold uppercase tracking-[0.06em] text-white no-underline"
	: "flex-shrink-0 rounded border border-black/20 bg-transparent px-5 py-[11px] text-[12px] font-bold uppercase tracking-[0.06em] text-muted no-underline";
const navCtaLabel = registrationOpen ? "2026 Registration" : "Registration Closed";
---

<!-- TOP UTILITY BAR -->
<div class="border-b border-white/[0.06] bg-night">
	<div class="mx-auto flex max-w-[1280px] items-center justify-between px-8 py-2 font-mono text-[11px] uppercase tracking-[0.08em] text-muted2 max-[960px]:px-6 max-[600px]:flex-wrap max-[600px]:gap-x-4 max-[600px]:gap-y-1.5">
		<span>Nairobi, Kenya · Season 2026</span>
		<div class="flex items-center gap-5">
			<span class="flex items-center gap-2"><span class="inline-block h-[7px] w-[7px] rounded-full bg-brand"></span>Live standings updating</span>
			<a href="/admin/login" class="text-cream no-underline">Log In</a>
		</div>
	</div>
</div>

<!-- NAV -->
<header x-data="{ menuOpen: false }" class="sticky top-0 z-50 border-b border-black/10 bg-paper/90 backdrop-blur-md">
	<div class="mx-auto flex max-w-[1280px] items-center justify-between gap-8 px-8 py-4 max-[960px]:px-6">
		<a href="/" class="flex flex-shrink-0 items-center text-inherit no-underline">
			<img src="/logo/Elevate_Logo.png" alt="Elevate Ballers League" class="h-[46px] w-auto max-[600px]:h-[38px]" />
		</a>
		<nav class="flex items-center gap-[26px] text-[13px] font-semibold uppercase tracking-[0.04em] max-[960px]:hidden">
			{navLinks.map((link) => (
				<a href={link.href} class={`no-underline hover:text-brand ${link.key === active ? "text-ink2" : "text-muted"}`}>{link.label}</a>
			))}
		</nav>
		<a href="/league-registration" class={`max-[960px]:hidden ${navCtaClass}`}>{navCtaLabel}</a>
		<!-- Mobile menu toggle (hamburger → X) -->
		<button
			type="button"
			@click="menuOpen = !menuOpen"
			:aria-expanded="menuOpen"
			aria-label="Toggle menu"
			class="hidden h-11 w-11 flex-shrink-0 cursor-pointer flex-col items-center justify-center rounded-lg border border-black/15 bg-transparent max-[960px]:inline-flex"
		>
			<span :style="`display:block;width:20px;height:2px;background:#1a1712;border-radius:2px;transition:transform .2s,opacity .2s;transform:${menuOpen ? 'translateY(6px) rotate(45deg)' : 'none'};`"></span>
			<span :style="`display:block;width:20px;height:2px;background:#1a1712;border-radius:2px;margin:4px 0;transition:opacity .2s;opacity:${menuOpen ? '0' : '1'};`"></span>
			<span :style="`display:block;width:20px;height:2px;background:#1a1712;border-radius:2px;transition:transform .2s,opacity .2s;transform:${menuOpen ? 'translateY(-6px) rotate(-45deg)' : 'none'};`"></span>
		</button>
	</div>

	<!-- Mobile dropdown menu -->
	<div
		x-show="menuOpen"
		x-cloak
		x-transition.opacity.duration.150ms
		class="border-t border-black/10 bg-paper2 px-8 pb-5 pt-2 max-[960px]:px-6"
	>
		<nav class="flex flex-col">
			{navLinks.map((link) => (
				<a
					href={link.href}
					@click="menuOpen = false"
					class="flex items-center justify-between border-b border-black/[0.07] px-1 py-3.5 text-[15px] font-semibold uppercase tracking-[0.04em] text-ink2 no-underline hover:text-brand"
				>
					<span>{link.label}</span>
					<span class="font-mono text-[13px] text-brand">→</span>
				</a>
			))}
			<a
				href="/league-registration"
				@click="menuOpen = false"
				class="mt-4 rounded-md bg-brand px-4 py-[15px] text-center text-[13px] font-extrabold uppercase tracking-[0.06em] text-white no-underline"
			>{navCtaLabel}</a>
		</nav>
	</div>
</header>
