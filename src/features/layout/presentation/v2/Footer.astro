---
// v2 public site footer — contact, explore links, newsletter + socials.
// Reusable across v2 pages. Faithful port of the design (inline styles).
const exploreLinks = [
	{ label: "Teams", href: "/teams" },
	{ label: "Standings", href: "#standings" },
	{ label: "Fixtures & Results", href: "#fixtures" },
	{ label: "About the Club", href: "#about" },
	{ label: "Rules", href: "/rules" },
];
const socials = ["FB", "IG", "YT", "X"];
const year = 2026;
---

<footer id="footer" style="background:#0c0b0a;color:#f3efe9;border-top:1px solid rgba(0,0,0,0.08);">
	<div class="eb-foot eb-pad" style="max-width:1280px;margin:0 auto;padding:60px 32px 30px;display:grid;grid-template-columns:1.4fr 1fr 1.2fr;gap:48px;">
		<div>
			<div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
				<img src="/images/Elevate_Icon.png" alt="Elevate Ballers" width="36" height="36" style="width:36px;height:36px;flex-shrink:0;object-fit:contain;" />
				<span style="font-family:'Anton',sans-serif;font-size:20px;text-transform:uppercase;line-height:0.9;color:#f3efe9;">Elevate<br /><span style="color:#e4002b;">Ballers</span></span>
			</div>
			<p style="font-size:14px;line-height:1.7;color:#8a817a;max-width:280px;">Pepo Lane, off Dagoretti Road, Nairobi.<br />Open Sat–Sun · 8am – 6pm</p>
			<div style="font-family:'Space Mono',monospace;font-size:13px;color:#b8afa6;margin-top:14px;line-height:1.9;">
				0703 913 923 · 0729 259 496<br />ballers@elevateballers.com
			</div>
		</div>
		<div>
			<div style="font-family:'Space Mono',monospace;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#8a817a;margin-bottom:18px;">Explore</div>
			<div style="display:flex;flex-direction:column;gap:11px;font-size:14px;">
				{exploreLinks.map((link) => (
					<a href={link.href} class="eb-footlink" style="color:#c9c1b8;text-decoration:none;">{link.label}</a>
				))}
			</div>
		</div>
		<div>
			<div style="font-family:'Space Mono',monospace;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#8a817a;margin-bottom:18px;">Sign up for email alerts</div>
			<p style="font-size:14px;color:#8a817a;line-height:1.6;margin-bottom:16px;">Select topics and stay current with our latest news.</p>
			<form style="display:flex;gap:8px;" onsubmit="return false;">
				<input type="email" placeholder="your@email.com" style="flex:1;background:#141210;border:1px solid rgba(255,255,255,0.12);border-radius:6px;padding:12px 14px;color:#f3efe9;font-family:'Archivo',sans-serif;font-size:14px;outline:none;" />
				<button type="submit" style="background:#e4002b;color:#fff;border:none;border-radius:6px;font-family:'Archivo',sans-serif;font-weight:800;font-size:13px;text-transform:uppercase;padding:0 18px;cursor:pointer;">Join</button>
			</form>
			<div style="display:flex;gap:10px;margin-top:22px;">
				{socials.map((s) => (
					<a href="#" class="eb-social" style="width:38px;height:38px;border-radius:8px;border:1px solid rgba(255,255,255,0.12);display:flex;align-items:center;justify-content:center;font-family:'Space Mono',monospace;font-size:12px;color:#c9c1b8;text-decoration:none;">{s}</a>
				))}
			</div>
		</div>
	</div>
	<div style="border-top:1px solid rgba(255,255,255,0.06);">
		<div class="eb-pad" style="max-width:1280px;margin:0 auto;padding:20px 32px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;font-family:'Space Mono',monospace;font-size:11px;color:#6b635a;letter-spacing:0.04em;">
			<span>© 2024–{year} Elevate Ballers · All Rights Reserved</span>
			<span>Kenya's Premier Basketball League</span>
		</div>
	</div>
</footer>

<style>
	.eb-footlink:hover { color: #e4002b !important; }
	.eb-social:hover { border-color: #e4002b !important; color: #e4002b !important; }
</style>
