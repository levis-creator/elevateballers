---
// v2 public site footer — contact + socials come from site settings (dynamic),
// explore links are static site navigation.
import type { FooterData } from "@/features/layout/domain/entities/footer";
import { DEFAULT_FOOTER } from "@/features/layout/domain/entities/footer";
import SubscribeFormV2 from "@/features/layout/presentation/v2/SubscribeFormV2.tsx";
import { socialIcon } from "@/features/layout/lib/social-icons";

interface Props {
	footer?: FooterData;
}
const { footer = DEFAULT_FOOTER } = Astro.props;
const { contact, socials, content } = footer;
---

<footer id="footer" class="border-t border-black/[0.08] bg-night text-cream">
	<div class="mx-auto grid max-w-[1280px] grid-cols-[1.4fr_1fr_1.2fr] gap-12 px-8 pb-[30px] pt-[60px] max-[960px]:grid-cols-2 max-[960px]:gap-8 max-[960px]:px-6 max-[600px]:grid-cols-1">
		<div>
			<div class="mb-5">
				<!-- Logo rendered white (brightness-0 invert) so its black wordmark reads on the dark footer. -->
				<img src="/logo/Elevate_Logo.png" alt="Elevate Ballers League" class="h-[44px] w-auto brightness-0 invert" />
			</div>
			<p class="max-w-[280px] text-[14px] leading-[1.7] text-muted2">{contact.address}, Nairobi.<br />Open {contact.hours}</p>
			<div class="mt-3.5 font-mono text-[13px] leading-[1.9] text-creamdim">
				{contact.phone}{contact.fax ? ` · ${contact.fax}` : ""}<br /><a href={`mailto:${contact.email}`} class="text-creamdim no-underline hover:text-brand">{contact.email}</a>
			</div>
		</div>
		<div>
			<div class="mb-[18px] font-mono text-[11px] uppercase tracking-[0.12em] text-muted2">{content.exploreTitle}</div>
			<div class="flex flex-col gap-[11px] text-[14px]">
				{content.exploreLinks.map((link) => (
					<a href={link.href} class="text-[#c9c1b8] no-underline hover:text-brand">{link.label}</a>
				))}
			</div>
		</div>
		<div>
			<div class="mb-[18px] font-mono text-[11px] uppercase tracking-[0.12em] text-muted2">{content.newsletterTitle}</div>
			<p class="mb-4 text-[14px] leading-[1.6] text-muted2">{content.newsletterText}</p>
			<SubscribeFormV2 client:visible />
			<div class="mt-[22px] flex gap-2.5">
				{socials.map((s) => {
					const icon = socialIcon(s.label);
					return (
						<a
							href={s.url}
							target="_blank"
							rel="noopener noreferrer"
							aria-label={icon?.name ?? s.label}
							class="flex h-[38px] w-[38px] items-center justify-center rounded-lg border border-white/[0.12] font-mono text-[12px] text-[#c9c1b8] no-underline hover:border-brand hover:text-brand"
						>
							{icon ? (
								<svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
									<path d={icon.path} />
								</svg>
							) : (
								s.label
							)}
						</a>
					);
				})}
			</div>
		</div>
	</div>
	<div class="border-t border-white/[0.06]">
		<div class="mx-auto flex max-w-[1280px] flex-wrap items-center justify-between gap-3 px-8 py-5 font-mono text-[11px] tracking-[0.04em] text-[#6b635a] max-[960px]:px-6">
			<span>{content.copyright}</span>
			<span><a href="/cookies/" class="text-[#6b635a] no-underline hover:text-brand">Cookie Policy</a></span>
		</div>
	</div>
</footer>
