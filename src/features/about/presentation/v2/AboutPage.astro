---
// v2 About page composition. Reuses the shared Header/Footer. All sections are
// server-rendered (no islands): the stat strip, league cards and venue contacts
// come from `data` (real queries); the prose is editorial content.
import Header from "@/features/layout/presentation/v2/Header.astro";
import Footer from "@/features/layout/presentation/v2/Footer.astro";
import { getAboutData } from "@/features/about/domain/usecases/get-about-data";
import { getFooterData } from "@/features/layout/domain/usecases/get-footer-data";

const [data, footer] = await Promise.all([getAboutData(), getFooterData()]);

const STRIPE = "repeating-linear-gradient(45deg,#e7e2da,#e7e2da 10px,#f0ece5 10px,#f0ece5 20px)";
const STRIPE_LG = "repeating-linear-gradient(45deg,#e7e2da,#e7e2da 12px,#f0ece5 12px,#f0ece5 24px)";

// Per-league card palette (first card dark, rest light).
const palette = (dark: boolean) =>
	dark
		? { card: "background:#0c0b0a;border-color:rgba(255,255,255,0.1);", tag: "background:rgba(228,0,43,0.16);color:#ff5a72;", title: "#f6f2ec", body: "#b8afa6", stat: "#e4002b", sub: "#8a817a", divider: "rgba(255,255,255,0.1)" }
		: { card: "background:#fff;border-color:rgba(0,0,0,0.1);", tag: "background:rgba(228,0,43,0.1);color:#e4002b;", title: "#141009", body: "#6f665c", stat: "#141009", sub: "#8a817a", divider: "rgba(0,0,0,0.08)" };
---

<div class="min-h-screen overflow-x-hidden bg-paper font-body text-ink2">
	<Header active="about" />

	<!-- HERO -->
	<section class="relative overflow-hidden border-b border-black/[0.08] bg-night text-cream">
		<div class="absolute inset-0" style="background:radial-gradient(100% 120% at 78% -10%,rgba(228,0,43,0.22),transparent 58%);"></div>
		<div class="absolute -top-24 right-[-120px] h-[520px] w-[520px] rounded-full border border-brand/[0.16]"></div>
		<div class="absolute right-[-20px] top-10 h-[320px] w-[320px] rounded-full border border-brand/10"></div>
		<div class="relative mx-auto max-w-[1280px] px-8 py-[84px] max-[960px]:px-6 max-[960px]:py-14">
			<div class="mb-[22px] inline-flex items-center gap-[10px] font-mono text-[12px] uppercase tracking-[0.14em] text-brandsoft">
				<span class="h-px w-[26px] bg-brandsoft"></span>{data.hero.eyebrow}
			</div>
			<h1 class="max-w-[880px] font-display text-[clamp(48px,7vw,104px)] uppercase leading-[0.88] tracking-[0.01em]">{data.hero.titleLead} <span class="text-brand">{data.hero.titleAccent}</span></h1>
			<p class="mt-7 max-w-[560px] text-[17px] leading-[1.7] text-creamdim">{data.hero.blurb}</p>
		</div>
	</section>

	<!-- STAT STRIP -->
	<section class="border-b border-black/[0.08] bg-panel">
		<div class="mx-auto grid max-w-[1280px] grid-cols-4 gap-6 px-8 py-9 max-[600px]:grid-cols-2 max-[960px]:px-6">
			{data.stats.map((s) => (
				<div>
					<div class="font-display text-[44px] leading-none" style={`color:${s.accent ? "#e4002b" : "#141009"};`}>{s.value}</div>
					<div class="mt-2 font-mono text-[11px] uppercase tracking-[0.08em] text-muted">{s.label}</div>
				</div>
			))}
		</div>
	</section>

	<!-- STORY -->
	<section class="mx-auto grid max-w-[1280px] grid-cols-[0.9fr_1.1fr] gap-16 px-8 py-[72px] max-[960px]:grid-cols-1 max-[960px]:gap-10 max-[960px]:px-6 max-[960px]:py-12">
		<div>
			<div class="mb-4 font-mono text-[12px] uppercase tracking-[0.14em] text-brand">{data.story.eyebrow}</div>
			<h2 class="font-display text-[clamp(32px,4vw,52px)] uppercase leading-[0.95] text-ink">{data.story.heading}</h2>
			{data.story.image ? (
				<img src={data.story.image} alt={data.story.heading} loading="lazy" class="mt-6 aspect-[4/3] w-full rounded-2xl border border-black/10 object-cover max-[600px]:aspect-[16/10]" />
			) : (
				<div class="mt-6 aspect-[4/3] rounded-2xl border border-black/10 max-[600px]:aspect-[16/10]" style={`background:${STRIPE_LG};`}></div>
			)}
		</div>
		<div class="flex flex-col gap-5 text-[16px] leading-[1.8] text-muted max-[960px]:justify-center">
			{data.story.paragraphs.map((p) => <p>{p}</p>)}
		</div>
	</section>

	<!-- THE LEAGUES -->
	<section class="border-y border-black/[0.08] bg-white">
		<div class="mx-auto max-w-[1280px] px-8 py-[72px] max-[960px]:px-6 max-[960px]:py-12">
			<div class="mb-10 text-center">
				<div class="mb-3 font-mono text-[12px] uppercase tracking-[0.14em] text-brand">{data.leaguesIntro.eyebrow}</div>
				<h2 class="font-display text-[clamp(30px,3.5vw,46px)] uppercase text-ink">{data.leaguesIntro.heading}</h2>
			</div>
			<div class="grid grid-cols-2 gap-6 max-[600px]:grid-cols-1">
				{data.leagues.map((l) => {
					const p = palette(l.dark);
					return (
						<div class="overflow-hidden rounded-2xl border shadow-[0_1px_2px_rgba(20,16,9,0.04)]" style={p.card}>
							<div class="p-7">
								<div class="mb-4 inline-flex items-center gap-2 rounded px-3 py-1.5 font-mono text-[11px] uppercase tracking-[0.1em]" style={p.tag}>{l.abbr}</div>
								<h3 class="font-display text-[26px] uppercase leading-none" style={`color:${p.title};`}>{l.title}</h3>
								<p class="mt-4 text-[15px] leading-[1.7]" style={`color:${p.body};`}>{l.body}</p>
								<div class="mt-6 flex gap-8 border-t pt-5" style={`border-color:${p.divider};`}>
									<div><div class="font-display text-[28px] leading-none" style={`color:${p.stat};`}>{l.teams}</div><div class="mt-1 font-mono text-[10px] uppercase tracking-[0.08em]" style={`color:${p.sub};`}>Teams</div></div>
									<div><div class="font-display text-[28px] leading-none" style={`color:${p.stat};`}>{l.players}</div><div class="mt-1 font-mono text-[10px] uppercase tracking-[0.08em]" style={`color:${p.sub};`}>Players</div></div>
								</div>
							</div>
						</div>
					);
				})}
			</div>
		</div>
	</section>

	<!-- VALUES -->
	<section class="mx-auto max-w-[1280px] px-8 py-[72px] max-[960px]:px-6 max-[960px]:py-12">
		<div class="mb-10">
			<div class="mb-3 font-mono text-[12px] uppercase tracking-[0.14em] text-brand">{data.valuesIntro.eyebrow}</div>
			<h2 class="font-display text-[clamp(30px,3.5vw,46px)] uppercase text-ink">{data.valuesIntro.heading}</h2>
		</div>
		<div class="grid grid-cols-4 gap-5 max-[600px]:grid-cols-1 max-[960px]:grid-cols-2">
			{data.values.map((v) => (
				<div class="rounded-2xl border border-black/10 bg-white p-6 shadow-[0_1px_2px_rgba(20,16,9,0.04)]">
					<div class="mb-4 font-display text-[30px] leading-none text-brand">{v.num}</div>
					<h3 class="font-display text-[19px] uppercase text-ink2">{v.title}</h3>
					<p class="mt-2.5 text-[14px] leading-[1.6] text-muted">{v.body}</p>
				</div>
			))}
		</div>
	</section>

	<!-- TIMELINE -->
	<section class="border-y border-black/[0.08] bg-panel">
		<div class="mx-auto max-w-[1000px] px-8 py-[72px] max-[960px]:px-6 max-[960px]:py-12">
			<div class="mb-10">
				<div class="mb-3 font-mono text-[12px] uppercase tracking-[0.14em] text-brand">{data.timelineIntro.eyebrow}</div>
				<h2 class="font-display text-[clamp(30px,3.5vw,46px)] uppercase text-ink">{data.timelineIntro.heading}</h2>
			</div>
			<div class="flex flex-col">
				{data.timeline.map((t) => (
					<div class="grid grid-cols-[110px_1fr] gap-6 max-[600px]:grid-cols-[70px_1fr]">
						<div class="text-right"><span class="font-display text-[26px] text-brand">{t.year}</span></div>
						<div class="relative border-l-2 border-black/[0.1] pb-9 pl-7 last:pb-0">
							<span class="absolute -left-[7px] top-1.5 h-3 w-3 rounded-full border-2 border-brand bg-panel"></span>
							<h3 class="font-display text-[18px] uppercase text-ink2">{t.title}</h3>
							<p class="mt-1.5 text-[14px] leading-[1.6] text-muted">{t.body}</p>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- LEADERSHIP -->
	<section class="mx-auto max-w-[1280px] px-8 py-[72px] max-[960px]:px-6 max-[960px]:py-12">
		<div class="mb-10">
			<div class="mb-3 font-mono text-[12px] uppercase tracking-[0.14em] text-brand">{data.peopleIntro.eyebrow}</div>
			<h2 class="font-display text-[clamp(30px,3.5vw,46px)] uppercase text-ink">{data.peopleIntro.heading}</h2>
		</div>
		<div class="grid grid-cols-4 gap-5 max-[600px]:grid-cols-2 max-[960px]:grid-cols-2">
			{data.people.map((person) => (
				<div class="overflow-hidden rounded-2xl border border-black/10 bg-white shadow-[0_1px_2px_rgba(20,16,9,0.04)]">
					{person.image ? (
						<img src={person.image} alt={person.name} loading="lazy" class="aspect-square w-full object-cover" />
					) : (
						<div class="aspect-square" style={`background:${STRIPE};`}></div>
					)}
					<div class="p-5">
						<div class="font-body text-[16px] font-extrabold uppercase leading-tight text-ink2">{person.name}</div>
						<div class="mt-1 font-mono text-[11px] uppercase tracking-[0.06em] text-brand">{person.role}</div>
					</div>
				</div>
			))}
		</div>
	</section>

	<!-- VENUE -->
	<section class="border-t border-black/[0.08] bg-white">
		<div class="mx-auto grid max-w-[1280px] grid-cols-[1.1fr_0.9fr] gap-14 px-8 py-[72px] max-[960px]:grid-cols-1 max-[960px]:gap-9 max-[960px]:px-6 max-[960px]:py-12">
			<div>
				<div class="mb-3 font-mono text-[12px] uppercase tracking-[0.14em] text-brand">{data.venue.eyebrow}</div>
				<h2 class="font-display text-[clamp(30px,3.5vw,46px)] uppercase leading-[0.95] text-ink">{data.venue.heading}</h2>
				<p class="mt-6 max-w-[440px] text-[16px] leading-[1.7] text-muted">{data.venue.body}</p>
				<div class="mt-8 flex flex-col gap-4">
					{data.contacts.map((c) => (
						<div class="flex items-start gap-3">
							<span class="mt-0.5 w-[52px] flex-shrink-0 font-mono text-[11px] uppercase tracking-[0.1em] text-brand">{c.k}</span>
							<span class="font-body text-[15px] text-ink2">{c.v}</span>
						</div>
					))}
				</div>
			</div>
			{data.venue.image ? (
				<img src={data.venue.image} alt={data.venue.heading} loading="lazy" class="min-h-[280px] w-full rounded-2xl border border-black/10 object-cover" />
			) : (
				<div class="rounded-2xl border border-black/10" style={`background:${STRIPE_LG};min-height:280px;`}></div>
			)}
		</div>
	</section>

	<!-- CTA -->
	<section class="relative overflow-hidden bg-brand text-white">
		<div class="absolute -bottom-[140px] right-[-100px] h-[420px] w-[420px] rounded-full border-2 border-white/[0.18]"></div>
		<div class="absolute -bottom-10 right-10 h-[220px] w-[220px] rounded-full border-2 border-white/[0.18]"></div>
		<div class="relative mx-auto flex max-w-[1280px] flex-wrap items-center justify-between gap-10 px-8 py-[70px] max-[960px]:px-6">
			<div>
				<h2 class="mb-3.5 font-display text-[clamp(34px,5vw,60px)] uppercase leading-[0.9]">{data.cta.heading}</h2>
				<p class="max-w-[440px] text-[17px] font-semibold">{data.cta.body}</p>
			</div>
			<div class="flex flex-wrap gap-3">
				<a href="/league-registration" class="rounded-md bg-night px-8 py-5 font-display text-[15px] uppercase tracking-[0.06em] text-white no-underline hover:bg-black">Register →</a>
				<a href="/teams" class="rounded-md border-2 border-white/70 px-8 py-5 font-display text-[15px] uppercase tracking-[0.06em] text-white no-underline hover:border-white">Browse Teams</a>
			</div>
		</div>
	</section>

	<Footer footer={footer} />
</div>
