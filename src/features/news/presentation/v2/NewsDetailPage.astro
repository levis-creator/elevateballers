---
// v2 news-article (detail) page. Reuses the shared Header/Footer. The article
// body is the sanitized Quill HTML rendered into `.article-body` (styled by the
// prose CSS below, mirroring the Quill editor output). Comments are a React
// island reusing /api/comments; everything else is server-rendered.
import Header from "@/features/layout/presentation/v2/Header.astro";
import Footer from "@/features/layout/presentation/v2/Footer.astro";
import CommentsSectionV2 from "./CommentsSectionV2.tsx";
import { getFooterData } from "@/features/layout/domain/usecases/get-footer-data";
import type { ArticleView } from "@/features/news/domain/entities/article-v2";

interface Props {
	view: ArticleView;
}
const { view } = Astro.props;
const footer = await getFooterData();

const NEWS_STRIPE = "repeating-linear-gradient(45deg,#e7e2da,#e7e2da 6px,#f0ece5 6px,#f0ece5 12px)";

// Real share-intent links for this article.
const pageUrl = `${Astro.url.origin}/news/${view.slug}/`;
const u = encodeURIComponent(pageUrl);
const t = encodeURIComponent(view.title);
const shares = [
	{ label: "FB", href: `https://www.facebook.com/sharer/sharer.php?u=${u}` },
	{ label: "X", href: `https://twitter.com/intent/tweet?url=${u}&text=${t}` },
	{ label: "WA", href: `https://wa.me/?text=${t}%20${u}` },
	{ label: "IN", href: `https://www.linkedin.com/sharing/share-offsite/?url=${u}` },
];
---

<div class="min-h-screen overflow-x-hidden bg-paper font-body text-ink2">
	<Header active="home" />

	<!-- ARTICLE HEADER -->
	<section class="border-b border-black/[0.08] bg-white">
		<div class="mx-auto max-w-[820px] px-8 pb-10 pt-9 max-[960px]:px-6">
			<div class="mb-5 flex flex-wrap items-center gap-2 font-mono text-[11px] uppercase tracking-[0.06em] text-muted2">
				<a href="/" class="text-muted2 no-underline hover:text-brand">Elevate</a><span class="text-black/20">›</span>
				<a href="/news" class="text-muted2 no-underline hover:text-brand">News</a><span class="text-black/20">›</span>
				<a href={view.categoryHref} class="text-brand no-underline">{view.category}</a>
			</div>
			<div class="mb-4 inline-flex items-center gap-2 rounded-full bg-brand/10 px-3 py-1 font-mono text-[10px] uppercase tracking-[0.1em] text-brand">{view.category}</div>
			<h1 class="font-display text-[clamp(34px,5vw,60px)] uppercase leading-[0.95] text-ink">{view.title}</h1>
			{view.excerpt && <p class="mt-5 max-w-[640px] text-[18px] leading-[1.6] text-muted">{view.excerpt}</p>}
			<div class="mt-6 flex flex-wrap items-center justify-between gap-4 border-t border-black/[0.06] pt-5">
				<div class="flex items-center gap-3">
					<span class="flex h-10 w-10 items-center justify-center rounded-full bg-night font-display text-[13px] text-brand">{view.author.initials}</span>
					<div>
						<div class="font-body text-[14px] font-bold text-ink2">{view.author.name}</div>
						<div class="font-mono text-[11px] text-muted2">{view.dateText}{view.dateText && " · "}{view.readTime}</div>
					</div>
				</div>
				<div class="flex items-center gap-2">
					<span class="mr-1 font-mono text-[10px] uppercase tracking-[0.1em] text-muted2">Share</span>
					{shares.map((s) => (
						<a href={s.href} target="_blank" rel="noopener" aria-label={`Share on ${s.label}`} class="flex h-9 w-9 items-center justify-center rounded-lg border border-black/12 font-mono text-[11px] text-muted no-underline hover:border-brand hover:text-brand">{s.label}</a>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- HERO IMAGE -->
	{view.heroImage && (
		<section class="mx-auto max-w-[1000px] px-8 pt-8 max-[960px]:px-6">
			<img src={view.heroImage} alt={view.title} class="block w-full rounded-2xl border border-black/10 object-cover" style="aspect-ratio:16/9;" loading="eager" />
		</section>
	)}

	<!-- BODY + SIDEBAR -->
	<section class="mx-auto grid max-w-[1200px] grid-cols-[minmax(0,720px)_1fr] gap-14 px-8 py-[48px] max-[960px]:grid-cols-1 max-[960px]:gap-10 max-[960px]:px-6">
		<!-- ARTICLE BODY (sanitized Quill HTML) -->
		<article class="min-w-0">
			<div class="article-body" set:html={view.bodyHtml}></div>

			<!-- TAGS + SHARE FOOTER -->
			<div class="mt-8 flex flex-wrap items-center justify-between gap-4 border-t border-black/[0.06] pt-6">
				<div class="flex flex-wrap gap-2">
					{view.tags.map((tag) => (
						<span class="rounded-full border border-black/12 bg-white px-3 py-1.5 font-mono text-[11px] text-muted">#{tag}</span>
					))}
				</div>
				<div class="flex items-center gap-2">
					{shares.map((s) => (
						<a href={s.href} target="_blank" rel="noopener" aria-label={`Share on ${s.label}`} class="flex h-9 w-9 items-center justify-center rounded-lg border border-black/12 font-mono text-[11px] text-muted no-underline hover:border-brand hover:text-brand">{s.label}</a>
					))}
				</div>
			</div>
		</article>

		<!-- SIDEBAR -->
		<aside class="flex flex-col gap-6">
			<div class="sticky top-[96px] flex flex-col gap-6">
				{view.sidebar.recent.length > 0 && (
					<div class="rounded-2xl border border-black/10 bg-white p-5 shadow-[0_1px_2px_rgba(20,16,9,0.04)]">
						<div class="mb-3 font-mono text-[11px] uppercase tracking-[0.12em] text-muted2">Recent Results</div>
						<div class="flex flex-col gap-2.5">
							{view.sidebar.recent.map((r) => (
								<a href={r.href} class="flex items-center justify-between gap-2 rounded-lg border border-black/[0.07] px-3 py-2.5 no-underline hover:border-brand/40">
									<span class="truncate font-body text-[13px] font-bold" style={`color:${r.hColor};`}>{r.home}</span>
									<span class="flex-shrink-0 font-display text-[15px] text-ink">{r.score}</span>
									<span class="truncate text-right font-body text-[13px] font-bold" style={`color:${r.aColor};`}>{r.away}</span>
								</a>
							))}
						</div>
						<a href="/matches" class="mt-3 inline-block font-mono text-[12px] text-brand no-underline">View all results →</a>
					</div>
				)}

				<div class="rounded-2xl border border-black/10 bg-white p-5 shadow-[0_1px_2px_rgba(20,16,9,0.04)]">
					<div class="mb-3 font-mono text-[11px] uppercase tracking-[0.12em] text-muted2">Categories</div>
					<div class="flex flex-wrap gap-2">
						{view.sidebar.categories.map((c) => (
							<a href={c.href} class="rounded-md border border-black/12 bg-paper2 px-3 py-1.5 font-body text-[12.5px] font-semibold text-ink2 no-underline hover:border-brand hover:text-brand">{c.label}</a>
						))}
					</div>
				</div>

				{view.sidebar.latest.length > 0 && (
					<div class="rounded-2xl border border-black/10 bg-white p-5 shadow-[0_1px_2px_rgba(20,16,9,0.04)]">
						<div class="mb-3 font-mono text-[11px] uppercase tracking-[0.12em] text-muted2">Latest News</div>
						<div class="flex flex-col gap-3.5">
							{view.sidebar.latest.map((n) => (
								<a href={n.href} class="group flex gap-3 no-underline">
									{n.image ? (
										<img src={n.image} alt={n.title} loading="lazy" class="mt-0.5 h-14 w-14 flex-shrink-0 rounded-lg object-cover" />
									) : (
										<span class="mt-0.5 h-14 w-14 flex-shrink-0 rounded-lg" style={`background:${NEWS_STRIPE};`}></span>
									)}
									<span>
										<span class="block font-body text-[13.5px] font-bold leading-[1.3] text-ink2 group-hover:text-brand">{n.title}</span>
										<span class="mt-1 block font-mono text-[10.5px] text-muted2">{n.date}</span>
									</span>
								</a>
							))}
						</div>
					</div>
				)}
			</div>
		</aside>
	</section>

	<!-- COMMENTS -->
	<section class="border-t border-black/[0.08] bg-white">
		<CommentsSectionV2 articleId={view.id} initialComments={view.comments} initialCount={view.commentCount} client:load />
	</section>

	<Footer footer={footer} />
</div>

<style is:global>
	/* .article-body — styles the sanitized HTML emitted by the Quill editor, so
	   authored articles render in the Elevate style with zero per-element classes. */
	.article-body { font-family: 'Archivo', sans-serif; color: #2a251d; }
	.article-body p { font-size: 17px; line-height: 1.8; margin: 0 0 1.25em; text-wrap: pretty; }
	.article-body > :first-child { margin-top: 0; }
	.article-body > :last-child { margin-bottom: 0; }
	.article-body h1, .article-body h2, .article-body h3,
	.article-body h4, .article-body h5, .article-body h6 {
		font-family: 'Anton', sans-serif; text-transform: uppercase; color: #141009; line-height: 1.05;
		letter-spacing: 0.01em; margin: 2.2rem 0 0.9rem;
	}
	.article-body h1 { font-size: 38px; }
	.article-body h2 { font-size: 27px; }
	.article-body h3 { font-size: 22px; }
	.article-body h4 { font-size: 19px; }
	.article-body h5, .article-body h6 { font-size: 16px; color: #6f665c; }
	.article-body a { color: #e4002b; text-decoration: underline; text-underline-offset: 2px; }
	.article-body a:hover { color: #ff2d43; }
	.article-body strong, .article-body b { font-weight: 800; color: #141009; }
	.article-body em, .article-body i { font-style: italic; }
	.article-body u { text-decoration: underline; }
	.article-body s, .article-body strike { text-decoration: line-through; color: #6f665c; }
	.article-body sub { vertical-align: sub; font-size: 0.8em; }
	.article-body sup { vertical-align: super; font-size: 0.8em; }
	.article-body blockquote {
		border-left: 4px solid #e4002b; background: #fff; margin: 2.2rem 0; padding: 1.15rem 1.4rem;
		font-family: 'Anton', sans-serif; text-transform: uppercase; font-size: 23px; line-height: 1.18; color: #141009;
	}
	.article-body blockquote p { font: inherit; margin: 0; }
	.article-body ul, .article-body ol { margin: 0 0 1.25em; padding-left: 1.4em; }
	.article-body li { font-size: 17px; line-height: 1.7; margin-bottom: 0.4em; }
	.article-body ul { list-style: disc; }
	.article-body ol { list-style: decimal; }
	.article-body li[data-list="bullet"] { list-style: disc; }
	.article-body li[data-list="ordered"] { list-style: decimal; }
	.article-body li[data-list="unchecked"], .article-body li[data-list="checked"] { list-style: none; }
	.article-body code { font-family: 'Space Mono', monospace; font-size: 0.9em; background: #efece5; padding: 0.12em 0.4em; border-radius: 4px; color: #141009; }
	.article-body pre, .article-body pre.ql-syntax {
		font-family: 'Space Mono', monospace; font-size: 14px; background: #0c0b0a; color: #f3efe9;
		padding: 1.1rem 1.25rem; border-radius: 12px; overflow-x: auto; margin: 0 0 1.25em; line-height: 1.6;
	}
	.article-body pre code { background: none; padding: 0; color: inherit; }
	.article-body img { display: block; width: 100%; height: auto; border-radius: 12px; margin: 1.5rem 0; border: 1px solid rgba(0,0,0,0.1); }
	.article-body iframe, .article-body .ql-video { display: block; width: 100%; aspect-ratio: 16/9; height: auto; border: 0; border-radius: 12px; margin: 1.5rem 0; }
	.article-body figure { margin: 1.5rem 0; }
	.article-body figcaption { font-family: 'Space Mono', monospace; font-size: 11px; color: #8a817a; text-align: center; margin-top: 0.5rem; }
	.article-body hr { border: 0; border-top: 1px solid rgba(0,0,0,0.12); margin: 2rem 0; }
	.article-body .ql-align-center { text-align: center; }
	.article-body .ql-align-right { text-align: right; }
	.article-body .ql-align-justify { text-align: justify; }
	.article-body .ql-size-small { font-size: 0.82em; }
	.article-body .ql-size-large { font-size: 1.35em; }
	.article-body .ql-size-huge { font-size: 1.8em; }
	.article-body .ql-font-serif { font-family: Georgia, 'Times New Roman', serif; }
	.article-body .ql-font-monospace { font-family: 'Space Mono', monospace; }
	.article-body .ql-direction-rtl { direction: rtl; text-align: inherit; }
	.article-body .ql-indent-1 { padding-left: 2em; }
	.article-body .ql-indent-2 { padding-left: 4em; }
	.article-body .ql-indent-3 { padding-left: 6em; }
	.article-body .ql-indent-4 { padding-left: 8em; }
</style>
