---
// F · Scoreboard skeleton — Match header (dark). Uses translucent-white blocks
// (not the light shimmer) so it reads on the night background.
---

<section class="bg-night">
	<div class="mx-auto max-w-[1000px] px-8 py-[48px] max-[960px]:px-6 max-[960px]:py-9">
		<div class="grid grid-cols-[1fr_auto_1fr] items-center gap-6 rounded-2xl border border-white/10 bg-night2 p-8 max-[600px]:gap-3">
			<div class="flex flex-col items-center gap-4">
				<div class="h-20 w-20 animate-pulse rounded-full bg-white/[0.08]"></div>
				<div class="h-4 w-24 animate-pulse rounded bg-white/[0.08]"></div>
			</div>
			<div class="flex items-center gap-4">
				<div class="h-16 w-12 animate-pulse rounded bg-white/[0.1]"></div>
				<div class="h-6 w-6 animate-pulse rounded bg-white/[0.06]"></div>
				<div class="h-16 w-12 animate-pulse rounded bg-white/[0.1]"></div>
			</div>
			<div class="flex flex-col items-center gap-4">
				<div class="h-20 w-20 animate-pulse rounded-full bg-white/[0.08]"></div>
				<div class="h-4 w-24 animate-pulse rounded bg-white/[0.08]"></div>
			</div>
		</div>
	</div>
</section>
