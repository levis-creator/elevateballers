---
// v2 Standings page composition. Reuses the home Header/Footer; the board
// (hero season selector + podium + table + search) is a React+Zustand island.
import Header from "@/features/layout/presentation/v2/Header.astro";
import Footer from "@/features/layout/presentation/v2/Footer.astro";
import StandingsBoard from "./sections/StandingsBoard.tsx";
import { getStandingsData } from "@/features/standings/domain/usecases/get-standings-data";
import { getFooterData } from "@/features/layout/domain/usecases/get-footer-data";

const [data, footer] = await Promise.all([getStandingsData(), getFooterData()]);
---

<div class="min-h-screen overflow-x-hidden bg-paper font-body text-ink2">
	<Header active="standings" />
	<StandingsBoard rows={data.rows} leagues={data.leagues} seasonLabel={data.seasonLabel} playoffSpots={data.playoffSpots} client:load />
	<Footer footer={footer} />
</div>
