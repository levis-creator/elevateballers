---
// v2 /staff ("League Staff") page — org-wide people grouped by department, as
// person cards (name = main line, role = subtitle). NO team coaches here (those
// render on each team page). Reuses the shared Header/Footer and the reusable
// StaffMemberCard. Data is live LeagueStaff (grouped) with a static fallback.
import Header from "@/features/layout/presentation/v2/Header.astro";
import Footer from "@/features/layout/presentation/v2/Footer.astro";
import StaffMemberCard from "./StaffMemberCard.astro";
import { getStaffData } from "@/features/staff/domain/usecases/get-staff-data";
import { getFooterData } from "@/features/layout/domain/usecases/get-footer-data";

const [data, footer] = await Promise.all([getStaffData(), getFooterData()]);
---

<div class="min-h-screen overflow-x-hidden bg-paper font-body text-ink2">
	<Header active="staff" />

	<!-- HERO -->
	<section class="relative overflow-hidden border-b border-black/[0.08]">
		<div class="absolute inset-0" style="background:radial-gradient(120% 80% at 82% -10%,rgba(228,0,43,0.12),transparent 58%);"></div>
		<div class="absolute -top-20 right-[-140px] h-[520px] w-[520px] rounded-full border border-brand/[0.14]"></div>
		<div class="relative mx-auto max-w-[1280px] px-8 pb-[40px] pt-[52px] max-[960px]:px-6">
			<div class="mb-[18px] inline-flex items-center gap-[10px] font-mono text-[12px] uppercase tracking-[0.14em] text-brand">
				<span class="h-px w-[26px] bg-brand"></span>The People Behind the League
			</div>
			<h1 class="font-display text-[clamp(52px,7.5vw,110px)] uppercase leading-[0.86] tracking-[0.01em] text-ink">League Staff</h1>
			<p class="mt-5 max-w-[560px] text-[16px] leading-[1.7] text-muted">{data.intro}</p>
		</div>
	</section>

	<!-- DEPARTMENTS -->
	{data.departments.map((d, i) => (
		<section class={`mx-auto max-w-[1280px] px-8 py-[40px] max-[960px]:px-6 ${i === 0 ? "pt-[48px] max-[960px]:pt-9" : ""}`}>
			<div class="mb-6 flex items-baseline gap-4">
				<h2 class="font-display text-[26px] uppercase text-ink">{d.name}</h2>
				<span class="h-px flex-1 bg-black/[0.08]"></span>
				<span class="font-mono text-[11px] text-muted2">{d.members.length} member{d.members.length === 1 ? "" : "s"}</span>
			</div>
			<div class="grid grid-cols-4 gap-5 max-[600px]:grid-cols-2 max-[960px]:grid-cols-3">
				{d.members.map((m) => (
					<StaffMemberCard name={m.name} role={m.role} initials={m.initials} email={m.email} image={m.image} />
				))}
			</div>
		</section>
	))}

	<!-- JOIN CTA -->
	<section class="border-t border-black/[0.08] bg-panel">
		<div class="mx-auto max-w-[1280px] px-8 py-[56px] max-[960px]:px-6">
			<div class="flex flex-wrap items-center justify-between gap-6 rounded-2xl bg-night p-9 text-cream max-[600px]:p-6">
				<div>
					<div class="mb-2 font-mono text-[11px] uppercase tracking-[0.12em]" style="color:#ff5a72;">Get Involved</div>
					<h2 class="font-display text-[clamp(26px,3vw,38px)] uppercase leading-[1.02]">Referee, score, or volunteer with us</h2>
					<p class="mt-3 max-w-[480px] text-[14.5px] leading-[1.6] text-creamdim">We're always looking for certified officials, table crew, and match-day volunteers. Join the team that runs Kenya's premier basketball league.</p>
				</div>
				<a href="/contacts" class="flex-shrink-0 rounded-md bg-brand px-7 py-4 font-body text-[13px] font-extrabold uppercase tracking-[0.05em] text-white no-underline hover:bg-brandlt">Get in Touch →</a>
			</div>
		</div>
	</section>

	<Footer footer={footer} />
</div>
