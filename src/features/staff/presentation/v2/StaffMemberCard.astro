---
// Reusable staff person tile: square avatar (photo when available, else striped
// initials), name, role, and an optional "Contact" mailto. Used by the Staff
// page department grids AND the team page's staff section.
interface Props {
	name: string;
	role: string;
	initials: string;
	/** Contact address, or null → hide the Contact link. */
	email?: string | null;
	/** Photo URL, or null → striped-initials avatar. */
	image?: string | null;
}
const { name, role, initials, email = null, image = null } = Astro.props;
const STRIPE = "repeating-linear-gradient(45deg,#e7e2da,#e7e2da 12px,#f0ece5 12px,#f0ece5 24px)";
---

<div class="flex flex-col overflow-hidden rounded-2xl border border-black/10 bg-white shadow-[0_1px_2px_rgba(20,16,9,0.04)]">
	<div class="relative flex aspect-square items-center justify-center overflow-hidden" style={image ? undefined : `background:${STRIPE};`}>
		{image ? (
			<img src={image} alt={name} loading="lazy" class="absolute inset-0 h-full w-full object-cover" />
		) : (
			<span class="font-display text-[34px] text-[#cfc7bb]">{initials}</span>
		)}
	</div>
	<div class="flex flex-1 flex-col p-4">
		<span title={name} class="truncate font-body text-[15px] font-extrabold text-ink2">{name}</span>
		<span title={role} class="mt-0.5 truncate font-mono text-[11px] text-muted2">{role}</span>
		{email && (
			<a href={`mailto:${email}`} class="mt-3 inline-flex items-center gap-1.5 border-t border-black/[0.06] pt-3 font-mono text-[11px] text-brand no-underline hover:underline">✉ Contact</a>
		)}
	</div>
</div>
