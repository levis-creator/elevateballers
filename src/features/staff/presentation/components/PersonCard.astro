---
interface Props {
	name: string;
	role: string;
	photo?: string | null;
	email?: string | null;
	href?: string;
	class?: string;
}

const { name, role, photo, email, href, class: className = "" } = Astro.props;
const initials = name
	.split(/\s+/)
	.filter(Boolean)
	.slice(0, 2)
	.map((word) => word[0])
	.join("")
	.toUpperCase() || "?";
const Tag = href ? "a" : "div";
const STRIPE = "background:repeating-linear-gradient(45deg,#e7e2da,#e7e2da 5px,#f0ece5 5px,#f0ece5 10px);";
---

<Tag href={href} class:list={["person-card", className]}>
	{photo ? (
		<img src={photo} alt={name} loading="lazy" class="person-card__photo" />
	) : (
		<div class="person-card__initials" style={STRIPE}>{initials}</div>
	)}
	<div class="person-card__body">
		<div class="person-card__name">{name}</div>
		<div class="person-card__role">{role}</div>
		{email && <div class="person-card__email">{email}</div>}
	</div>
</Tag>

<style>
	.person-card {
		display: flex;
		align-items: center;
		gap: 16px;
		min-width: 0;
		padding: 20px;
		border: 1px solid rgba(20, 16, 9, 0.1);
		border-radius: 12px;
		background: #fff;
		color: inherit;
		text-decoration: none;
		box-shadow: 0 1px 2px rgba(20, 16, 9, 0.04);
	}

	a.person-card:hover {
		border-color: rgba(228, 0, 43, 0.35);
	}

	.person-card__photo,
	.person-card__initials {
		width: 56px;
		height: 56px;
		flex: 0 0 auto;
		border-radius: 999px;
		border: 1px solid rgba(20, 16, 9, 0.1);
	}

	.person-card__photo {
		object-fit: cover;
	}

	.person-card__initials {
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: Anton, Impact, sans-serif;
		font-size: 18px;
		color: #141009;
	}

	.person-card__body {
		min-width: 0;
	}

	.person-card__name {
		overflow: hidden;
		color: #1a1712;
		font-size: 17px;
		font-weight: 800;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.person-card__role {
		margin-top: 3px;
		color: #e4002b;
		font-family: "Space Mono", monospace;
		font-size: 11px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.person-card__email {
		overflow: hidden;
		margin-top: 6px;
		color: #6f665c;
		font-size: 13px;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
</style>
