---
// v2 public home page — thin composition layer.
// Data is loaded server-side via the getHomeData use-case (Clean Architecture:
// domain use-case → data datasource → real queries, with demo fallbacks).
// Interactive sections (LatestNews, StatsSection, FeaturedMedia) are React
// islands backed by Zustand stores; the rest are server-rendered .astro.
import Header from "@/features/layout/presentation/v2/Header.astro";
import Footer from "@/features/layout/presentation/v2/Footer.astro";
import Hero from "./sections/Hero.astro";
import NewsTicker from "./sections/NewsTicker.astro";
import FixturesResults from "./sections/FixturesResults.astro";
import PlayerOfTheWeek from "./sections/PlayerOfTheWeek.astro";
import LatestNews from "./sections/LatestNews.tsx";
import StatsSection from "./sections/StatsSection.astro";
import FeaturedMedia from "./sections/FeaturedMedia.tsx";
import About from "./sections/About.astro";
import RegisterCta from "./sections/RegisterCta.astro";
import { getHomeData } from "@/features/home/domain/usecases/get-home-data";
import { getFooterData } from "@/features/layout/domain/usecases/get-footer-data";
import { buildHomeJsonLd } from "./lib/structured-data";

const [home, footer] = await Promise.all([getHomeData(), getFooterData()]);
const heroCtaLabel = home.registrationOpen ? "Register Your Team" : "Join the Waitlist";
// Use the canonical site URL (matches SEO.astro's WebSite @id and keeps schema
// URLs on the canonical domain regardless of the request host).
const siteBase = Astro.site ? Astro.site.toString().replace(/\/$/, "") : Astro.url.origin;
const jsonLd = buildHomeJsonLd(siteBase, home, footer.socials.map((s) => s.url));
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

<div class="min-h-screen overflow-x-hidden bg-paper font-body text-ink2">
	<Header registrationOpen={home.registrationOpen} active="home" />
	<Hero heroCtaLabel={heroCtaLabel} nextMatch={home.nextMatch} />
	<NewsTicker items={home.ticker} />
	<FixturesResults upcoming={home.upcoming} results={home.results} />
	<PlayerOfTheWeek potw={home.potw} />
	<LatestNews news={home.news} categories={home.newsCategories} client:visible />
	<StatsSection leaderData={home.leaderData} leaderTabs={home.leaderTabs} counts={home.counts} />
	{home.media.length > 0 && <FeaturedMedia media={home.media} tabs={home.mediaTabs} client:visible />}
	<About />
	<RegisterCta registrationOpen={home.registrationOpen} />
	<Footer footer={footer} />
</div>

