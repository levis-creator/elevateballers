---
// v2 public home page — thin composition layer.
// Data comes from ./data.ts (the seam for wiring real CMS/DB later); each visual
// section is its own component under ./sections/. Keep this file about *what*
// renders and in what order, not *how* each section looks.
import Header from "@/features/layout/presentation/v2/Header.astro";
import Footer from "@/features/layout/presentation/v2/Footer.astro";
import Hero from "./sections/Hero.astro";
import NewsTicker from "./sections/NewsTicker.astro";
import FixturesResults from "./sections/FixturesResults.astro";
import PlayerOfTheWeek from "./sections/PlayerOfTheWeek.astro";
import LatestNews from "./sections/LatestNews.astro";
import StatsSection from "./sections/StatsSection.astro";
import FeaturedMedia from "./sections/FeaturedMedia.astro";
import About from "./sections/About.astro";
import RegisterCta from "./sections/RegisterCta.astro";
import {
	ticker,
	upcoming,
	results,
	news,
	newsCategories,
	leaderData,
	leaderTabs,
	countTargets,
	media,
	mediaTabs,
} from "./data";

// Single source of truth for registration state. Replace with a CMS flag, a date
// window, or a live API value. Drives the nav CTA, hero CTA and register band.
const registrationOpen = true;
const heroCtaLabel = registrationOpen ? "Register Your Team" : "Join the Waitlist";
---

<div class="min-h-screen overflow-x-hidden bg-paper font-body text-ink2">
	<Header registrationOpen={registrationOpen} active="home" />
	<Hero heroCtaLabel={heroCtaLabel} />
	<NewsTicker items={ticker} />
	<FixturesResults upcoming={upcoming} results={results} />
	<PlayerOfTheWeek />
	<LatestNews news={news} categories={newsCategories} />
	<StatsSection leaderData={leaderData} leaderTabs={leaderTabs} countTargets={countTargets} />
	<FeaturedMedia media={media} tabs={mediaTabs} />
	<About />
	<RegisterCta registrationOpen={registrationOpen} />
	<Footer />
</div>
