---
// v2 public home page — Tailwind rebuild of the standalone design.
// Static sections render server-side; the interactive parts (news filter,
// league-leaders tabs, featured-media tabs, count-up) run on Alpine.js.
// Design tokens (brand/ink/paper/night/cream, fonts display/body/mono) come from
// the v2-only Tailwind config wired via @config in src/styles/v2.css.
//
// NOTE: ports the design's demo data verbatim — wire to real CMS/DB later.
import Header from "@/features/layout/presentation/v2/Header.astro";
import Footer from "@/features/layout/presentation/v2/Footer.astro";

// Single source of truth for registration state. Replace with a CMS flag, a date
// window, or a live API value. Drives the nav CTA, hero CTA and register band.
const registrationOpen = true;
const heroCtaLabel = registrationOpen ? "Register Your Team" : "Join the Waitlist";

const ticker = [
	"Queens storm into the EWBL final",
	"City Hawks host Alliance Queens this Saturday",
	"Travious Kitondo named Player of the Week",
	"Coast Waves climb to 2nd in the standings",
	"2026 League registration now open",
];

const upcoming = [
	{ day: "05", mon: "Jul", home: "City Hawks", away: "Alliance Queens", venue: "Nyayo Stadium", time: "4:00 PM" },
	{ day: "06", mon: "Jul", home: "Nairobi Thunder", away: "Coast Waves", venue: "Aga Khan Court", time: "2:30 PM" },
	{ day: "08", mon: "Jul", home: "CBA Jets", away: "Rift Valley Rangers", venue: "Nyayo Stadium", time: "6:00 PM" },
];

const results = [
	{ home: "CBA Jets", hs: 78, away: "City Hawks", as: 74 },
	{ home: "Alliance Queens", hs: 65, away: "Eldoret Blaze", as: 52 },
	{ home: "Coast Waves", hs: 81, away: "Kisumu Lakers", as: 69 },
].map((r) => ({
	...r,
	homeColor: r.hs > r.as ? "#141009" : "#a49a8d",
	awayColor: r.as > r.hs ? "#141009" : "#a49a8d",
}));

// --- Interactive data (handed to Alpine) ---
const allNews = [
	{ cat: "Championships", title: "Queens Storm Into the EWBL Final", excerpt: "A dominant fourth quarter sealed a spot in the championship game for the reigning favorites.", date: "Jul 1, 2026" },
	{ cat: "Match report", title: "City Hawks Edge CBA Jets in Overtime Thriller", excerpt: "Two clutch free throws in the final seconds decided a game that had everything.", date: "Jun 29, 2026" },
	{ cat: "Interviews", title: "Travious Kitondo on Ice-Cold Shooting", excerpt: "The Player of the Week sits down to talk footwork, confidence, and big dreams.", date: "Jun 28, 2026" },
	{ cat: "Analysis", title: "Why the Three Is Reshaping the League", excerpt: "The math behind the shot that is changing how every team builds its offense.", date: "Jun 26, 2026" },
	{ cat: "Match report", title: "Coast Waves Sink Rift Valley Rangers", excerpt: "A wire-to-wire performance keeps the Waves firmly in the playoff hunt.", date: "Jun 24, 2026" },
	{ cat: "Championships", title: "Road to the 2026 Finals: What to Watch", excerpt: "The storylines, the matchups, and the players who will decide the title.", date: "Jun 22, 2026" },
];
const newsCategories = ["All", "Interviews", "Championships", "Match report", "Analysis"];

const leaderData = {
	Points: [
		{ name: "Travious Kitondo", team: "CBA Jets", val: 24.8 },
		{ name: "Brian Otieno", team: "City Hawks", val: 22.1 },
		{ name: "Faith Mwangi", team: "Alliance Queens", val: 20.6 },
		{ name: "Kevin Barasa", team: "Nairobi Thunder", val: 19.4 },
		{ name: "Aisha Noor", team: "Coast Waves", val: 18.9 },
	],
	Rebounds: [
		{ name: "Kevin Barasa", team: "Nairobi Thunder", val: 12.7 },
		{ name: "Mercy Achieng", team: "Alliance Queens", val: 11.4 },
		{ name: "Samuel Kiptoo", team: "Rift Valley Rangers", val: 10.8 },
		{ name: "Brian Otieno", team: "City Hawks", val: 9.6 },
		{ name: "Grace Wanjiru", team: "Coast Waves", val: 9.1 },
	],
	Assists: [
		{ name: "Faith Mwangi", team: "Alliance Queens", val: 8.9 },
		{ name: "Dennis Mutua", team: "City Hawks", val: 7.7 },
		{ name: "Aisha Noor", team: "Coast Waves", val: 6.8 },
		{ name: "Travious Kitondo", team: "CBA Jets", val: 6.2 },
		{ name: "John Kamau", team: "Eldoret Blaze", val: 5.9 },
	],
};
const leaderTabs = ["Points", "Rebounds", "Assists"];

const countTargets = { matches: 214, players: 372, teams: 24, awards: 18 };

const allMedia = [
	{ type: "Images", label: "game photo", span: true },
	{ type: "Audio", label: "podcast clip", span: false },
	{ type: "Images", label: "court shot", span: false },
	{ type: "Images", label: "action photo", span: false },
	{ type: "Audio", label: "post-game audio", span: false },
	{ type: "Images", label: "crowd photo", span: true },
];
const mediaTabs = ["All", "Images", "Audio"];

// Tab pill styles (active/inactive), applied via Alpine :style. font-family is
// inherited from the page (font-body), so it's omitted here.
const TAB_ACTIVE = "background:#e4002b;color:#fff;border:1px solid #e4002b;font-weight:700;font-size:12px;letter-spacing:0.04em;text-transform:uppercase;padding:9px 15px;border-radius:6px;cursor:pointer;";
const TAB_INACTIVE = "background:#fff;color:#6f665c;border:1px solid rgba(0,0,0,0.15);font-weight:600;font-size:12px;letter-spacing:0.04em;text-transform:uppercase;padding:9px 15px;border-radius:6px;cursor:pointer;";
---

<div class="min-h-screen overflow-x-hidden bg-paper font-body text-ink2">
	<Header registrationOpen={registrationOpen} active="home" />

	<!-- HERO -->
	<section class="relative overflow-hidden border-b border-black/[0.08]">
		<div class="absolute inset-0" style="background:radial-gradient(120% 80% at 82% -10%,rgba(228,0,43,0.12),transparent 58%);"></div>
		<div class="absolute -top-20 right-[-140px] h-[520px] w-[520px] rounded-full border border-brand/[0.14]"></div>
		<div class="absolute right-[-40px] top-5 h-[340px] w-[340px] rounded-full border border-brand/10"></div>
		<div class="relative mx-auto grid max-w-[1280px] grid-cols-[1.15fr_0.85fr] items-center gap-14 px-8 pb-[60px] pt-[72px] max-[960px]:grid-cols-1 max-[960px]:gap-9 max-[960px]:px-6 max-[960px]:pt-12">
			<div>
				<div class="mb-[22px] inline-flex items-center gap-[10px] font-mono text-[12px] uppercase tracking-[0.14em] text-brand">
					<span class="h-px w-[26px] bg-brand"></span>Kenya's Premier Basketball League
				</div>
				<h1 class="mb-6 font-display text-[clamp(56px,7vw,104px)] uppercase leading-[0.86] tracking-[0.01em] text-ink">
					Elevate<br />your <span class="text-brand">game</span>
				</h1>
				<p class="mb-[34px] max-w-[460px] text-[17px] leading-[1.6] text-muted">
					Live matches, standings, and rising stars from the courts of Nairobi. Follow every game, every team, every player — all season long.
				</p>
				<div class="flex flex-wrap items-center gap-4 max-[600px]:flex-col max-[600px]:items-start">
					<a href="#register" class="rounded bg-brand px-7 py-4 text-[14px] font-extrabold uppercase tracking-[0.04em] text-white no-underline hover:bg-brandlt max-[600px]:w-full max-[600px]:text-center">{heroCtaLabel}</a>
					<a href="#standings" class="rounded border border-black/20 px-7 py-4 text-[14px] font-bold uppercase tracking-[0.04em] text-ink2 no-underline hover:border-brand hover:text-brand max-[600px]:w-full max-[600px]:text-center">View Standings</a>
				</div>
			</div>

			<!-- NEXT MATCH CARD -->
			<div class="overflow-hidden rounded-xl border border-black/10 bg-night2 shadow-[0_26px_50px_rgba(20,16,9,0.22)]">
				<div class="flex items-center justify-between border-b border-white/[0.08] bg-black px-[18px] py-[14px]">
					<span class="font-mono text-[11px] uppercase tracking-[0.12em] text-brand">Next Match</span>
					<span class="font-mono text-[11px] text-muted2">Jul 5, 2026 · 4:00 PM</span>
				</div>
				<div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2 px-[18px] py-[26px]">
					<div class="flex flex-col items-center gap-3 text-center">
						<div class="flex h-16 w-16 items-center justify-center rounded-full font-display text-[22px] text-brand" style="background:repeating-linear-gradient(45deg,#221d18,#221d18 6px,#1b1712 6px,#1b1712 12px);">CH</div>
						<div>
							<div class="font-display text-[16px] uppercase text-cream">City Hawks</div>
							<div class="font-mono text-[10px] tracking-[0.1em] text-muted2">HOME</div>
						</div>
					</div>
					<div class="font-display text-[20px] text-[#6b635a]">VS</div>
					<div class="flex flex-col items-center gap-3 text-center">
						<div class="flex h-16 w-16 items-center justify-center rounded-full font-display text-[22px] text-cream" style="background:repeating-linear-gradient(45deg,#221d18,#221d18 6px,#1b1712 6px,#1b1712 12px);">AG</div>
						<div>
							<div class="font-display text-[15px] uppercase leading-none text-cream">Alliance Queens</div>
							<div class="font-mono text-[10px] tracking-[0.1em] text-muted2">AWAY</div>
						</div>
					</div>
				</div>
				<div class="px-[18px] pb-[18px]">
					<a href="#fixtures" class="block rounded-md border border-brand/30 bg-brand/[0.14] py-[13px] text-center text-[12px] font-bold uppercase tracking-[0.08em] text-brandsoft no-underline hover:bg-brand/[0.24]">View Match · Nyayo Stadium</a>
				</div>
			</div>
		</div>
	</section>

	<!-- NEWS TICKER -->
	<div class="flex items-center overflow-hidden whitespace-nowrap bg-brand text-white">
		<span class="flex-shrink-0 bg-night px-5 py-3 font-display text-[14px] uppercase tracking-[0.1em] text-white">Elevate News</span>
		<div class="flex-1 overflow-hidden">
			<div class="inline-flex animate-marquee font-mono text-[13px] font-bold">
				<div class="inline-flex">
					{ticker.map((t) => (
						<span class="inline-flex items-center gap-7 px-7 py-3">{t}<span class="inline-block h-1.5 w-1.5 rounded-full bg-white"></span></span>
					))}
				</div>
				<div class="inline-flex" aria-hidden="true">
					{ticker.map((t) => (
						<span class="inline-flex items-center gap-7 px-7 py-3">{t}<span class="inline-block h-1.5 w-1.5 rounded-full bg-white"></span></span>
					))}
				</div>
			</div>
		</div>
	</div>

	<!-- FIXTURES & RESULTS -->
	<section id="fixtures" class="mx-auto grid max-w-[1280px] grid-cols-2 gap-10 px-8 py-[72px] max-[960px]:grid-cols-1 max-[960px]:gap-9 max-[960px]:px-6 max-[960px]:py-[52px]">
		<div>
			<div class="mb-6 flex items-baseline justify-between">
				<h2 class="font-display text-[30px] uppercase tracking-[0.01em] text-ink">Upcoming Matches</h2>
				<a href="#fixtures" class="font-mono text-[12px] tracking-[0.06em] text-brand no-underline">All fixtures →</a>
			</div>
			<div class="flex flex-col gap-3">
				{upcoming.map((m) => (
					<div class="flex min-h-[142px] flex-col justify-between gap-3 rounded-[10px] border border-black/10 bg-white px-[18px] pb-4 pt-3.5 shadow-[0_1px_2px_rgba(20,16,9,0.04)] hover:border-brand/40">
						<div class="flex items-center justify-between gap-2">
							<span class="rounded bg-brand/[0.08] px-[9px] py-[3px] font-mono text-[10px] uppercase tracking-[0.12em] text-brand">{m.day} {m.mon} · {m.time}</span>
							<span class="font-mono text-[11px] text-muted2">{m.venue}</span>
						</div>
						<div class="flex flex-col gap-[11px]">
							<div class="flex items-center gap-3">
								<div class="h-[30px] w-[30px] flex-shrink-0 rounded-full" style="background:repeating-linear-gradient(45deg,#e7e2da,#e7e2da 5px,#f0ece5 5px,#f0ece5 10px);"></div>
								<span class="flex-1 font-body text-[15px] font-bold text-ink2">{m.home}</span>
								<span class="font-mono text-[10px] tracking-[0.1em] text-[#a49a8d]">HOME</span>
							</div>
							<div class="flex items-center gap-3">
								<div class="h-[30px] w-[30px] flex-shrink-0 rounded-full" style="background:repeating-linear-gradient(45deg,#e7e2da,#e7e2da 5px,#f0ece5 5px,#f0ece5 10px);"></div>
								<span class="flex-1 font-body text-[15px] font-bold text-ink2">{m.away}</span>
								<span class="font-mono text-[10px] tracking-[0.1em] text-[#a49a8d]">AWAY</span>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
		<div id="standings">
			<div class="mb-6 flex items-baseline justify-between">
				<h2 class="font-display text-[30px] uppercase tracking-[0.01em] text-ink">Recent Results</h2>
				<a href="/standings" class="font-mono text-[12px] tracking-[0.06em] text-brand no-underline">All results →</a>
			</div>
			<div class="flex flex-col gap-3">
				{results.map((r) => (
					<div class="flex min-h-[142px] flex-col justify-between gap-3 rounded-[10px] border border-black/10 bg-white px-[18px] pb-4 pt-3.5 shadow-[0_1px_2px_rgba(20,16,9,0.04)] hover:border-brand/40">
						<span class="self-start rounded bg-[#f0ede7] px-[9px] py-[3px] font-mono text-[10px] uppercase tracking-[0.12em] text-[#a49a8d]">Final</span>
						<div class="flex flex-col gap-[11px]">
							<div class="flex items-center gap-3">
								<div class="h-[30px] w-[30px] flex-shrink-0 rounded-full" style="background:repeating-linear-gradient(45deg,#e7e2da,#e7e2da 5px,#f0ece5 5px,#f0ece5 10px);"></div>
								<span class="flex-1 font-body text-[15px] font-bold" style={`color:${r.homeColor};`}>{r.home}</span>
								<span class="font-display text-[22px]" style={`color:${r.homeColor};`}>{r.hs}</span>
							</div>
							<div class="flex items-center gap-3">
								<div class="h-[30px] w-[30px] flex-shrink-0 rounded-full" style="background:repeating-linear-gradient(45deg,#e7e2da,#e7e2da 5px,#f0ece5 5px,#f0ece5 10px);"></div>
								<span class="flex-1 font-body text-[15px] font-bold" style={`color:${r.awayColor};`}>{r.away}</span>
								<span class="font-display text-[22px]" style={`color:${r.awayColor};`}>{r.as}</span>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- PLAYER OF THE WEEK -->
	<section class="relative overflow-hidden border-t border-black/[0.08] bg-night text-cream">
		<div class="absolute inset-0" style="background:radial-gradient(90% 120% at 10% 50%,rgba(228,0,43,0.16),transparent 55%);"></div>
		<div class="relative mx-auto grid max-w-[1280px] grid-cols-[0.85fr_1.15fr] items-center gap-14 px-8 py-[72px] max-[960px]:grid-cols-1 max-[960px]:gap-9 max-[960px]:px-6 max-[960px]:py-[52px]">
			<div class="relative">
				<div class="flex aspect-[4/5] items-center justify-center rounded-[14px] border border-white/10 max-[600px]:max-w-[320px]" style="background:repeating-linear-gradient(45deg,#1a1714,#1a1714 12px,#151210 12px,#151210 24px);">
					<span class="font-mono text-[12px] uppercase tracking-[0.14em] text-[#6b635a]">player photo</span>
				</div>
				<div class="absolute -bottom-3.5 -left-3.5 rounded-md bg-brand px-4 py-2.5 font-display text-[14px] uppercase tracking-[0.06em] text-white">CBA Jets · #7</div>
			</div>
			<div>
				<div class="mb-4 font-mono text-[12px] uppercase tracking-[0.14em] text-brandsoft">Player of the Week</div>
				<h2 class="mb-2.5 font-display text-[clamp(40px,5vw,68px)] uppercase leading-[0.9] text-[#f6f2ec]">Travious<br />Kitondo</h2>
				<div class="mb-[22px] font-display text-[20px] tracking-[0.06em] text-brand">DYNAMITE.</div>
				<p class="mb-[18px] max-w-[520px] text-[16px] leading-[1.7] text-creamdim">
					Size, physicality, strength — none of which Travious has. But inside that lean frame is a mean competitor, a silent assassin afraid of no one on the court. All game long she was quiet, calculating and methodical as she tore City Hawks to shreds.
				</p>
				<p class="mb-7 max-w-[520px] text-[16px] leading-[1.7] text-creamdim">
					Spot-up three, contested catch-and-shoot three, and a deadly side-step three closed out CBA Jets' final 14 points — officially slamming the door on a much-needed win.
				</p>
				<div class="flex gap-10">
					<div><div class="font-display text-[34px] text-cream">27</div><div class="font-mono text-[11px] uppercase tracking-[0.08em] text-muted2">Points</div></div>
					<div><div class="font-display text-[34px] text-cream">6</div><div class="font-mono text-[11px] uppercase tracking-[0.08em] text-muted2">Threes</div></div>
					<div><div class="font-display text-[34px] text-cream">5</div><div class="font-mono text-[11px] uppercase tracking-[0.08em] text-muted2">Assists</div></div>
				</div>
			</div>
		</div>
	</section>

	<!-- LATEST NEWS (Alpine: category filter) -->
	<section class="mx-auto max-w-[1280px] px-8 py-[72px] max-[960px]:px-6 max-[960px]:py-[52px]" x-data={`{ cat: 'All', news: ${JSON.stringify(allNews)} }`}>
		<div class="mb-7 flex flex-wrap items-end justify-between gap-6">
			<div>
				<div class="mb-2.5 font-mono text-[12px] uppercase tracking-[0.14em] text-brand">From around the league</div>
				<h2 class="font-display text-[38px] uppercase text-ink">Latest News</h2>
			</div>
			<div class="flex flex-wrap gap-2">
				{newsCategories.map((c) => (
					<button @click={`cat = '${c}'`} :style={`cat === '${c}' ? '${TAB_ACTIVE}' : '${TAB_INACTIVE}'`} class="hover:!border-brand">{c}</button>
				))}
			</div>
		</div>
		<div class="grid grid-cols-3 gap-5 max-[960px]:grid-cols-2 max-[600px]:grid-cols-1">
			<template x-for="n in (cat === 'All' ? news : news.filter(x => x.cat === cat))" :key="n.title">
				<a href="/news" class="flex flex-col overflow-hidden rounded-xl border border-black/10 bg-white text-inherit no-underline shadow-[0_1px_2px_rgba(20,16,9,0.04)] hover:border-brand/40">
					<div class="flex aspect-[16/10] items-center justify-center" style="background:repeating-linear-gradient(45deg,#e7e2da,#e7e2da 10px,#f0ece5 10px,#f0ece5 20px);">
						<span class="font-mono text-[11px] uppercase tracking-[0.12em] text-[#a49a8d]">article image</span>
					</div>
					<div class="flex flex-1 flex-col p-5">
						<span class="mb-2.5 font-mono text-[10px] uppercase tracking-[0.12em] text-brand" x-text="n.cat"></span>
						<h3 class="mb-2.5 font-body text-[18px] font-extrabold leading-[1.25] text-ink2" x-text="n.title"></h3>
						<p class="flex-1 text-[13.5px] leading-[1.55] text-muted" x-text="n.excerpt"></p>
						<span class="mt-3.5 font-mono text-[11px] text-[#a49a8d]" x-text="n.date"></span>
					</div>
				</a>
			</template>
		</div>
	</section>

	<!-- LEAGUE LEADERS + BY THE NUMBERS (Alpine: tabs + count-up) -->
	<section class="border-y border-black/[0.08] bg-panel">
		<div class="mx-auto grid max-w-[1280px] grid-cols-2 items-start gap-14 px-8 py-[72px] max-[960px]:grid-cols-1 max-[960px]:gap-9 max-[960px]:px-6 max-[960px]:py-[52px]">
			<div x-data={`{
				tab: 'Points',
				data: ${JSON.stringify(leaderData)},
				get list() {
					const arr = this.data[this.tab];
					const max = Math.max(...arr.map(p => p.val));
					return arr.map((p, i) => ({ name: p.name, team: p.team, rank: i + 1, first: i === 0, pct: Math.round((p.val / max) * 100), val: p.val.toFixed(1) }));
				}
			}`}>
				<div class="mb-[22px] flex items-baseline justify-between">
					<h2 class="font-display text-[32px] uppercase text-ink">League Leaders</h2>
					<a href="/stats/leaders" class="font-mono text-[12px] text-brand no-underline">All stats →</a>
				</div>
				<div class="mb-5 flex gap-2">
					{leaderTabs.map((t) => (
						<button @click={`tab = '${t}'`} :style={`tab === '${t}' ? '${TAB_ACTIVE}' : '${TAB_INACTIVE}'`}>{t}</button>
					))}
				</div>
				<div class="flex flex-col gap-0.5">
					<template x-for="p in list" :key="p.name">
						<div class="flex items-center gap-4 border-b border-black/[0.08] px-1 py-3.5">
							<span class="w-[26px] font-display text-[20px]" :style="`color:${p.first ? '#e4002b' : '#b3a99c'}`" x-text="p.rank"></span>
							<div class="h-10 w-10 flex-shrink-0 rounded-full bg-[#ddd7cd]"></div>
							<div class="flex-1">
								<div class="font-body text-[15px] font-bold text-ink2" x-text="p.name"></div>
								<div class="font-mono text-[11px] text-muted2" x-text="p.team"></div>
							</div>
							<div class="max-w-[160px] flex-[1.2]">
								<div class="h-1.5 overflow-hidden rounded-[3px] bg-black/[0.08]">
									<div class="h-full rounded-[3px]" :style="`width:${p.pct}%;background:${p.first ? '#e4002b' : 'rgba(228,0,43,0.4)'}`"></div>
								</div>
							</div>
							<span class="w-14 text-right font-display text-[22px] text-ink" x-text="p.val"></span>
						</div>
					</template>
				</div>
			</div>

			<div x-data={`{
				counts: { matches: 0, players: 0, teams: 0, awards: 0 },
				init() {
					const targets = ${JSON.stringify(countTargets)};
					const start = performance.now();
					const dur = 1400;
					const tick = (now) => {
						const p = Math.min(1, (now - start) / dur);
						const e = 1 - Math.pow(1 - p, 3);
						this.counts = {
							matches: Math.round(targets.matches * e),
							players: Math.round(targets.players * e),
							teams: Math.round(targets.teams * e),
							awards: Math.round(targets.awards * e),
						};
						if (p < 1) requestAnimationFrame(tick);
					};
					requestAnimationFrame(tick);
				}
			}`}>
				<h2 class="mb-[22px] font-display text-[32px] uppercase text-ink">By The Numbers</h2>
				<div class="grid grid-cols-2 gap-4">
					<div class="rounded-xl border border-black/10 bg-white p-[26px] shadow-[0_1px_2px_rgba(20,16,9,0.04)]">
						<div class="font-display text-[52px] leading-none text-brand" x-text="counts.matches"></div>
						<div class="mt-2 font-mono text-[12px] uppercase tracking-[0.08em] text-muted">Matches Played</div>
					</div>
					<div class="rounded-xl border border-black/10 bg-white p-[26px] shadow-[0_1px_2px_rgba(20,16,9,0.04)]">
						<div class="font-display text-[52px] leading-none text-ink" x-text="counts.players"></div>
						<div class="mt-2 font-mono text-[12px] uppercase tracking-[0.08em] text-muted">Players</div>
					</div>
					<div class="rounded-xl border border-black/10 bg-white p-[26px] shadow-[0_1px_2px_rgba(20,16,9,0.04)]">
						<div class="font-display text-[52px] leading-none text-ink" x-text="counts.teams"></div>
						<div class="mt-2 font-mono text-[12px] uppercase tracking-[0.08em] text-muted">Teams</div>
					</div>
					<div class="rounded-xl border border-black/10 bg-white p-[26px] shadow-[0_1px_2px_rgba(20,16,9,0.04)]">
						<div class="font-display text-[52px] leading-none text-brand" x-text="counts.awards"></div>
						<div class="mt-2 font-mono text-[12px] uppercase tracking-[0.08em] text-muted">Awards Won</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- FEATURED MEDIA (Alpine: tabs + empty state) -->
	<section class="mx-auto max-w-[1280px] px-8 py-[72px] max-[960px]:px-6 max-[960px]:py-[52px]" x-data={`{
		tab: 'All',
		all: ${JSON.stringify(allMedia)},
		get items() { return this.tab === 'All' ? this.all : this.all.filter(m => m.type === this.tab); },
		get emptyTitle() { return this.tab === 'All' ? 'No featured media yet' : (this.tab === 'Audio' ? 'No audio clips yet' : 'No images yet'); },
		get emptyBody() { return this.tab === 'All' ? 'Photos, audio and highlights from match days will appear here as the season plays out.' : ('Nothing tagged ' + this.tab.toLowerCase() + ' right now — check back after the next match day.'); }
	}`}>
		<div class="mb-7 flex flex-wrap items-end justify-between gap-6">
			<div>
				<div class="mb-2.5 font-mono text-[12px] uppercase tracking-[0.14em] text-brand">Visual highlights from across the league</div>
				<h2 class="font-display text-[38px] uppercase text-ink">Featured Media</h2>
			</div>
			<div class="flex gap-2">
				{mediaTabs.map((t) => (
					<button @click={`tab = '${t}'`} :style={`tab === '${t}' ? '${TAB_ACTIVE}' : '${TAB_INACTIVE}'`}>{t}</button>
				))}
			</div>
		</div>
		<div class="grid grid-cols-4 gap-3.5 max-[600px]:grid-cols-1" style="grid-auto-rows:180px;" x-show="items.length > 0">
			<template x-for="mi in items" :key="mi.label">
				<div class="flex items-center justify-center rounded-xl border border-black/10" :class="mi.span ? 'col-span-2' : ''" :style="`background:${mi.type === 'Audio' ? 'linear-gradient(135deg,#ece7df,#f4f0ea)' : 'repeating-linear-gradient(45deg,#e7e2da,#e7e2da 10px,#f0ece5 10px,#f0ece5 20px)'};`">
					<span class="font-mono text-[11px] uppercase tracking-[0.12em] text-[#a49a8d]" x-text="mi.label"></span>
				</div>
			</template>
		</div>
		<div x-show="items.length === 0" class="flex flex-col items-center gap-3 rounded-[14px] border border-dashed border-black/[0.16] bg-paper2 px-8 py-14 text-center">
			<div class="flex h-[52px] w-[52px] items-center justify-center rounded-full bg-panel">
				<div class="relative h-4 w-5 rounded-[3px] border-2 border-[#b3a99c]">
					<div class="absolute left-0.5 top-0.5 h-1.5 w-1.5 rounded-full bg-[#b3a99c]"></div>
				</div>
			</div>
			<div class="font-display text-[22px] uppercase text-ink" x-text="emptyTitle"></div>
			<p class="max-w-[360px] text-[14px] leading-[1.5] text-muted" x-text="emptyBody"></p>
		</div>
	</section>

	<!-- ABOUT -->
	<section id="about" class="border-t border-black/[0.08] bg-white">
		<div class="mx-auto max-w-[1000px] px-8 py-20 text-center max-[960px]:px-6">
			<div class="mb-[18px] font-mono text-[12px] uppercase tracking-[0.14em] text-brand">Welcome to Elevate Ballers</div>
			<h2 class="mb-6 font-display text-[clamp(34px,4.5vw,56px)] uppercase leading-[0.95] text-ink">Your home for the game<br />we live for</h2>
			<p class="mx-auto mb-8 max-w-[640px] text-[17px] leading-[1.7] text-muted">
				The official home of Kenya's premier basketball league. Follow every game, every team, and every player. Standings update after every match, and the Player of the Week highlights one standout performance from the past week.
			</p>
			<a href="#about" class="inline-block rounded border border-black/20 px-[30px] py-[15px] text-[14px] font-bold uppercase tracking-[0.04em] text-ink2 no-underline hover:border-brand hover:text-brand">Read the full story →</a>
		</div>
	</section>

	<!-- REGISTER CTA -->
	<section id="register" class="relative overflow-hidden bg-brand text-white">
		<div class="absolute -bottom-[140px] right-[-100px] h-[420px] w-[420px] rounded-full border-2 border-white/[0.18]"></div>
		<div class="absolute -bottom-10 right-10 h-[220px] w-[220px] rounded-full border-2 border-white/[0.18]"></div>
		<div class="relative mx-auto max-w-[1280px] px-8 py-[70px] max-[960px]:px-6">
			<div class="flex flex-wrap items-center justify-between gap-10">
				<div>
					<div class="mb-4 inline-flex items-center gap-[9px] font-mono text-[12px] uppercase tracking-[0.12em]">
						<span class="inline-block h-2 w-2 rounded-full bg-white"></span>{registrationOpen ? "Registration Open" : "Registration Closed"}
					</div>
					{registrationOpen ? (
						<Fragment>
							<h2 class="mb-3.5 font-display text-[clamp(36px,5vw,64px)] uppercase leading-[0.9]">Register to<br />join the league</h2>
							<p class="max-w-[440px] text-[17px] font-semibold">Be part of Elevate Ballers. Tryouts run throughout the year for late entries — sign up your team or yourself today.</p>
						</Fragment>
					) : (
						<Fragment>
							<h2 class="mb-3.5 font-display text-[clamp(36px,5vw,64px)] uppercase leading-[0.9]">2026 entries<br />are closed</h2>
							<p class="max-w-[460px] text-[17px] font-semibold">The season is underway. Tryouts still run year-round for late entries — join the waitlist and we'll reach out the moment a spot or the 2027 window opens.</p>
						</Fragment>
					)}
				</div>
				<a href="/league-registration" class="flex-shrink-0 rounded-md bg-night px-9 py-5 font-display text-[16px] uppercase tracking-[0.06em] text-white no-underline hover:bg-black">{registrationOpen ? "Open Registration Form →" : "Join the Waitlist →"}</a>
			</div>
		</div>
	</section>

	<Footer />
</div>
