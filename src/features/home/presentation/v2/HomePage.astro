			<div x-data={`{
				tab: 'Points',
				data: ${JSON.stringify(leaderData)},
				get list() {
					const arr = this.data[this.tab];
					const max = Math.max(...arr.map(p => p.val));
					return arr.map((p, i) => ({ name: p.name, team: p.team, rank: i + 1, first: i === 0, pct: Math.round((p.val / max) * 100), val: p.val.toFixed(1) }));
				}
			}`}>
				<div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:22px;">
					<h2 style="font-family:'Anton',sans-serif;font-size:32px;text-transform:uppercase;color:#141009;">League Leaders</h2>
					<a href="/stats/leaders" style="font-family:'Space Mono',monospace;font-size:12px;color:#e4002b;text-decoration:none;">All stats →</a>
				</div>
				<div style="display:flex;gap:8px;margin-bottom:20px;">
					{leaderTabs.map((t) => (
						<button
							@click={`tab = '${t}'`}
