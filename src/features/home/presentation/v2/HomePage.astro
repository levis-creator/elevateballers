---
// v2 public home page — faithful port of the standalone design.
// Static sections render server-side; the four interactive parts (news filter,
// league-leaders tabs, featured-media tabs, count-up) run on Alpine.js.
//
// NOTE: this ports the design's demo data verbatim. Wire these arrays to real
// CMS/DB queries later — the markup won't need to change.
import Header from "@/features/layout/presentation/v2/Header.astro";
import Footer from "@/features/layout/presentation/v2/Footer.astro";

// Single source of truth for the registration state. Replace with a real
// source when ready: a CMS flag, a date window, or a live API value. Drives the
// nav CTA, the hero CTA and the registration band together.
const registrationOpen = true;

const heroCtaLabel = registrationOpen ? "Register Your Team" : "Join the Waitlist";

const ticker = [
	"Queens storm into the EWBL final",
	"City Hawks host Alliance Queens this Saturday",
	"Travious Kitondo named Player of the Week",
	"Coast Waves climb to 2nd in the standings",
	"2026 League registration now open",
];

const upcoming = [
	{ day: "05", mon: "Jul", home: "City Hawks", away: "Alliance Queens", venue: "Nyayo Stadium", time: "4:00 PM" },
	{ day: "06", mon: "Jul", home: "Nairobi Thunder", away: "Coast Waves", venue: "Aga Khan Court", time: "2:30 PM" },
	{ day: "08", mon: "Jul", home: "CBA Jets", away: "Rift Valley Rangers", venue: "Nyayo Stadium", time: "6:00 PM" },
];

const results = [
	{ home: "CBA Jets", hs: 78, away: "City Hawks", as: 74 },
	{ home: "Alliance Queens", hs: 65, away: "Eldoret Blaze", as: 52 },
	{ home: "Coast Waves", hs: 81, away: "Kisumu Lakers", as: 69 },
].map((r) => ({
	...r,
	homeColor: r.hs > r.as ? "#141009" : "#a49a8d",
	awayColor: r.as > r.hs ? "#141009" : "#a49a8d",
}));

// --- Interactive data (handed to Alpine) ---
const allNews = [
	{ cat: "Championships", title: "Queens Storm Into the EWBL Final", excerpt: "A dominant fourth quarter sealed a spot in the championship game for the reigning favorites.", date: "Jul 1, 2026" },
	{ cat: "Match report", title: "City Hawks Edge CBA Jets in Overtime Thriller", excerpt: "Two clutch free throws in the final seconds decided a game that had everything.", date: "Jun 29, 2026" },
	{ cat: "Interviews", title: "Travious Kitondo on Ice-Cold Shooting", excerpt: "The Player of the Week sits down to talk footwork, confidence, and big dreams.", date: "Jun 28, 2026" },
	{ cat: "Analysis", title: "Why the Three Is Reshaping the League", excerpt: "The math behind the shot that is changing how every team builds its offense.", date: "Jun 26, 2026" },
	{ cat: "Match report", title: "Coast Waves Sink Rift Valley Rangers", excerpt: "A wire-to-wire performance keeps the Waves firmly in the playoff hunt.", date: "Jun 24, 2026" },
	{ cat: "Championships", title: "Road to the 2026 Finals: What to Watch", excerpt: "The storylines, the matchups, and the players who will decide the title.", date: "Jun 22, 2026" },
];
const newsCategories = ["All", "Interviews", "Championships", "Match report", "Analysis"];

const leaderData = {
	Points: [
		{ name: "Travious Kitondo", team: "CBA Jets", val: 24.8 },
		{ name: "Brian Otieno", team: "City Hawks", val: 22.1 },
		{ name: "Faith Mwangi", team: "Alliance Queens", val: 20.6 },
		{ name: "Kevin Barasa", team: "Nairobi Thunder", val: 19.4 },
		{ name: "Aisha Noor", team: "Coast Waves", val: 18.9 },
	],
	Rebounds: [
		{ name: "Kevin Barasa", team: "Nairobi Thunder", val: 12.7 },
		{ name: "Mercy Achieng", team: "Alliance Queens", val: 11.4 },
		{ name: "Samuel Kiptoo", team: "Rift Valley Rangers", val: 10.8 },
		{ name: "Brian Otieno", team: "City Hawks", val: 9.6 },
		{ name: "Grace Wanjiru", team: "Coast Waves", val: 9.1 },
	],
	Assists: [
		{ name: "Faith Mwangi", team: "Alliance Queens", val: 8.9 },
		{ name: "Dennis Mutua", team: "City Hawks", val: 7.7 },
		{ name: "Aisha Noor", team: "Coast Waves", val: 6.8 },
		{ name: "Travious Kitondo", team: "CBA Jets", val: 6.2 },
		{ name: "John Kamau", team: "Eldoret Blaze", val: 5.9 },
	],
};
const leaderTabs = ["Points", "Rebounds", "Assists"];

const countTargets = { matches: 214, players: 372, teams: 24, awards: 18 };

const allMedia = [
	{ type: "Images", label: "game photo", span: true },
	{ type: "Audio", label: "podcast clip", span: false },
	{ type: "Images", label: "court shot", span: false },
	{ type: "Images", label: "action photo", span: false },
	{ type: "Audio", label: "post-game audio", span: false },
	{ type: "Images", label: "crowd photo", span: true },
];
const mediaTabs = ["All", "Images", "Audio"];
---

<div style="background:#f5f3ef;color:#1a1712;font-family:'Archivo',sans-serif;min-height:100vh;overflow-x:hidden;">
	<Header registrationOpen={registrationOpen} active="home" />

	<!-- HERO -->
	<section style="position:relative;border-bottom:1px solid rgba(0,0,0,0.08);overflow:hidden;">
		<div style="position:absolute;inset:0;background:radial-gradient(120% 80% at 82% -10%,rgba(228,0,43,0.12),transparent 58%);"></div>
		<div style="position:absolute;right:-140px;top:-80px;width:520px;height:520px;border-radius:50%;border:1px solid rgba(228,0,43,0.14);"></div>
		<div style="position:absolute;right:-40px;top:20px;width:340px;height:340px;border-radius:50%;border:1px solid rgba(228,0,43,0.1);"></div>
		<div class="eb-hero eb-pad" style="position:relative;max-width:1280px;margin:0 auto;padding:72px 32px 60px;display:grid;grid-template-columns:1.15fr 0.85fr;gap:56px;align-items:center;">
			<div>
				<div style="display:inline-flex;align-items:center;gap:10px;font-family:'Space Mono',monospace;font-size:12px;letter-spacing:0.14em;text-transform:uppercase;color:#e4002b;margin-bottom:22px;">
					<span style="width:26px;height:1px;background:#e4002b;"></span>Kenya's Premier Basketball League
				</div>
				<h1 style="font-family:'Anton',sans-serif;font-size:clamp(56px,7vw,104px);line-height:0.86;letter-spacing:0.01em;text-transform:uppercase;margin-bottom:24px;color:#141009;">
					Elevate<br />your <span style="color:#e4002b;">game</span>
				</h1>
				<p style="font-size:17px;line-height:1.6;color:#6f665c;max-width:460px;margin-bottom:34px;">
					Live matches, standings, and rising stars from the courts of Nairobi. Follow every game, every team, every player — all season long.
				</p>
				<div class="eb-cta" style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
					<a href="#register" class="eb-btn-primary" style="background:#e4002b;color:#fff;text-decoration:none;font-weight:800;font-size:14px;letter-spacing:0.04em;text-transform:uppercase;padding:16px 28px;border-radius:4px;">{heroCtaLabel}</a>
					<a href="#standings" class="eb-btn-outline" style="border:1px solid rgba(0,0,0,0.22);color:#1a1712;text-decoration:none;font-weight:700;font-size:14px;letter-spacing:0.04em;text-transform:uppercase;padding:16px 28px;border-radius:4px;">View Standings</a>
				</div>
			</div>

			<!-- NEXT MATCH CARD -->
			<div style="background:#111010;border:1px solid rgba(0,0,0,0.1);border-radius:12px;overflow:hidden;box-shadow:0 26px 50px rgba(20,16,9,0.22);">
				<div style="display:flex;align-items:center;justify-content:space-between;padding:14px 18px;background:#000;border-bottom:1px solid rgba(255,255,255,0.08);">
					<span style="font-family:'Space Mono',monospace;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#e4002b;">Next Match</span>
					<span style="font-family:'Space Mono',monospace;font-size:11px;color:#8a817a;">Jul 5, 2026 · 4:00 PM</span>
				</div>
				<div style="padding:26px 18px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:8px;">
					<div style="display:flex;flex-direction:column;align-items:center;gap:12px;text-align:center;">
						<div style="width:64px;height:64px;border-radius:50%;background:repeating-linear-gradient(45deg,#221d18,#221d18 6px,#1b1712 6px,#1b1712 12px);display:flex;align-items:center;justify-content:center;font-family:'Anton',sans-serif;font-size:22px;color:#e4002b;">CH</div>
						<div>
							<div style="font-family:'Anton',sans-serif;font-size:16px;text-transform:uppercase;color:#f3efe9;">City Hawks</div>
							<div style="font-family:'Space Mono',monospace;font-size:10px;color:#8a817a;letter-spacing:0.1em;">HOME</div>
						</div>
					</div>
					<div style="font-family:'Anton',sans-serif;font-size:20px;color:#6b635a;">VS</div>
					<div style="display:flex;flex-direction:column;align-items:center;gap:12px;text-align:center;">
						<div style="width:64px;height:64px;border-radius:50%;background:repeating-linear-gradient(45deg,#221d18,#221d18 6px,#1b1712 6px,#1b1712 12px);display:flex;align-items:center;justify-content:center;font-family:'Anton',sans-serif;font-size:22px;color:#f3efe9;">AG</div>
						<div>
							<div style="font-family:'Anton',sans-serif;font-size:15px;text-transform:uppercase;line-height:1;color:#f3efe9;">Alliance Queens</div>
							<div style="font-family:'Space Mono',monospace;font-size:10px;color:#8a817a;letter-spacing:0.1em;">AWAY</div>
						</div>
					</div>
				</div>
				<div style="padding:0 18px 18px;">
					<a href="#fixtures" class="eb-chip" style="display:block;text-align:center;background:rgba(228,0,43,0.14);color:#ff5a72;text-decoration:none;font-weight:700;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;padding:13px;border-radius:6px;border:1px solid rgba(228,0,43,0.3);">View Match · Nyayo Stadium</a>
				</div>
			</div>
		</div>
	</section>

	<!-- NEWS TICKER -->
	<div style="background:#e4002b;color:#fff;overflow:hidden;white-space:nowrap;display:flex;align-items:center;">
		<span style="flex-shrink:0;background:#0c0b0a;color:#fff;font-family:'Anton',sans-serif;font-size:14px;letter-spacing:0.1em;text-transform:uppercase;padding:12px 20px;">Elevate News</span>
		<div style="overflow:hidden;flex:1;">
			<div style="display:inline-flex;animation:marquee 34s linear infinite;font-family:'Space Mono',monospace;font-size:13px;font-weight:700;">
				<div style="display:inline-flex;">
					{ticker.map((t) => (
						<span style="padding:12px 28px;display:inline-flex;align-items:center;gap:28px;">{t}<span style="width:6px;height:6px;border-radius:50%;background:#fff;display:inline-block;"></span></span>
					))}
				</div>
				<div style="display:inline-flex;" aria-hidden="true">
					{ticker.map((t) => (
						<span style="padding:12px 28px;display:inline-flex;align-items:center;gap:28px;">{t}<span style="width:6px;height:6px;border-radius:50%;background:#fff;display:inline-block;"></span></span>
					))}
				</div>
			</div>
		</div>
	</div>

	<!-- FIXTURES & RESULTS -->
	<section id="fixtures" class="eb-two eb-pad eb-sec" style="max-width:1280px;margin:0 auto;padding:72px 32px;display:grid;grid-template-columns:1fr 1fr;gap:40px;">
		<div>
			<div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:24px;">
				<h2 style="font-family:'Anton',sans-serif;font-size:30px;text-transform:uppercase;letter-spacing:0.01em;color:#141009;">Upcoming Matches</h2>
				<a href="#fixtures" style="font-family:'Space Mono',monospace;font-size:12px;color:#e4002b;text-decoration:none;letter-spacing:0.06em;">All fixtures →</a>
			</div>
			<div style="display:flex;flex-direction:column;gap:12px;">
				{upcoming.map((m) => (
					<div class="eb-card" style="background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:10px;padding:14px 18px 16px;display:flex;flex-direction:column;gap:12px;min-height:142px;justify-content:space-between;box-shadow:0 1px 2px rgba(20,16,9,0.04);">
						<div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
							<span style="font-family:'Space Mono',monospace;font-size:10px;color:#e4002b;letter-spacing:0.12em;text-transform:uppercase;background:rgba(228,0,43,0.08);padding:3px 9px;border-radius:4px;">{m.day} {m.mon} · {m.time}</span>
							<span style="font-family:'Space Mono',monospace;font-size:11px;color:#8a817a;">{m.venue}</span>
						</div>
						<div style="display:flex;flex-direction:column;gap:11px;">
							<div style="display:flex;align-items:center;gap:12px;">
								<div style="width:30px;height:30px;border-radius:50%;background:repeating-linear-gradient(45deg,#e7e2da,#e7e2da 5px,#f0ece5 5px,#f0ece5 10px);flex-shrink:0;"></div>
								<span style="flex:1;font-family:'Archivo',sans-serif;font-weight:700;font-size:15px;color:#1a1712;">{m.home}</span>
								<span style="font-family:'Space Mono',monospace;font-size:10px;color:#a49a8d;letter-spacing:0.1em;">HOME</span>
							</div>
							<div style="display:flex;align-items:center;gap:12px;">
								<div style="width:30px;height:30px;border-radius:50%;background:repeating-linear-gradient(45deg,#e7e2da,#e7e2da 5px,#f0ece5 5px,#f0ece5 10px);flex-shrink:0;"></div>
								<span style="flex:1;font-family:'Archivo',sans-serif;font-weight:700;font-size:15px;color:#1a1712;">{m.away}</span>
								<span style="font-family:'Space Mono',monospace;font-size:10px;color:#a49a8d;letter-spacing:0.1em;">AWAY</span>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
		<div id="standings">
			<div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:24px;">
				<h2 style="font-family:'Anton',sans-serif;font-size:30px;text-transform:uppercase;letter-spacing:0.01em;color:#141009;">Recent Results</h2>
				<a href="/standings" style="font-family:'Space Mono',monospace;font-size:12px;color:#e4002b;text-decoration:none;letter-spacing:0.06em;">All results →</a>
			</div>
			<div style="display:flex;flex-direction:column;gap:12px;">
				{results.map((r) => (
					<div class="eb-card" style="background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:10px;padding:14px 18px 16px;display:flex;flex-direction:column;gap:12px;min-height:142px;justify-content:space-between;box-shadow:0 1px 2px rgba(20,16,9,0.04);">
						<span style="align-self:flex-start;font-family:'Space Mono',monospace;font-size:10px;color:#a49a8d;letter-spacing:0.12em;text-transform:uppercase;background:#f0ede7;padding:3px 9px;border-radius:4px;">Final</span>
						<div style="display:flex;flex-direction:column;gap:11px;">
							<div style="display:flex;align-items:center;gap:12px;">
								<div style="width:30px;height:30px;border-radius:50%;background:repeating-linear-gradient(45deg,#e7e2da,#e7e2da 5px,#f0ece5 5px,#f0ece5 10px);flex-shrink:0;"></div>
								<span style={`flex:1;font-family:'Archivo',sans-serif;font-weight:700;font-size:15px;color:${r.homeColor};`}>{r.home}</span>
								<span style={`font-family:'Anton',sans-serif;font-size:22px;color:${r.homeColor};`}>{r.hs}</span>
							</div>
							<div style="display:flex;align-items:center;gap:12px;">
								<div style="width:30px;height:30px;border-radius:50%;background:repeating-linear-gradient(45deg,#e7e2da,#e7e2da 5px,#f0ece5 5px,#f0ece5 10px);flex-shrink:0;"></div>
								<span style={`flex:1;font-family:'Archivo',sans-serif;font-weight:700;font-size:15px;color:${r.awayColor};`}>{r.away}</span>
								<span style={`font-family:'Anton',sans-serif;font-size:22px;color:${r.awayColor};`}>{r.as}</span>
							</div>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- PLAYER OF THE WEEK -->
	<section style="background:#0c0b0a;color:#f3efe9;border-top:1px solid rgba(0,0,0,0.08);position:relative;overflow:hidden;">
		<div style="position:absolute;inset:0;background:radial-gradient(90% 120% at 10% 50%,rgba(228,0,43,0.16),transparent 55%);"></div>
		<div class="eb-potw eb-pad" style="position:relative;max-width:1280px;margin:0 auto;padding:72px 32px;display:grid;grid-template-columns:0.85fr 1.15fr;gap:56px;align-items:center;">
			<div style="position:relative;">
				<div class="eb-potw-img" style="aspect-ratio:4/5;border-radius:14px;background:repeating-linear-gradient(45deg,#1a1714,#1a1714 12px,#151210 12px,#151210 24px);border:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;">
					<span style="font-family:'Space Mono',monospace;font-size:12px;letter-spacing:0.14em;color:#6b635a;text-transform:uppercase;">player photo</span>
				</div>
				<div style="position:absolute;bottom:-14px;left:-14px;background:#e4002b;color:#fff;font-family:'Anton',sans-serif;font-size:14px;text-transform:uppercase;letter-spacing:0.06em;padding:10px 16px;border-radius:6px;">CBA Jets · #7</div>
			</div>
			<div>
				<div style="font-family:'Space Mono',monospace;font-size:12px;letter-spacing:0.14em;text-transform:uppercase;color:#ff5a72;margin-bottom:16px;">Player of the Week</div>
				<h2 style="font-family:'Anton',sans-serif;font-size:clamp(40px,5vw,68px);line-height:0.9;text-transform:uppercase;margin-bottom:10px;color:#f6f2ec;">Travious<br />Kitondo</h2>
				<div style="font-family:'Anton',sans-serif;font-size:20px;color:#e4002b;letter-spacing:0.06em;margin-bottom:22px;">DYNAMITE.</div>
				<p style="font-size:16px;line-height:1.7;color:#b8afa6;max-width:520px;margin-bottom:18px;">
					Size, physicality, strength — none of which Travious has. But inside that lean frame is a mean competitor, a silent assassin afraid of no one on the court. All game long she was quiet, calculating and methodical as she tore City Hawks to shreds.
				</p>
				<p style="font-size:16px;line-height:1.7;color:#b8afa6;max-width:520px;margin-bottom:28px;">
					Spot-up three, contested catch-and-shoot three, and a deadly side-step three closed out CBA Jets' final 14 points — officially slamming the door on a much-needed win.
				</p>
				<div style="display:flex;gap:40px;">
					<div><div style="font-family:'Anton',sans-serif;font-size:34px;color:#f3efe9;">27</div><div style="font-family:'Space Mono',monospace;font-size:11px;color:#8a817a;letter-spacing:0.08em;text-transform:uppercase;">Points</div></div>
					<div><div style="font-family:'Anton',sans-serif;font-size:34px;color:#f3efe9;">6</div><div style="font-family:'Space Mono',monospace;font-size:11px;color:#8a817a;letter-spacing:0.08em;text-transform:uppercase;">Threes</div></div>
					<div><div style="font-family:'Anton',sans-serif;font-size:34px;color:#f3efe9;">5</div><div style="font-family:'Space Mono',monospace;font-size:11px;color:#8a817a;letter-spacing:0.08em;text-transform:uppercase;">Assists</div></div>
				</div>
			</div>
		</div>
	</section>

	<!-- LATEST NEWS (Alpine: category filter) -->
	<section class="eb-pad eb-sec" style="max-width:1280px;margin:0 auto;padding:72px 32px;" x-data={`{ cat: 'All', news: ${JSON.stringify(allNews)} }`}>
		<div style="display:flex;align-items:flex-end;justify-content:space-between;gap:24px;flex-wrap:wrap;margin-bottom:28px;">
			<div>
				<div style="font-family:'Space Mono',monospace;font-size:12px;letter-spacing:0.14em;text-transform:uppercase;color:#e4002b;margin-bottom:10px;">From around the league</div>
				<h2 style="font-family:'Anton',sans-serif;font-size:38px;text-transform:uppercase;color:#141009;">Latest News</h2>
			</div>
			<div style="display:flex;gap:8px;flex-wrap:wrap;">
				{newsCategories.map((c) => (
					<button
						class="eb-chipbtn"
						@click={`cat = '${c}'`}
						:style={`cat === '${c}' ? 'background:#e4002b;color:#fff;border:1px solid #e4002b;font-family:\\'Archivo\\',sans-serif;font-weight:700;font-size:12px;letter-spacing:0.04em;text-transform:uppercase;padding:9px 15px;border-radius:6px;cursor:pointer;' : 'background:#fff;color:#6f665c;border:1px solid rgba(0,0,0,0.15);font-family:\\'Archivo\\',sans-serif;font-weight:600;font-size:12px;letter-spacing:0.04em;text-transform:uppercase;padding:9px 15px;border-radius:6px;cursor:pointer;'`}
					>{c}</button>
				))}
			</div>
		</div>
		<div class="eb-news" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
			<template x-for="n in (cat === 'All' ? news : news.filter(x => x.cat === cat))" :key="n.title">
				<a href="/news" class="eb-newscard" style="background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:12px;overflow:hidden;text-decoration:none;color:inherit;display:flex;flex-direction:column;box-shadow:0 1px 2px rgba(20,16,9,0.04);">
					<div style="aspect-ratio:16/10;background:repeating-linear-gradient(45deg,#e7e2da,#e7e2da 10px,#f0ece5 10px,#f0ece5 20px);display:flex;align-items:center;justify-content:center;">
						<span style="font-family:'Space Mono',monospace;font-size:11px;letter-spacing:0.12em;color:#a49a8d;text-transform:uppercase;">article image</span>
					</div>
					<div style="padding:20px;flex:1;display:flex;flex-direction:column;">
						<span style="font-family:'Space Mono',monospace;font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:#e4002b;margin-bottom:10px;" x-text="n.cat"></span>
						<h3 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:18px;line-height:1.25;margin-bottom:10px;color:#1a1712;" x-text="n.title"></h3>
						<p style="font-size:13.5px;line-height:1.55;color:#6f665c;flex:1;" x-text="n.excerpt"></p>
						<span style="font-family:'Space Mono',monospace;font-size:11px;color:#a49a8d;margin-top:14px;" x-text="n.date"></span>
					</div>
				</a>
			</template>
		</div>
	</section>

