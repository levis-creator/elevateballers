						<div style="font-family:'Anton',sans-serif;font-size:52px;color:#e4002b;line-height:1;" x-text="counts.awards"></div>
						<div style="font-family:'Space Mono',monospace;font-size:12px;color:#6f665c;letter-spacing:0.08em;text-transform:uppercase;margin-top:8px;">Awards Won</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- FEATURED MEDIA (Alpine: tabs + empty state) -->
	<section class="eb-pad eb-sec" style="max-width:1280px;margin:0 auto;padding:72px 32px;" x-data={`{
		tab: 'All',
