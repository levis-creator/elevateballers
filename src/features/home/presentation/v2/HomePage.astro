					</div>
					<div style="background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:12px;padding:26px;box-shadow:0 1px 2px rgba(20,16,9,0.04);">
						<div style="font-family:'Anton',sans-serif;font-size:52px;color:#141009;line-height:1;" x-text="counts.teams"></div>
						<div style="font-family:'Space Mono',monospace;font-size:12px;color:#6f665c;letter-spacing:0.08em;text-transform:uppercase;margin-top:8px;">Teams</div>
