						<div style="display:flex;align-items:center;gap:16px;padding:14px 4px;border-bottom:1px solid rgba(0,0,0,0.08);">
							<span style="font-family:'Anton',sans-serif;font-size:20px;width:26px;" :style="`color:${p.first ? '#e4002b' : '#b3a99c'}`" x-text="p.rank"></span>
							<div style="width:40px;height:40px;border-radius:50%;background:#ddd7cd;flex-shrink:0;"></div>
							<div style="flex:1;">
								<div style="font-family:'Archivo',sans-serif;font-weight:700;font-size:15px;color:#1a1712;" x-text="p.name"></div>
								<div style="font-family:'Space Mono',monospace;font-size:11px;color:#8a817a;" x-text="p.team"></div>
							</div>
							<div style="flex:1.2;max-width:160px;">
								<div style="height:6px;background:rgba(0,0,0,0.08);border-radius:3px;overflow:hidden;">
									<div style="height:100%;border-radius:3px;" :style="`width:${p.pct}%;background:${p.first ? '#e4002b' : 'rgba(228,0,43,0.4)'}`"></div>
								</div>
							</div>
							<span style="font-family:'Anton',sans-serif;font-size:22px;color:#141009;width:56px;text-align:right;" x-text="p.val"></span>
						</div>
					</template>
				</div>
			</div>

			<div x-data={`{
				counts: { matches: 0, players: 0, teams: 0, awards: 0 },
				init() {
					const targets = ${JSON.stringify(countTargets)};
					const start = performance.now();
					const dur = 1400;
					const tick = (now) => {
						const p = Math.min(1, (now - start) / dur);
						const e = 1 - Math.pow(1 - p, 3);
						this.counts = {
							matches: Math.round(targets.matches * e),
							players: Math.round(targets.players * e),
							teams: Math.round(targets.teams * e),
							awards: Math.round(targets.awards * e),
						};
						if (p < 1) requestAnimationFrame(tick);
					};
					requestAnimationFrame(tick);
				}
			}`}>
				<h2 style="font-family:'Anton',sans-serif;font-size:32px;text-transform:uppercase;margin-bottom:22px;color:#141009;">By The Numbers</h2>
				<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
