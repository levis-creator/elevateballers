---
// League Leaders + By The Numbers section wrapper. Hosts two React islands
// (Zustand-backed leader tabs, react-countup) inside the shared grid.
import LeagueLeaders from "./LeagueLeaders.tsx";
import ByTheNumbers from "./ByTheNumbers.tsx";
import type { LeaderData, CountTargets } from "@/features/home/domain/entities/home-v2";

interface Props {
	leaderData: LeaderData;
	leaderTabs: string[];
	counts: CountTargets;
}
const { leaderData, leaderTabs, counts } = Astro.props;
---

<section class="border-y border-black/[0.08] bg-panel">
	<div class="mx-auto grid max-w-[1280px] grid-cols-2 items-start gap-14 px-8 py-[72px] max-[960px]:grid-cols-1 max-[960px]:gap-9 max-[960px]:px-6 max-[960px]:py-[52px]">
		<LeagueLeaders leaderData={leaderData} tabs={leaderTabs} client:visible />
		<ByTheNumbers counts={counts} client:visible />
	</div>
</section>
