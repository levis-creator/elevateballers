---
// Latest News with an Alpine category filter (client-side).
import type { NewsItem } from "@/features/home/presentation/v2/data";
import { TAB_ACTIVE, TAB_INACTIVE } from "@/features/home/presentation/v2/lib/tab-styles";

interface Props {
	news: NewsItem[];
	categories: string[];
}
const { news, categories } = Astro.props;
---

<section class="mx-auto max-w-[1280px] px-8 py-[72px] max-[960px]:px-6 max-[960px]:py-[52px]" x-data={`{ cat: 'All', news: ${JSON.stringify(news)} }`}>
	<div class="mb-7 flex flex-wrap items-end justify-between gap-6">
		<div>
			<div class="mb-2.5 font-mono text-[12px] uppercase tracking-[0.14em] text-brand">From around the league</div>
			<h2 class="font-display text-[38px] uppercase text-ink">Latest News</h2>
		</div>
		<div class="flex flex-wrap gap-2">
			{categories.map((c) => (
				<button @click={`cat = '${c}'`} :style={`cat === '${c}' ? '${TAB_ACTIVE}' : '${TAB_INACTIVE}'`} class="hover:!border-brand">{c}</button>
			))}
		</div>
	</div>
	<div class="grid grid-cols-3 gap-5 max-[960px]:grid-cols-2 max-[600px]:grid-cols-1">
		<template x-for="n in (cat === 'All' ? news : news.filter(x => x.cat === cat))" :key="n.title">
			<a href="/news" class="flex flex-col overflow-hidden rounded-xl border border-black/10 bg-white text-inherit no-underline shadow-[0_1px_2px_rgba(20,16,9,0.04)] hover:border-brand/40">
				<div class="flex aspect-[16/10] items-center justify-center" style="background:repeating-linear-gradient(45deg,#e7e2da,#e7e2da 10px,#f0ece5 10px,#f0ece5 20px);">
					<span class="font-mono text-[11px] uppercase tracking-[0.12em] text-[#a49a8d]">article image</span>
				</div>
				<div class="flex flex-1 flex-col p-5">
					<span class="mb-2.5 font-mono text-[10px] uppercase tracking-[0.12em] text-brand" x-text="n.cat"></span>
					<h3 class="mb-2.5 font-body text-[18px] font-extrabold leading-[1.25] text-ink2" x-text="n.title"></h3>
					<p class="flex-1 text-[13.5px] leading-[1.55] text-muted" x-text="n.excerpt"></p>
					<span class="mt-3.5 font-mono text-[11px] text-[#a49a8d]" x-text="n.date"></span>
				</div>
			</a>
		</template>
	</div>
</section>
