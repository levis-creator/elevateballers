---
import { getActivePlayerOfTheWeek } from "../../cms/lib/editorial-queries";
import { playerOfTheWeek as staticPlayer } from "../data/homeData";
import { resolveAssetUrl } from "../../../lib/asset-url";

// Fetch dynamic POTW from database
const activePotw = await getActivePlayerOfTheWeek();

// Use dynamic data if available, otherwise fallback to static
const player = activePotw
  ? {
      id: activePotw.player.id,
      name: `${activePotw.player.firstName} ${activePotw.player.lastName}`,
      image: activePotw.customImage || activePotw.player.image,
      description: activePotw.description,
      // These fields are not in the new schema but used in the component
      imageAlt: `${activePotw.player.firstName} ${activePotw.player.lastName} - Player of the Week`,
      signature: null,
    }
  : staticPlayer;

// Resolve image URLs to absolute paths for Astro Image component
const playerImageUrl = resolveAssetUrl(player.image) || player.image;
const signatureImageUrl = player.signature
  ? resolveAssetUrl(player.signature) || player.signature
  : null;

const descriptionHtml = player.description
  .split("\n\n")
  .map((p) => `<p>${p.replace(/\n/g, "<br/>")}</p>`)
  .join("");
---

<div class="stm-coach-excerption-wrapp">
  <div class="stm-title-wrapp">
    <h3>PLAYER OF THE WEEK</h3>
  </div>
  <div class="clearfix"></div>
  <div class="stm-data-wrapp">
    <div class="stm-photo-wrapp">
      <img
        src={playerImageUrl || "/images/default-player.png"}
        alt={player.imageAlt || player.name}
        width="300"
        height="300"
        loading="eager"
        onerror="this.onerror=null;this.src='/images/default-player.png';"
      />
    </div>
    <div class="stm-excerption-wrapp">
      <span class="stm-excerption" set:html={descriptionHtml}></span>
      <div class="stm-name-sign-wrapp">
        <span class="stm-coach-name heading-font">{player.name}</span>
        {
          signatureImageUrl && (
            <div class="stm-img-wrapp">
              <img
                src={signatureImageUrl}
                alt={`${player.name} signature`}
                width="200"
                height="50"
                loading="lazy"
              />
            </div>
          )
        }
      </div>
    </div>
  </div>
</div>
