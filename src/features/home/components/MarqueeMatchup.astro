---
import { formatMatchDate } from "@/features/matches/lib/utils";
import {
  getTeam1Name,
  getTeam1Logo,
  getTeam2Name,
  getTeam2Logo,
  getTeamInitials,
} from "@/features/matches/lib/team-helpers";
import { getChampionships, getNextMatch } from "@/features/matches/lib/queries";

let match: any = null;

try {
  // Try to get championships first
  const championships = await getChampionships(1);
  if (championships && championships.length > 0) {
    match = championships[0];
  }

  // Fallback to any next match
  if (!match) {
    match = await getNextMatch();
  }
} catch (error) {
  console.error("Error fetching match data:", error);
}

const matchDate = match ? formatMatchDate(match.date) : null;
const matchUrl = match ? `/matches/${(match as any).slug || match.id}/` : "#";
const team1Name = match ? getTeam1Name(match) : "";
const team1Logo = match ? getTeam1Logo(match) : null;
const team2Name = match ? getTeam2Name(match) : "";
const team2Logo = match ? getTeam2Logo(match) : null;

const team1Initials = team1Name ? getTeamInitials(team1Name) : "";
const team2Initials = team2Name ? getTeamInitials(team2Name) : "";
---

<section class="mq" aria-label="Featured match">
  {match ? (
    <a href={matchUrl} class="mq-link">
      <div class="mq-body">
        <div class="mq-team mq-team--home">
          <div class="mq-logo-wrap">
            {team1Logo
              ? <img src={team1Logo} alt={team1Name} width="120" height="120" />
              : <span class="mq-initials">{team1Initials}</span>
            }
          </div>
          <span class="mq-team-name">{team1Name}</span>
          <span class="mq-team-label">HOME</span>
        </div>

        <div class="mq-vs-block">
          <span class="mq-vs-text">VS</span>
          <time class="mq-date" datetime={match?.date ? new Date(match.date).toISOString() : undefined}>
            {matchDate}
          </time>
          <span class="mq-view-btn">View Match <i class="fa fa-arrow-right"></i></span>
        </div>

        <div class="mq-team mq-team--away">
          <div class="mq-logo-wrap">
            {team2Logo
              ? <img src={team2Logo} alt={team2Name} width="120" height="120" />
              : <span class="mq-initials">{team2Initials}</span>
            }
          </div>
          <span class="mq-team-name">{team2Name}</span>
          <span class="mq-team-label">AWAY</span>
        </div>
      </div>
    </a>
  ) : (
    <div class="mq-empty">
      <div class="mq-empty-glow" aria-hidden="true"></div>
      <div class="mq-empty-body">
        <div class="mq-empty-left">
          <p class="mq-empty-eyebrow"><span class="mq-pulse-dot"></span> RECRUITMENT IN PROGRESS</p>
          <h2 class="mq-empty-title">2026 SEASON<br/><span class="mq-title-accent">IS COMING</span></h2>
          <p class="mq-empty-desc">
            Our teams are recruiting. The schedule is being drafted.<br/>
            Stay tuned for the next chapter of Elevate Basketball.
          </p>
          <div class="mq-empty-actions">
            <a href="/upcoming-fixtures/" class="mq-btn mq-btn--primary">
              Match Center <i class="fa fa-arrow-right"></i>
            </a>
            <a href="/league-registration/" class="mq-btn mq-btn--outline">
              Register Now
            </a>
          </div>
        </div>
        <div class="mq-empty-right" aria-hidden="true">
          <div class="mq-badge-ring">
            <div class="mq-badge-inner">
              <i class="fa fa-basketball-ball mq-badge-icon"></i>
              <span class="mq-badge-year">2026</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  )}
</section>

<style>
  /* ── Base ── */
  .mq {
    background: #0d0d0d;
    font-family: "Teko", sans-serif;
    width: 100%;
    overflow: hidden;
  }

  /* ══════════════════════════════
     MATCH STATE
  ══════════════════════════════ */
  .mq-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .mq-body {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    max-width: 1170px;
    margin-left: auto;
    margin-right: auto;
    padding: 3rem 15px;
    gap: 2rem;
    min-height: 280px;
  }

  .mq-team {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    min-width: 0;
  }

  .mq-logo-wrap {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    border: 2px solid rgba(255,255,255,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .mq-logo-wrap img {
    width: 75%;
    height: 75%;
    object-fit: contain;
  }

  .mq-initials {
    font-size: 2.5rem;
    font-weight: 700;
    color: rgba(255,255,255,0.3);
  }

  .mq-team-name {
    font-size: clamp(1.8rem, 3.5vw, 3rem);
    font-weight: 700;
    color: #fff;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    max-width: min(100%, 14ch);
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
    text-wrap: balance;
  }

  .mq-team-label {
    font-family: "Rubik", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
  }

  .mq-vs-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 0 1rem;
  }

  .mq-vs-text {
    font-size: 3rem;
    font-weight: 800;
    color: #dd3333;
    line-height: 1;
    letter-spacing: 0.05em;
  }

  .mq-date {
    font-family: "Rubik", sans-serif;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.45);
    font-weight: 500;
    text-align: center;
    letter-spacing: 0.05em;
  }

  .mq-view-btn {
    font-family: "Rubik", sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #ffba00;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .mq-link:hover .mq-view-btn {
    color: #fff;
  }

  /* ══════════════════════════════
     EMPTY / OFF-SEASON STATE
  ══════════════════════════════ */
  .mq-empty {
    position: relative;
  }

  .mq-empty-glow {
    position: absolute;
    top: 50%;
    right: 15%;
    transform: translateY(-50%);
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(221,51,51,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .mq-empty-body {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    max-width: 1170px;
    margin-left: auto;
    margin-right: auto;
    padding: 3.5rem 15px;
    gap: 3rem;
    min-height: 320px;
    position: relative;
    z-index: 1;
  }

  .mq-empty-left {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 580px;
  }

  .mq-empty-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: "Rubik", sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: #ffba00;
    text-transform: uppercase;
    margin: 0;
  }

  .mq-pulse-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    background: #ffba00;
    border-radius: 50%;
    animation: mq-pulse 2s infinite;
    flex-shrink: 0;
  }

  @keyframes mq-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(255,186,0,0.6); }
    70%  { box-shadow: 0 0 0 8px rgba(255,186,0,0); }
    100% { box-shadow: 0 0 0 0 rgba(255,186,0,0); }
  }

  .mq-empty-title {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 800;
    color: #fff;
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: -1px;
    margin: 0;
  }

  .mq-title-accent {
    color: #dd3333;
  }

  .mq-empty-desc {
    font-family: "Rubik", sans-serif;
    font-size: 1rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
    margin: 0;
  }

  .mq-empty-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .mq-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1.75rem;
    font-family: "Teko", sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.25s ease;
  }

  .mq-btn--primary {
    background: #dd3333;
    color: #fff;
  }

  .mq-btn--primary:hover {
    background: #bb2020;
    transform: translateY(-2px);
  }

  .mq-btn--outline {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255,255,255,0.25);
  }

  .mq-btn--outline:hover {
    border-color: #fff;
    background: rgba(255,255,255,0.06);
    transform: translateY(-2px);
  }

  /* Badge graphic */
  .mq-empty-right {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mq-badge-ring {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    border: 3px solid rgba(221,51,51,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .mq-badge-ring::before {
    content: "";
    position: absolute;
    inset: 10px;
    border-radius: 50%;
    border: 1px solid rgba(255,186,0,0.2);
  }

  .mq-badge-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .mq-badge-icon {
    font-size: 2.5rem;
    color: #dd3333;
    opacity: 0.8;
  }

  .mq-badge-year {
    font-size: 2.75rem;
    font-weight: 800;
    color: #fff;
    line-height: 1;
    letter-spacing: 0.05em;
  }

  /* ══════════════════════════════
     RESPONSIVE
  ══════════════════════════════ */
  @media (max-width: 900px) {
    .mq-body {
      padding: 2.5rem 15px;
    }

    .mq-empty-body {
      padding: 2.5rem 15px;
      gap: 2rem;
    }

    .mq-badge-ring {
      width: 160px;
      height: 160px;
    }

    .mq-badge-year {
      font-size: 2.25rem;
    }
  }

  @media (max-width: 680px) {
    /* Match state: stack vertically */
    .mq-body {
      grid-template-columns: 1fr;
      padding: 2rem 1.25rem;
      gap: 1.5rem;
      text-align: center;
    }

    .mq-team--home { order: 1; }
    .mq-vs-block   { order: 2; flex-direction: row; gap: 1.25rem; }
    .mq-team--away { order: 3; }

    .mq-vs-text { font-size: 2rem; }
    .mq-team-name { max-width: 12ch; font-size: clamp(1.5rem, 7vw, 2.2rem); }

    /* Empty state: stack vertically */
    .mq-empty-body {
      grid-template-columns: 1fr;
      padding: 2.5rem 1.25rem;
      text-align: center;
    }

    .mq-empty-left {
      align-items: center;
    }

    .mq-empty-right {
      display: none;
    }

    .mq-empty-actions {
      justify-content: center;
    }

    .mq-empty-title {
      font-size: clamp(2.5rem, 12vw, 4rem);
    }
  }

  @media (max-width: 420px) {
    .mq-btn {
      padding: 0.65rem 1.25rem;
      font-size: 1rem;
    }

    .mq-logo-wrap {
      width: 80px;
      height: 80px;
    }

    .mq-empty-desc {
      font-size: 0.9rem;
    }
  }
</style>
