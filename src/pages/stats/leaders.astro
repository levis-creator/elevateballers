---
export const prerender = false;

Astro.response.headers.set("Cache-Control", "public, s-maxage=120, stale-while-revalidate=300");

import { usePublicV2 } from "@/lib/ui-version";

// v2-only route. Rewrite to the legacy page when the flag is off — URL stays
// /stats/leaders.
if (!usePublicV2) return Astro.rewrite("/stats/leaders-v1");

import LayoutV2 from "@/layouts/v2/Layout.astro";
import LeadersPage from "@/features/stats/presentation/v2/LeadersPage.astro";
---

<LayoutV2
	title="Stat Leaders - Elevate Ballers | League Statistical Leaders"
	description="The top performers across Elevate Ballers — points, rebounds, assists, steals, blocks and three-pointers per game, by league and season."
	canonicalURL={`${Astro.url.origin}/stats/leaders/`}
	type="website"
>
	<LeadersPage />
</LayoutV2>
