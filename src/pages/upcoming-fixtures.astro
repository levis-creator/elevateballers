---
export const prerender = false;

// Edge cache fixtures for 60s — they change rarely.
Astro.response.headers.set("Cache-Control", "public, s-maxage=60, stale-while-revalidate=300");

import { usePublicV2 } from "@/lib/ui-version";

// v2-only route (imports only the v2 tree). Rewrite to the legacy fixtures page
// when the flag is off — URL stays /upcoming-fixtures.
if (!usePublicV2) return Astro.rewrite("/upcoming-fixtures-v1");

import LayoutV2 from "@/layouts/v2/Layout.astro";
import FixturesPage from "@/features/fixtures/presentation/v2/FixturesPage.astro";
---

<LayoutV2
	title="Fixtures - Elevate Ballers | Match Calendar & Results"
	description="Elevate Ballers match calendar — upcoming fixtures and final results by season and league, with tip-off times and scores."
	canonicalURL={`${Astro.url.origin}/upcoming-fixtures/`}
	type="website"
>
	<FixturesPage />
</LayoutV2>
