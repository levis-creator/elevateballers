---
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import TopBar from "../features/layout/components/TopBar.astro";
import Header from "../features/layout/components/Header";
import Footer from "../features/layout/components/Footer.astro";
import Spacing from "../shared/components/ui/Spacing.astro";
import { getCompletedMatches, getUpcomingMatches } from "../features/matches/lib/queries";
import MatchesTabbedTable from "../features/matches/presentation/components/MatchesTabbedTable";
import PageLoader from "../components/PageLoader";
import ContentLoader from "../components/ContentLoader";

// Fetch match center data from database
let fixtures: any[] = [];
let results: any[] = [];
let hasError = false;
try {
  const [upcomingMatches, completedMatches] = await Promise.all([
    getUpcomingMatches(),
    getCompletedMatches(),
  ]);

  fixtures = upcomingMatches.map((m) => ({
    id: m.id,
    date: m.date,
    team1Name: m.team1Name || m.team1?.name || "TBD",
    team2Name: m.team2Name || m.team2?.name || "TBD",
    league: m.league?.name || m.leagueName || "Unknown League",
    venue: (m as any).venue || "Main Court", // Use placeholder since venue isn't in current schema
    status: m.status,
  }));

  results = completedMatches.map((m) => ({
    id: m.id,
    date: m.date,
    team1Name: m.team1Name || m.team1?.name || "TBD",
    team2Name: m.team2Name || m.team2?.name || "TBD",
    team1Score: m.team1Score ?? "-",
    team2Score: m.team2Score ?? "-",
    league: m.league?.name || m.leagueName || "Unknown League",
    winnerName:
      m.winner?.name ||
      (m.winnerId === m.team1Id
        ? m.team1Name
        : m.winnerId === m.team2Id
          ? m.team2Name
          : undefined),
    status: m.status,
  }));
} catch (error) {
  console.error("Error fetching matches:", error);
  hasError = true;
}
---

<Layout
  title="Upcoming Fixtures - Elevate Basketball Schedule"
  description="Never miss a game! View the complete schedule of upcoming basketball matches, venues, and tip-off times for the Elevate Basketball league."
  canonicalURL={`${Astro.url.origin}/upcoming-fixtures/`}
  type="website"
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebPage",
          "@id": `${Astro.url.origin}/upcoming-fixtures/`,
          url: `${Astro.url.origin}/upcoming-fixtures/`,
          name: "Upcoming Fixtures - Elevate Basketball Schedule",
          isPartOf: { "@id": `${Astro.url.origin}/#website` },
          description:
            "Never miss a game! View the complete schedule of upcoming basketball matches, venues, and tip-off times for the Elevate Basketball league.",
          breadcrumb: {
            "@id": `${Astro.url.origin}/upcoming-fixtures/#breadcrumb`,
          },
          inLanguage: "en-US",
        },
        {
          "@type": "BreadcrumbList",
          "@id": `${Astro.url.origin}/upcoming-fixtures/#breadcrumb`,
          itemListElement: [
            {
              "@type": "ListItem",
              position: 1,
              name: "Home",
              item: `${Astro.url.origin}/`,
            },
            {
              "@type": "ListItem",
              position: 2,
              name: "Upcoming Fixtures",
            },
          ],
        },
      ],
    })}
  />
  <PageLoader client:load />
  <div id="wrapper" class="match-center-page-shell">
    <TopBar />
    <Header client:load currentPath={Astro.url.pathname} />
    <div id="main">
      <div
        class="stm-title-box-unit transparent-header_on title_box-357"
        style="padding-top: 0; padding-bottom: 0px;"
      >
      </div>
      <div class="container">
        <section class="wpb-content-wrapper">
          <div class="vc_row wpb_row vc_row-fluid">
            <div class="wpb_column vc_column_container vc_col-sm-12">
              <div class="vc_column-inner">
                <div class="wpb_wrapper">
                  <Spacing
                    id="stm-spacing-fixtures-header"
                    lg="80"
                    md="70"
                    sm="60"
                    xs="50"
                  />

                  {
                    hasError ? (
                      <ContentLoader
                        client:load
                        message="Failed to load the match center. Please try again later."
                      />
                    ) : (
                      <div class="sp-template sp-template-event-list">
                        <MatchesTabbedTable
                          fixtures={fixtures}
                          results={results}
                          initialTab="fixtures"
                          client:load
                        />
                      </div>
                    )
                  }

                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
    <Footer />

  </div>
  <!--main-->
  <!--wrapper-->

  <div class="rev-close-btn">
    <span class="close-left"></span>
    <span class="close-right"></span>
  </div>

  <script is:inline>
    window.RS_MODULES = window.RS_MODULES || {};
    window.RS_MODULES.modules = window.RS_MODULES.modules || {};
    window.RS_MODULES.waiting = window.RS_MODULES.waiting || [];
    window.RS_MODULES.defered = true;
    window.RS_MODULES.moduleWaiting = window.RS_MODULES.moduleWaiting || {};
    window.RS_MODULES.type = "compiled";
  </script>
  <script
    is:inline
    type="speculationrules"
    set:html={JSON.stringify({
      prefetch: [
        {
          source: "document",
          where: {
            and: [
              { href_matches: "/*" },
              {
                not: {
                  href_matches: [
                    "/wp-*.php",
                    "/wp-admin/*",
                    "/wp-content/uploads/*",
                    "/wp-content/*",
                    "/wp-content/plugins/*",
                    "/wp-content/themes/elevate/*",
                    "/*\\?(.+)",
                  ],
                },
              },
              { not: { selector_matches: 'a[rel~="nofollow"]' } },
              { not: { selector_matches: ".no-prefetch, .no-prefetch a" } },
            ],
          },
          eagerness: "conservative",
        },
      ],
    })}
  />

  <style is:inline type="text/css">
    .sp-footer-sponsors {
      background: #f4f4f4;
      color: #363f48;
    }
    .sp-footer-sponsors .sp-sponsors .sp-sponsors-title {
      color: #363f48;
    }

    /* Smooth scroll behavior - Matching homepage */
    html {
      scroll-behavior: smooth;
    }

    html:has(#wrapper.match-center-page-shell),
    body:has(#wrapper.match-center-page-shell) {
      background:
        radial-gradient(circle at top center, rgba(255, 186, 0, 0.08), transparent 30%),
        linear-gradient(180deg, #0f0d18 0%, #14111f 100%) !important;
    }

    /* Dark section background to complement the dark match cards */
    #main {
      background:
        radial-gradient(circle at top center, rgba(255, 186, 0, 0.08), transparent 30%),
        linear-gradient(180deg, #0f0d18 0%, #14111f 100%);
    }

    .match-center-page-shell {
      background:
        radial-gradient(circle at top center, rgba(255, 186, 0, 0.08), transparent 30%),
        linear-gradient(180deg, #0f0d18 0%, #14111f 100%) !important;
      min-height: 100vh;
    }

    .sp-template-event-list {
      margin-top: 20px;
      margin-bottom: 20px;
    }
  </style>

  <div class="sp-header-sponsors" style="margin-top: 10px; margin-right: 10px;">
    <div class="sportspress"><div class="sp-sponsors"></div></div>
  </div>

  <script is:inline type="text/javascript">
    jQuery(document).ready(function ($) {
      $(".sp-header").prepend($(".sp-header-sponsors"));
    });
  </script>

  <style is:inline type="text/css">
    /* Hide reCAPTCHA V3 badge */
    .grecaptcha-badge {
      visibility: hidden !important;
    }
  </style>

  <script is:inline type="text/javascript">
    jQuery(document).ready(function ($) {
      $(".sp-header-loaded").prepend($(".sp-league-menu"));
    });
  </script>
  <script is:inline type="text/javascript">
    jQuery(document).ready(function ($) {
      $(".sp-header-loaded").prepend($(".sp-header-scoreboard"));
    });
  </script>
</Layout>
<!-- wrapper -->
