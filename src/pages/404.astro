---
import Layout from "../layouts/Layout.astro";
import TopBar from "../features/layout/components/TopBar.astro";
import Header from "../features/layout/components/Header";
import Footer from "../features/layout/components/Footer.astro";
import Spacing from "../shared/components/ui/Spacing.astro";
import PageLoader from "../components/PageLoader";

const quickLinks = [
  { href: "/", label: "Go to Home" },
  { href: "/standings/", label: "View Standings" },
  { href: "/teams/", label: "Browse Teams" },
  { href: "/contacts/", label: "Contact Us" },
];
---

<Layout
  title="Page Not Found - Elevate Basketball"
  description="The page you are looking for doesn't exist. Head back to Elevate Basketball home or explore standings, teams, and upcoming fixtures."
  robots="noindex, follow"
>
  <PageLoader client:load />
  <div id="wrapper">
    <TopBar />
    <Header client:load currentPath={Astro.url.pathname} />
    <div id="main">
      <div
        class="stm-title-box-unit transparent-header_on title_box-357"
        style="padding-top: 0; padding-bottom: 0px;"
      >
      </div>
      <div class="container">
        <section class="wpb-content-wrapper">
          <div class="vc_row wpb_row vc_row-fluid">
            <div class="wpb_column vc_column_container vc_col-sm-12">
              <div class="vc_column-inner">
                <div class="wpb_wrapper">
                  <Spacing
                    id="stm-spacing-404-header"
                    lg="80"
                    md="70"
                    sm="60"
                    xs="50"
                  />

                  <div
                    class="not-found-wrap"
                    style="text-align: center; max-width: 820px; margin: 0 auto;"
                  >
                    <img
                      src="/images/Elevate_Icon-200x200.png"
                      alt="Elevate Basketball"
                      width="120"
                      height="120"
                      style="display: inline-block; margin-bottom: 18px;"
                      loading="eager"
                    />
                    <h1
                      class="heading-font"
                      style="margin-bottom: 12px; color: #dd3333;"
                    >
                      404 - Page Not Found
                    </h1>
                    <p
                      class="normal_font"
                      style="font-size: 18px; line-height: 1.8; color: #363f48; margin-bottom: 22px;"
                    >
                      The page you requested does not exist or may have been moved.
                      Check the address, or use the links below to get back in the game.
                    </p>

                    <div class="row" style="margin-top: 10px;">
                      {quickLinks.map((link) => (
                        <div class="col-sm-6" style="margin-bottom: 14px;">
                          <a
                            class="btn btn-secondary btn-lg"
                            href={link.href}
                            title={link.label}
                            style="min-width: 220px;"
                          >
                            {link.label}
                          </a>
                        </div>
                      ))}
                    </div>
                  </div>

                  <Spacing
                    id="stm-spacing-404-footer"
                    lg="60"
                    md="60"
                    sm="50"
                    xs="40"
                  />
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
    <Footer />

  </div>
  <!--main-->
  <!--wrapper-->

  <div class="rev-close-btn">
    <span class="close-left"></span>
    <span class="close-right"></span>
  </div>

  <script is:inline>
    window.RS_MODULES = window.RS_MODULES || {};
    window.RS_MODULES.modules = window.RS_MODULES.modules || {};
    window.RS_MODULES.waiting = window.RS_MODULES.waiting || [];
    window.RS_MODULES.defered = true;
    window.RS_MODULES.moduleWaiting = window.RS_MODULES.moduleWaiting || {};
    window.RS_MODULES.type = "compiled";
  </script>
</Layout>
