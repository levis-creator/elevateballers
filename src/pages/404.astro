---
export const prerender = false;

import { usePublicV2 } from "@/lib/ui-version";

// v2-only route. Rewrite to the legacy 404 when the flag is off — URL stays /404.
if (!usePublicV2) return Astro.rewrite("/404-v1");

// Ensure a real 404 status, including when other routes Astro.rewrite("/404").
Astro.response.status = 404;

import LayoutV2 from "@/layouts/v2/Layout.astro";
import NotFound from "@/features/layout/presentation/v2/NotFound.astro";
---

<LayoutV2
	title="Page Not Found - Elevate Ballers"
	description="That shot missed — the page you're looking for isn't on the court. Head back home or explore standings, teams, fixtures and results."
	robots="noindex, follow"
>
	<NotFound />
</LayoutV2>
