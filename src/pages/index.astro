---
export const prerender = false;

// Edge cache the homepage for 5 min — most visitors see the exact same content
// so serving from cache avoids running ~8 DB queries per visit. SWR keeps
// stale content serving instantly while the next request triggers a refresh,
// so admins editing settings see updates within ~5 min and visitors never wait.
Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=300, stale-while-revalidate=600'
);

import Layout from "../layouts/Layout.astro";
import TopBar from "../features/layout/components/TopBar.astro";
import Header from "../features/layout/components/Header";
import Footer from "../features/layout/components/Footer.astro";
import MarqueeMatchup from "../features/home/components/MarqueeMatchup.astro";
import PlayerOfTheWeek from "../features/home/components/PlayerOfTheWeek.astro";
import StatsSection from "../features/home/components/StatsSection";
import PostSlider from "../features/home/components/PostSlider";
import NewsTicker from "../features/home/components/NewsTicker";
import NextMatchCarousel from "../features/home/components/NextMatchCarousel";
import LatestNews from "../features/home/components/LatestNews";
import RecentResultsCarousel from "../features/home/components/RecentResultsCarousel";
import Sponsors from "../features/home/components/Sponsors";
import StatsLeadersSection from "../features/home/components/StatsLeadersSection";
import MediaGallery from "../features/media/components/MediaGallery";
import HomepageIntro from "../features/home/components/HomepageIntro.astro";
import FeatureGate from "../components/FeatureGate.astro";
import { isFeatureEnabled } from "../lib/feature-flags";
import PageLoader from "../components/PageLoader";
import { getAllSiteSettings } from "../features/cms/lib/queries";
import { getFeaturedNewsArticles } from "../features/cms/lib/queries/news";
import { optimizeImageUrl } from "../lib/image-cdn";

// Editable in admin → Settings → SEO. Defaults match the previously
// hardcoded values so behaviour is unchanged until an admin overrides them.
const DEFAULT_SEO_TITLE =
  "Elevate Ballers - Kenya's Premier Basketball League & Championships";
const DEFAULT_SEO_DESCRIPTION =
  "Elevate Ballers is Kenya's premier basketball league hosting championships in Nairobi. Follow live standings, rising stars, and match results from our basketball community.";
const DEFAULT_SEO_IMAGE = "/images/Elevate_Icon-200x200.png";
const DEFAULT_SEO_KEYWORDS =
  "basketball, basketball league, Kenya basketball, Elevate Ballers, championships, Nairobi basketball, basketball news, basketball standings, basketball fixtures";

let seoTitle = DEFAULT_SEO_TITLE;
let seoDescription = DEFAULT_SEO_DESCRIPTION;
let seoImage = DEFAULT_SEO_IMAGE;
let seoKeywords = DEFAULT_SEO_KEYWORDS;

try {
  const seoSettings = await getAllSiteSettings("seo");
  for (const s of seoSettings) {
    if (s.key === "seo_homepage_title" && s.value) seoTitle = s.value;
    if (s.key === "seo_homepage_description" && s.value) seoDescription = s.value;
    if (s.key === "seo_homepage_image" && s.value) seoImage = s.value;
    if (s.key === "seo_homepage_keywords" && s.value) seoKeywords = s.value;
  }
} catch (err) {
  console.error("[index.astro] failed to load SEO settings, using defaults:", err);
}

// LCP optimization: pre-fetch the first featured news article on the server
// so we can preload its hero image during HTML parse — the PostSlider hero
// is the LCP element and previously didn't start loading until React
// hydrated and then fetched the API. Preloading shaves several seconds.
let heroPreloadImage: string | undefined;
try {
  const featured = await getFeaturedNewsArticles();
  const firstImage = featured[0]?.image;
  if (firstImage) {
    heroPreloadImage = optimizeImageUrl(firstImage, { width: 1600 });
  }
} catch (err) {
  console.error("[index.astro] failed to fetch featured news for LCP preload:", err);
}
---

<Layout
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  keywords={seoKeywords}
  preloadImage={heroPreloadImage}
  canonicalURL={`${Astro.url.origin}/`}
  type="website"
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": `${Astro.url.origin}/#website`,
          url: `${Astro.url.origin}/`,
          name: "Elevate Ballers",
          description: seoDescription,
          inLanguage: "en-US",
          publisher: { "@id": `${Astro.url.origin}/#organization` },
        },
        {
          "@type": "WebPage",
          "@id": `${Astro.url.origin}/`,
          url: `${Astro.url.origin}/`,
          name: seoTitle,
          isPartOf: { "@id": `${Astro.url.origin}/#website` },
          about: { "@id": `${Astro.url.origin}/#organization` },
          primaryImageOfPage: { "@id": `${Astro.url.origin}/#logo` },
          description: seoDescription,
          breadcrumb: { "@id": `${Astro.url.origin}/#breadcrumb` },
          inLanguage: "en-US",
        },
        {
          "@type": "BreadcrumbList",
          "@id": `${Astro.url.origin}/#breadcrumb`,
          itemListElement: [
            {
              "@type": "ListItem",
              position: 1,
              name: "Home",
              item: `${Astro.url.origin}/`,
            },
          ],
        },
        {
          "@type": "ImageObject",
          "@id": `${Astro.url.origin}/#logo`,
          url: `${Astro.url.origin}/images/Elevate_Icon-200x200.png`,
          contentUrl: `${Astro.url.origin}/images/Elevate_Icon-200x200.png`,
          width: 200,
          height: 200,
          caption: "Elevate Ballers",
          inLanguage: "en-US",
        },
        {
          "@type": "SportsOrganization",
          "@id": `${Astro.url.origin}/#organization`,
          name: "Elevate Ballers",
          url: `${Astro.url.origin}/`,
          sport: "Basketball",
          description:
            "Premier basketball league providing high-quality competition, player development, and community engagement.",
          address: {
            "@type": "PostalAddress",
            streetAddress: "Pepo Lane, off Dagoretti Road",
            addressLocality: "Nairobi",
            addressCountry: "KE",
          },
          email: "ballers@elevateballers.com",
          logo: { "@id": `${Astro.url.origin}/#logo` },
          image: { "@id": `${Astro.url.origin}/#logo` },
        },
      ],
    })}
  />
  <PageLoader client:load />
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <div id="wrapper">
    {isFeatureEnabled("layout.topbar") && <TopBar />}
    {
      isFeatureEnabled("layout.header") && (
        <Header client:load currentPath={Astro.url.pathname} />
      )
    }

    <main id="main" role="main">
      <h1 class="sr-only">Elevate Ballers - Kenya's Premier Basketball League & Championships</h1>
      <!-- Hero Section: Post Slider -->
      <FeatureGate feature="home.postSlider">
        <section class="hero-section" aria-label="Featured content">
          <div class="container">
            <PostSlider client:load />
          </div>
        </section>
      </FeatureGate>

      <!-- News Ticker Section -->
      <FeatureGate feature="home.newsTicker">
        <section class="news-ticker-section" aria-label="Latest news ticker">
          <NewsTicker client:load />
        </section>
      </FeatureGate>

      <!-- Marquee Matchup Section -->
      <FeatureGate feature="home.marqueeMatchup">
        <section
          class="marquee-matchup-section section"
          aria-label="Featured match"
        >
          <MarqueeMatchup />
        </section>
      </FeatureGate>

      <!-- Next Match Carousel Section -->
      <FeatureGate feature="home.nextMatchCarousel">
        <section
          class="next-match-section section"
          aria-label="Upcoming matches"
        >
          <div class="container">
            <div class="row">
              <div class="col-md-6 col-sm-12">
                <NextMatchCarousel client:visible />
              </div>
              <div class="col-md-6 col-sm-12">
                <RecentResultsCarousel client:visible />
              </div>
            </div>
          </div>
        </section>
      </FeatureGate>

      <!-- Latest News Section -->
      <FeatureGate feature="home.latestNews">
        <section
          class="latest-news-section section"
          id="main-content"
          aria-label="Latest news"
        >
          <div class="container">
            <LatestNews client:visible />
          </div>
        </section>
      </FeatureGate>

      <!-- Player of the Week Section -->
      <section
        class="player-week-section section"
        aria-label="Player of the week"
      >
        <div class="container">
          <PlayerOfTheWeek />
        </div>
      </section>

      <!-- Stats Leaders Section -->
      <FeatureGate feature="home.statsLeaders">
        <section
          class="stats-leaders-section section"
          aria-label="Statistics and leaders"
        >
          <div class="container">
            <!-- Redesigned Stats Leaders Section - Integrated React Component -->
            <StatsLeadersSection client:visible />
          </div>
        </section>
      </FeatureGate>

      <!-- Statistics Section -->
      <FeatureGate feature="home.statsSection">
        <section
          class="statistics-section section"
          aria-label="League statistics"
        >
          <div class="container">
            <StatsSection client:visible />
          </div>
        </section>
      </FeatureGate>

      <!-- Media Gallery Section -->
      <FeatureGate feature="home.mediaGallery">
        <section
          class="media-gallery-section section"
          aria-label="Media gallery"
        >
          <div class="container">
            <MediaGallery client:visible />
          </div>
        </section>
      </FeatureGate>

      <!-- Sponsors Section (renders only if there are active sponsors) -->
      <Sponsors client:visible />

      <!-- Homepage Intro (editable in admin -> Settings -> Homepage Intro) -->
      <HomepageIntro />

      <!-- Registration CTA Section -->
      <FeatureGate feature="home.registrationCta">
        <section
          class="registration-cta-section section"
          aria-label="Join the league"
        >
          <div class="container">
            <div class="registration-cta-content">
              <h2 class="registration-title">
                Register to Join the League
              </h2>
              <p class="registration-description">
                Be part of Elevate Ballers, Kenya's premier basketball league.
                Join us today and elevate your game!
              </p>
              <a
                class="btn btn-secondary btn-lg"
                href="/league-registration/"
                title="Open the league registration form"
              >
                Open Registration Form
              </a>
            </div>
          </div>
        </section>
      </FeatureGate>
    </main>

    {isFeatureEnabled("layout.footer") && <Footer />}

  </div>

  <!-- Additional Scripts and Styles -->
  <div class="rev-close-btn" aria-hidden="true">
    <span class="close-left"></span>
    <span class="close-right"></span>
  </div>

  <!-- Speculation Rules for Prefetching -->
  <script is:inline type="speculationrules">
    {
      "prefetch": [
        {
          "source": "document",
          "where": {
            "and": [
              { "href_matches": "/*" },
              {
                "not": {
                  "href_matches": [
                    "/wp-*.php",
                    "/wp-admin/*",
                    "/wp-content/uploads/*",
                    "/wp-content/*",
                    "/wp-content/plugins/*",
                    "/wp-content/themes/elevate/*",
                    "/*\\?(.+)"
                  ]
                }
              },
              { "not": { "selector_matches": "a[rel~=\"nofollow\"]" } },
              { "not": { "selector_matches": ".no-prefetch, .no-prefetch a" } }
            ]
          },
          "eagerness": "conservative"
        }
      ]
    }
  </script>

  <!-- Header Sponsors -->
  <div
    class="sp-header-sponsors"
    style="margin-top: 10px; margin-right: 10px;"
    aria-hidden="true"
  >
    <div class="sportspress"><div class="sp-sponsors"></div></div>
  </div>

  <!-- Legacy Scripts (jQuery is loaded with `defer` in Layout.astro, so we
       must wait for DOMContentLoaded before assuming it's available.) -->
  <script is:inline type="text/javascript">
    document.addEventListener("DOMContentLoaded", function () {
      if (typeof jQuery !== "undefined") {
        jQuery(function ($) {
          var header = $(".sp-header");
          var sponsors = $(".sp-header-sponsors");
          if (header.length && sponsors.length) {
            header.prepend(sponsors);
          }
        });
      }
    });
  </script>

  <script is:inline>
    (function () {
      function maybePrefixUrlField() {
        const value = this.value.trim();
        if (value !== "" && value.indexOf("http") !== 0) {
          this.value = "http://" + value;
        }
      }

      const urlFields = document.querySelectorAll(
        '.mc4wp-form input[type="url"]',
      );
      for (let j = 0; j < urlFields.length; j++) {
        urlFields[j].addEventListener("blur", maybePrefixUrlField);
      }
    })();
  </script>

  <style is:inline type="text/css">
    /* Hide reCAPTCHA V3 badge */
    .grecaptcha-badge {
      visibility: hidden !important;
    }

    /* No extra margin before footer on homepage */
    .stm-footer {
      margin-top: 0 !important;
    }

    /* Landing Page Specific Styles */
    .hero-section {
      padding: 0;
    }

    .news-ticker-section {
      width: 100%;
    }

    .marquee-matchup-section {
      padding: 0 !important;
    }

    /* Reserve vertical space for sections whose React content hydrates with
       `client:visible`. Without these min-heights, content slots in late and
       pushes everything below it down, killing the CLS score. Values lean
       slightly conservative for typical desktop renders; on mobile the
       content may exceed them with a small shift. */
    .next-match-section {
      background: var(--color-accent-dark, #2d1e49)
        url("/images/basketball-game-concept-scaled.jpg") center center
        no-repeat;
      background-size: cover;
      position: relative;
      color: white;
      min-height: 420px;
    }

    .next-match-section::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: radial-gradient(
        circle at center,
        rgba(45, 30, 73, 0.6) 0%,
        rgba(20, 10, 40, 0.95) 100%
      );
      z-index: 0;
    }

    .next-match-section > * {
      position: relative;
      z-index: 1;
    }

    .latest-news-section {
      background-color: var(--color-white, #ffffff);
      min-height: 700px;
    }

    .player-week-section {
      background-color: var(--color-white, #ffffff);
    }

    .stats-leaders-section {
      background-color: var(--color-white, #ffffff);
      min-height: 480px;
    }

    .stats-leaders-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: var(--spacing-8, 2rem);
      flex-wrap: wrap;
      gap: var(--spacing-4, 1rem);
    }

    .section-title {
      margin: 0;
    }

    .statistics-section {
      background-color: var(--color-secondary, #ffba00);
      min-height: 280px;
    }

    .media-gallery-section {
      background-color: var(--color-white, #ffffff);
      min-height: 580px;
    }

    .sponsors-section {
      background-color: var(--color-gray-100, #f2f4f7);
    }

    .registration-cta-section {
      background: var(--color-accent-dark, #301e48) url("/images/award.png")
        center center no-repeat;
      background-size: contain;
      position: relative;
      text-align: center;
      color: white;
    }

    .registration-cta-content {
      max-width: 800px;
      margin: 0 auto;
    }

    .registration-title {
      font-size: clamp(2rem, 4vw + 1rem, 4.5rem);
      color: white;
      margin-bottom: var(--spacing-6, 1.5rem);
    }

    .registration-title a {
      color: white;
      text-decoration: none;
      transition: color var(--transition-base, 250ms);
    }

    .registration-title a:hover,
    .registration-title a:focus {
      color: var(--color-secondary, #ffba00);
    }

    .registration-description {
      font-size: var(--font-size-lg, 1.25rem);
      margin-bottom: var(--spacing-8, 2rem);
      color: rgba(255, 255, 255, 0.9);
    }

    .sp-footer-sponsors {
      background: #f4f4f4;
      color: #363f48;
    }
    .sp-footer-sponsors .sp-sponsors .sp-sponsors-title {
      color: #363f48;
    }

    /* Responsive Adjustments */
    @media (max-width: 768px) {
      .stats-leaders-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .registration-title {
        font-size: clamp(1.5rem, 5vw, 3rem);
      }
    }
  </style>

  <!-- External CSS Files -->
  <link
    rel="stylesheet"
    id="stm_post_slider-css"
    href="/css/stm_post_slider.css"
    type="text/css"
    media="all"
  />
  <link
    rel="stylesheet"
    id="stm_next_match_carousel2-css"
    href="/css/stm_next_match_carousel2.css"
    type="text/css"
    media="all"
  />
  <link
    rel="stylesheet"
    id="stm_media_tabs_default-css"
    href="/css/stm_media_tabs_default.css"
    type="text/css"
    media="all"
  />
  <link
    rel="stylesheet"
    id="rs-plugin-settings-css"
    href="/css/rs6.css"
    type="text/css"
    media="all"
  />
</Layout>
