---
export const prerender = false;

// Edge cache the homepage for 5 min — most visitors see the exact same content
// so serving from cache avoids running DB queries per visit. SWR keeps stale
// content serving instantly while the next request triggers a refresh.
Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=300, stale-while-revalidate=600'
);

import { usePublicV2 } from "@/lib/ui-version";
import HomeV2 from "@/features/home/presentation/v2/HomeV2.astro";

// This route imports ONLY the v2 tree, so v1's global CSS can never reach it.
// When the flag is off we internally rewrite to the legacy home (URL stays `/`).
// A static/dynamic import + ternary would NOT work: Astro links every stylesheet
// in a page's module graph, so both UIs' CSS would ship. Separate routes +
// rewrite is the only reliable isolation.
if (!usePublicV2) return Astro.rewrite("/home-v1");
---

<HomeV2 />
