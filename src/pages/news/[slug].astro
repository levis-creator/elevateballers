---
export const prerender = false;

Astro.response.headers.set("Cache-Control", "public, s-maxage=120, stale-while-revalidate=300");

import { usePublicV2 } from "@/lib/ui-version";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404", 302);

// v2-only route (imports only the v2 tree). Rewrite to the legacy page when the
// flag is off — URL stays /news/<slug>.
if (!usePublicV2) return Astro.rewrite(`/news-v1/${slug}`);

import LayoutV2 from "@/layouts/v2/Layout.astro";
import NewsDetailPage from "@/features/news/presentation/v2/NewsDetailPage.astro";
import { getArticleView } from "@/features/news/domain/usecases/get-article-view";

const view = await getArticleView(slug);
if (!view) return Astro.redirect("/404", 302);

const seoTitle = `${view.title} - Elevate Ballers`;
const seoDescription = view.excerpt || view.title;
---

<LayoutV2
	title={seoTitle}
	description={seoDescription}
	image={view.heroImage ?? undefined}
	canonicalURL={`${Astro.url.origin}/news/${view.slug}/`}
	type="article"
>
	<NewsDetailPage view={view} />
</LayoutV2>
