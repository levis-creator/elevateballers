---
export const prerender = false;

Astro.response.headers.set("Cache-Control", "public, s-maxage=120, stale-while-revalidate=300");

import { usePublicV2 } from "@/lib/ui-version";

// v2-only route. Rewrite to the legacy page when the flag is off — URL stays /news.
if (!usePublicV2) return Astro.rewrite("/news-v1");

import LayoutV2 from "@/layouts/v2/Layout.astro";
import NewsListPage from "@/features/news/presentation/v2/NewsListPage.astro";
---

<LayoutV2
	title="News - Elevate Ballers | Match Reports, Interviews & Analysis"
	description="The latest from Elevate Ballers — match reports, championship coverage, interviews and analysis from Kenya's premier basketball league."
	canonicalURL={`${Astro.url.origin}/news/`}
	type="website"
>
	<NewsListPage />
</LayoutV2>
