---
import Layout from "../layouts/Layout.astro";
import TopBar from "../features/layout/components/TopBar.astro";
import Header from "../features/layout/components/Header";
import Footer from "../features/layout/components/Footer.astro";
import Spacing from "../shared/components/ui/Spacing.astro";
import { standings as fallbackStandings } from "../features/standings/data/standingsData";
import { StandingsPage } from "../features/standings/components/StandingsPage";
import PageLoader from "../components/PageLoader";

// Fetch standings from API
let standings = fallbackStandings;
try {
  const baseUrl =
    import.meta.env.SITE || `http://localhost:${import.meta.env.PORT || 4321}`;
  const response = await fetch(`${baseUrl}/api/standings`);
  if (response.ok) {
    const data = await response.json();
    if (data && data.length > 0) {
      standings = data;
    }
  }
} catch (error) {
  console.error("Failed to fetch standings, using fallback data:", error);
}
---

<Layout
  title="League Standings - Elevate Basketball"
  description="Stay up to date with the latest Elevate Basketball league standings. Track team performance, wins, losses, and rankings across all our divisions."
  canonicalURL={`${Astro.url.origin}/standings/`}
  type="website"
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebPage",
          "@id": `${Astro.url.origin}/standings/`,
          url: `${Astro.url.origin}/standings/`,
          name: "League Standings - Elevate Basketball",
          isPartOf: { "@id": `${Astro.url.origin}/#website` },
          description:
            "Stay up to date with the latest Elevate Basketball league standings. Track team performance, wins, losses, and rankings across all our divisions.",
          breadcrumb: { "@id": `${Astro.url.origin}/standings/#breadcrumb` },
          inLanguage: "en-US",
        },
        {
          "@type": "BreadcrumbList",
          "@id": `${Astro.url.origin}/standings/#breadcrumb`,
          itemListElement: [
            {
              "@type": "ListItem",
              position: 1,
              name: "Home",
              item: `${Astro.url.origin}/`,
            },
            { "@type": "ListItem", position: 2, name: "Standings" },
          ],
        },
      ],
    })}
  />
  <PageLoader client:load />
  <div id="wrapper">
    <TopBar />
    <Header client:load currentPath={Astro.url.pathname} />
    <div id="main">
      <div
        class="stm-title-box-unit transparent-header_on title_box-357"
        style="padding-top: 0; padding-bottom: 0px;"
      >
      </div>
      <div class="container">
        <section class="wpb-content-wrapper">
          <div class="vc_row wpb_row vc_row-fluid">
            <div class="wpb_column vc_column_container vc_col-sm-12">
              <div class="vc_column-inner">
                <div class="wpb_wrapper">
                  <Spacing
                    id="stm-spacing-standings-header"
                    lg="80"
                    md="70"
                    sm="60"
                    xs="50"
                  />

                  <h1
                    class="heading-font"
                    style="text-align: center; margin-bottom: 50px; color: #dd3333;"
                  >
                    STANDINGS
                  </h1>

                  <div class="sp-template sp-template-league-table">
                    <StandingsPage initialStandings={standings} client:load />
                  </div>

                  <Spacing
                    id="stm-spacing-standings-footer"
                    lg="50"
                    md="50"
                    sm="40"
                    xs="40"
                  />
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
    <Footer />

  </div>
  <!--main-->
  <!--wrapper-->

  <div class="rev-close-btn">
    <span class="close-left"></span>
    <span class="close-right"></span>
  </div>

  <script is:inline>
    window.RS_MODULES = window.RS_MODULES || {};
    window.RS_MODULES.modules = window.RS_MODULES.modules || {};
    window.RS_MODULES.waiting = window.RS_MODULES.waiting || [];
    window.RS_MODULES.defered = true;
    window.RS_MODULES.moduleWaiting = window.RS_MODULES.moduleWaiting || {};
    window.RS_MODULES.type = "compiled";
  </script>
  <script is:inline type="speculationrules">
    {
      "prefetch": [
        {
          "source": "document",
          "where": {
            "and": [
              { "href_matches": "/*" },
              {
                "not": {
                  "href_matches": [
                    "/wp-*.php",
                    "/wp-admin/*",
                    "/wp-content/uploads/*",
                    "/wp-content/*",
                    "/wp-content/plugins/*",
                    "/wp-content/themes/elevate/*",
                    "/*\\?(.+)"
                  ]
                }
              },
              { "not": { "selector_matches": "a[rel~=\"nofollow\"]" } },
              { "not": { "selector_matches": ".no-prefetch, .no-prefetch a" } }
            ]
          },
          "eagerness": "conservative"
        }
      ]
    }
  </script>

  <style is:inline type="text/css">
    .sp-footer-sponsors {
      background: #f4f4f4;
      color: #363f48;
    }
    .sp-footer-sponsors .sp-sponsors .sp-sponsors-title {
      color: #363f48;
    }

    /* Smooth scroll behavior - Matching homepage */
    html {
      scroll-behavior: smooth;
    }

    /* Standings page specific styles */
    .wpb_wrapper h2.heading-font {
      font-size: 40px;
      line-height: 44px;
      margin-bottom: 50px;
      color: #dd3333 !important;
    }

  </style>

  <div class="sp-header-sponsors" style="margin-top: 10px; margin-right: 10px;">
    <div class="sportspress"><div class="sp-sponsors"></div></div>
  </div>

  <script is:inline type="text/javascript">
    jQuery(document).ready(function ($) {
      $(".sp-header").prepend($(".sp-header-sponsors"));
    });
  </script>

  <style is:inline type="text/css">
    /* Hide reCAPTCHA V3 badge */
    .grecaptcha-badge {
      visibility: hidden !important;
    }
  </style>
</Layout>
<!-- wrapper -->
