---
export const prerender = false;

// Edge cache standings for 60s — they change rarely.
Astro.response.headers.set("Cache-Control", "public, s-maxage=60, stale-while-revalidate=300");

import { usePublicV2 } from "@/lib/ui-version";

// v2-only route (imports only the v2 tree). Rewrite to the legacy standings when
// the flag is off — URL stays /standings.
if (!usePublicV2) return Astro.rewrite("/standings-v1");

import LayoutV2 from "@/layouts/v2/Layout.astro";
import StandingsPage from "@/features/standings/presentation/v2/StandingsPage.astro";
---

<LayoutV2
	title="Standings - Elevate Ballers | League Table"
	description="Live Elevate Ballers league standings — points, wins, losses, differentials and playoff positions, filterable by season."
	canonicalURL={`${Astro.url.origin}/standings/`}
	type="website"
>
	<StandingsPage />
</LayoutV2>
