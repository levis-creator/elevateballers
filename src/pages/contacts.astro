---
import Layout from "../layouts/Layout.astro";
import TopBar from "../features/layout/components/TopBar.astro";
import Header from "../features/layout/components/Header";
import Footer from "../features/layout/components/Footer.astro";
import Spacing from "../shared/components/ui/Spacing.astro";
import PageLoader from "../components/PageLoader";
import ContactForm from "../features/contact/components/ContactForm";
import { prisma } from "../lib/prisma";

const DEFAULT_CONTACT = {
  address: 'Pepo Lane, off Dagoretti Road',
  phone: '0703913923',
  fax: '0729259496',
  email: 'ballers@elevateballers.com',
  hours: 'Sat-Sun 8am - 6pm',
};

let contact = { ...DEFAULT_CONTACT };
let contactDescription = "Have questions or want to join the league? Contact Elevate Basketball.";

try {
  const settings = await prisma.siteSetting.findMany({
    where: {
      key: {
        in: [
          'contact_address',
          'contact_phone',
          'contact_fax',
          'contact_email',
          'contact_hours',
        ],
      },
    },
  });

  const settingsMap = settings.reduce((acc, curr) => {
    acc[curr.key] = curr.value;
    return acc;
  }, {} as Record<string, string>);

  const getValue = (key: string, fallback: string) =>
    Object.prototype.hasOwnProperty.call(settingsMap, key)
      ? settingsMap[key]
      : fallback;

  contact = {
    address: getValue('contact_address', DEFAULT_CONTACT.address),
    phone: getValue('contact_phone', DEFAULT_CONTACT.phone),
    fax: getValue('contact_fax', DEFAULT_CONTACT.fax),
    email: getValue('contact_email', DEFAULT_CONTACT.email),
    hours: getValue('contact_hours', DEFAULT_CONTACT.hours),
  };

  contactDescription = contact.address
    ? `Have questions or want to join the league? Contact Elevate Basketball. Find our location at ${contact.address}, reach us by phone, or send us a message.`
    : contactDescription;
} catch (error) {
  console.error("Error fetching contact settings:", error);
}
---

<Layout
  title="Contact Us - Elevate Basketball"
  description={contactDescription}
>
  <PageLoader client:load />
  <div id="wrapper">
    <TopBar />
    <Header client:load currentPath={Astro.url.pathname} />
    <div id="main">
      <div
        class="stm-title-box-unit transparent-header_on title_box-357"
        style="padding-top: 0; padding-bottom: 0px;"
      >
      </div>
      <div class="container">
        <section class="wpb-content-wrapper">
          <div class="vc_row wpb_row vc_row-fluid">
            <div class="wpb_column vc_column_container vc_col-sm-12">
              <div class="vc_column-inner">
                <div class="wpb_wrapper">
                  <Spacing
                    id="stm-spacing-contacts-header"
                    lg="80"
                    md="70"
                    sm="60"
                    xs="50"
                  />

                  <h1
                    class="heading-font"
                    style="text-align: center; margin-bottom: 50px; color: #dd3333;"
                  >
                    CONTACTS
                  </h1>

                  <div class="vc_row wpb_row vc_inner vc_row-fluid">
                    <div class="wpb_column vc_column_container vc_col-sm-6">
                      <div class="vc_column-inner">
                        <div class="wpb_wrapper">
                          <div
                            class="contact-info normal_font"
                            style="margin-bottom: 30px;"
                          >
                            <h3
                              class="heading-font"
                              style="color: #dd3333; margin-bottom: 20px; font-size: 24px;"
                            >
                              Contact Information
                            </h3>
                            <table
                              class="stm-list-duty normal_font"
                              style="width: 100%;"
                            >
                              <tbody>
                                <tr>
                                  <td style="padding: 10px 0;">
                                    <div
                                      style="display: flex; align-items: center;"
                                    >
                                      <i
                                        class="fa fa-map-marker"
                                        style="margin-right: 15px; color: #dd3333; font-size: 18px;"
                                      ></i>
                                      <span>{contact.address}</span>
                                    </div>
                                  </td>
                                </tr>
                                <tr>
                                  <td style="padding: 10px 0;">
                                    <div
                                      style="display: flex; align-items: center;"
                                    >
                                      <i
                                        class="fa fa-phone"
                                        style="margin-right: 15px; color: #dd3333; font-size: 18px;"
                                      ></i>
                                      <span>{contact.phone}</span>
                                    </div>
                                  </td>
                                </tr>
                                <tr>
                                  <td style="padding: 10px 0;">
                                    <div
                                      style="display: flex; align-items: center;"
                                    >
                                      <i
                                        class="fa fa-fax"
                                        style="margin-right: 15px; color: #dd3333; font-size: 18px;"
                                      ></i>
                                      <span>{contact.fax}</span>
                                    </div>
                                  </td>
                                </tr>
                                <tr>
                                  <td style="padding: 10px 0;">
                                    <div
                                      style="display: flex; align-items: center;"
                                    >
                                      <i
                                        class="fa fa-envelope"
                                        style="margin-right: 15px; color: #dd3333; font-size: 18px;"
                                      ></i>
                                      {contact.email && (
                                        <a
                                          href={`mailto:${contact.email}`}
                                          style="color: #595959; text-decoration: none;"
                                        >
                                          {contact.email}
                                        </a>
                                      )}
                                    </div>
                                  </td>
                                </tr>
                                <tr>
                                  <td style="padding: 10px 0;">
                                    <div
                                      style="display: flex; align-items: center;"
                                    >
                                      <i
                                        class="fa fa-clock-o"
                                        style="margin-right: 15px; color: #dd3333; font-size: 18px;"
                                      ></i>
                                      <span>{contact.hours}</span>
                                    </div>
                                  </td>
                                </tr>
                              </tbody>
                            </table>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="wpb_column vc_column_container vc_col-sm-6">
                      <div class="vc_column-inner">
                        <div class="wpb_wrapper">
                          <div class="contact-form-wrapper">
                            <h3
                              class="heading-font"
                              style="color: #dd3333; margin-bottom: 20px; font-size: 24px;"
                            >
                              Send us a Message
                            </h3>
                            <ContactForm client:load />
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <Spacing
                    id="stm-spacing-contacts-footer"
                    lg="50"
                    md="50"
                    sm="40"
                    xs="40"
                  />
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
    <Footer />

  </div>
  <!--main-->
  <!--wrapper-->

  <div class="rev-close-btn">
    <span class="close-left"></span>
    <span class="close-right"></span>
  </div>

  <script is:inline>
    window.RS_MODULES = window.RS_MODULES || {};
    window.RS_MODULES.modules = window.RS_MODULES.modules || {};
    window.RS_MODULES.waiting = window.RS_MODULES.waiting || [];
    window.RS_MODULES.defered = true;
    window.RS_MODULES.moduleWaiting = window.RS_MODULES.moduleWaiting || {};
    window.RS_MODULES.type = "compiled";
  </script>

  <script is:inline type="speculationrules">
    {
      "prefetch": [
        {
          "source": "document",
          "where": {
            "and": [
              { "href_matches": "/*" },
              {
                "not": {
                  "href_matches": [
                    "/wp-*.php",
                    "/wp-admin/*",
                    "/wp-content/uploads/*",
                    "/wp-content/*",
                    "/wp-content/plugins/*",
                    "/wp-content/themes/elevate/*",
                    "/*\\?(.+)"
                  ]
                }
              },
              { "not": { "selector_matches": "a[rel~=\"nofollow\"]" } },
              { "not": { "selector_matches": ".no-prefetch, .no-prefetch a" } }
            ]
          },
          "eagerness": "conservative"
        }
      ]
    }
  </script>

  <style is:inline type="text/css">
    .sp-footer-sponsors {
      background: #f4f4f4;
      color: #363f48;
    }
    .sp-footer-sponsors .sp-sponsors .sp-sponsors-title {
      color: #363f48;
    }

    /* Smooth scroll behavior - Matching homepage */
    html {
      scroll-behavior: smooth;
    }

    /* Contacts page specific styles */
    .wpb_wrapper h2.heading-font {
      font-size: 40px;
      line-height: 44px;
      margin-bottom: 50px;
      color: #dd3333 !important;
    }

    .contact-info table td {
      color: #363f48;
    }

    @media (max-width: 767px) {
      .vc_col-sm-6 {
        margin-bottom: 30px;
      }
    }
  </style>


  <div class="sp-header-sponsors" style="margin-top: 10px; margin-right: 10px;">
    <div class="sportspress"><div class="sp-sponsors"></div></div>
  </div>


  <style is:inline type="text/css">
    /* Hide reCAPTCHA V3 badge */
    .grecaptcha-badge {
      visibility: hidden !important;
    }
  </style>

  <script is:inline type="text/javascript" id="sportspress-js-extra">
    /* <![CDATA[ */
    var localized_strings = {
      days: "days",
      hrs: "hrs",
      mins: "mins",
      secs: "secs",
      previous: "Previous",
      next: "Next",
    };
    //# sourceURL=sportspress-js-extra
    /* ]]> */
  </script>

</Layout>
<!-- wrapper -->
