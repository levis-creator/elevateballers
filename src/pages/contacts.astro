---
export const prerender = false;

// Edge cache — contact info rarely changes.
Astro.response.headers.set("Cache-Control", "public, s-maxage=600, stale-while-revalidate=1200");

import { usePublicV2 } from "@/lib/ui-version";

// v2-only route. Rewrite to the legacy page when the flag is off — URL stays /contacts.
if (!usePublicV2) return Astro.rewrite("/contacts-v1");

import LayoutV2 from "@/layouts/v2/Layout.astro";
import ContactPage from "@/features/contact/presentation/v2/ContactPage.astro";
---

<LayoutV2
	title="Contacts - Elevate Ballers | Get in Touch"
	description="Reach Elevate Ballers — call, email, or visit us in Nairobi. Contact the right desk for registration, transfers, fixtures, officiating and media, or send us a message."
	canonicalURL={`${Astro.url.origin}/contacts/`}
	type="website"
>
	<ContactPage />
</LayoutV2>
