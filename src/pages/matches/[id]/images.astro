---
import Layout from "../../../layouts/Layout.astro";
import TopBar from "../../../features/layout/components/TopBar.astro";
import Header from "../../../features/layout/components/Header";
import Footer from "../../../features/layout/components/Footer.astro";
import Spacing from "../../../shared/components/ui/Spacing.astro";
import { getMatchById } from "../../../features/cms/lib/queries";
import { MATCH_TIMEZONE } from "../../../features/matches/domain/usecases/utils";
import MatchImagesViewAllPublic from "../../../features/matches/components/MatchImagesViewAllPublic";
import type { Match } from "@prisma/client";
import PageLoader from "../../../components/PageLoader";
import ContentLoader from "../../../components/ContentLoader";

export const prerender = false;

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/matches");
}

let match: Match | null = null;
let hasError = false;
try {
  match = await getMatchById(id);
  if (!match) {
    return Astro.redirect("/matches");
  }
} catch (error) {
  console.error("Error fetching match:", error);
  hasError = true;
}

const team1Name = match?.team1Name || match?.team1?.name || "TBD";
const team2Name = match?.team2Name || match?.team2?.name || "TBD";
const matchDate = match?.date
  ? new Date(match.date).toLocaleDateString("en-US", {
      timeZone: MATCH_TIMEZONE,
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
const pageTitle = `${team1Name} vs ${team2Name} - Match Photos`;
const pageDescription = matchDate
  ? `Photo gallery for ${team1Name} vs ${team2Name} on ${matchDate}.`
  : `Photo gallery for ${team1Name} vs ${team2Name}.`;
const pageUrl = `${Astro.url.origin}/matches/${id}/images`;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={pageUrl}
  type="website"
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "ImageGallery",
          "@id": pageUrl,
          url: pageUrl,
          name: pageTitle,
          isPartOf: { "@id": `${Astro.url.origin}/#website` },
          description: pageDescription,
          breadcrumb: { "@id": `${pageUrl}#breadcrumb` },
          inLanguage: "en-US",
        },
        {
          "@type": "BreadcrumbList",
          "@id": `${pageUrl}#breadcrumb`,
          itemListElement: [
            {
              "@type": "ListItem",
              position: 1,
              name: "Home",
              item: `${Astro.url.origin}/`,
            },
            {
              "@type": "ListItem",
              position: 2,
              name: "Results",
              item: `${Astro.url.origin}/matches/results`,
            },
            {
              "@type": "ListItem",
              position: 3,
              name: `${team1Name} vs ${team2Name}`,
              item: `${Astro.url.origin}/matches/${id}`,
            },
            { "@type": "ListItem", position: 4, name: "Photos" },
          ],
        },
      ],
    })}
  />
  <PageLoader client:load />
  <div id="wrapper">
    <TopBar />
    <Header client:load currentPath={Astro.url.pathname} />
    <div id="main">
      <div
        class="stm-title-box-unit transparent-header_on title_box-357"
        style="padding-top: 0; padding-bottom: 0px;"
      >
      </div>
      <div class="container">
        <section class="wpb-content-wrapper">
          <div class="vc_row wpb_row vc_row-fluid">
            <div class="wpb_column vc_column_container vc_col-sm-12">
              <div class="vc_column-inner">
                <div class="wpb_wrapper">
                  <Spacing
                    id="stm-spacing-match-images-header"
                    lg="80"
                    md="70"
                    sm="60"
                    xs="50"
                  />

                  {
                    hasError ? (
                      <ContentLoader
                        client:load
                        message="Failed to load match. Please try again later."
                      />
                    ) : match ? (
                      <div style="max-width: 1200px; margin: 0 auto;">
                        <MatchImagesViewAllPublic matchId={id} client:load />
                      </div>
                    ) : null
                  }

                  <div style="text-align: center; margin-top: 2rem;">
                    <a
                      href={`/matches/${id}`}
                      class="btn btn-primary"
                      data-astro-prefetch
                    >
                      Back to Match
                    </a>
                    <a
                      href="/upcoming-fixtures"
                      class="btn btn-secondary"
                      data-astro-prefetch
                      style="margin-left: 1rem;"
                    >
                      View All Fixtures
                    </a>
                  </div>

                  <Spacing
                    id="stm-spacing-match-images-footer"
                    lg="50"
                    md="50"
                    sm="40"
                    xs="40"
                  />
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>

  <Footer />

</Layout>

<style is:inline type="text/css">
  .sp-footer-sponsors {
    background: #f4f4f4;
    color: #363f48;
  }
</style>
