---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import TopBar from "../../features/layout/components/TopBar.astro";
import Header from "../../features/layout/components/Header";
import Footer from "../../features/layout/components/Footer.astro";
import Spacing from "../../shared/components/ui/Spacing.astro";
import { getCompletedMatches, getUpcomingMatches } from "../../features/matches/lib/queries";
import MatchesTabbedTable from "../../features/matches/presentation/components/MatchesTabbedTable";
import PageLoader from "../../components/PageLoader";
import ContentLoader from "../../components/ContentLoader";
import { getDisplayImageUrl } from "../../lib/asset-url";

// Fetch match center data from database
let fixtures: any[] = [];
let results: any[] = [];
let hasError = false;
try {
  const [upcomingMatches, completedMatches] = await Promise.all([
    getUpcomingMatches(),
    getCompletedMatches(),
  ]);

  fixtures = upcomingMatches.map((m) => ({
    id: m.id,
    date: m.date,
    team1Name: m.team1Name || m.team1?.name || "TBD",
    team1Logo: getDisplayImageUrl(m.team1?.logo || m.team1Logo),
    team2Name: m.team2Name || m.team2?.name || "TBD",
    team2Logo: getDisplayImageUrl(m.team2?.logo || m.team2Logo),
    league: m.league?.name || m.leagueName || "Unknown League",
    venue: (m as any).venue || "Main Court",
    status: m.status,
  }));

  results = completedMatches.map((m) => ({
    id: m.id,
    date: m.date,
    team1Name: m.team1Name || m.team1?.name || "TBD",
    team1Logo: getDisplayImageUrl(m.team1?.logo || m.team1Logo),
    team2Name: m.team2Name || m.team2?.name || "TBD",
    team2Logo: getDisplayImageUrl(m.team2?.logo || m.team2Logo),
    team1Score: m.team1Score ?? "-",
    team2Score: m.team2Score ?? "-",
    league: m.league?.name || m.leagueName || "Unknown League",
    winnerName:
      m.winner?.name ||
      (m.winnerId === m.team1Id
        ? m.team1Name
        : m.winnerId === m.team2Id
          ? m.team2Name
          : undefined),
    status: m.status,
  }));
} catch (error) {
  console.error("Error fetching match results:", error);
  hasError = true;
}

const pageTitle = "Match Results - Elevate Ballers";
const pageDescription =
  "View the latest completed match results from the Elevate Ballers league.";
const pageUrl = `${Astro.url.origin}/matches/results`;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={pageUrl}
  type="website"
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": ["WebPage", "CollectionPage"],
          "@id": pageUrl,
          url: pageUrl,
          name: pageTitle,
          isPartOf: { "@id": `${Astro.url.origin}/#website` },
          description: pageDescription,
          breadcrumb: { "@id": `${pageUrl}#breadcrumb` },
          inLanguage: "en-US",
        },
        {
          "@type": "BreadcrumbList",
          "@id": `${pageUrl}#breadcrumb`,
          itemListElement: [
            {
              "@type": "ListItem",
              position: 1,
              name: "Home",
              item: `${Astro.url.origin}/`,
            },
            { "@type": "ListItem", position: 2, name: "Match Results" },
          ],
        },
      ],
    })}
  />
  <PageLoader client:load />
  <div id="wrapper" class="match-center-page-shell">
    <TopBar />
    <Header client:load currentPath={Astro.url.pathname} />
    <div id="main">
      <div
        class="stm-title-box-unit transparent-header_on title_box-357"
        style="padding-top: 0; padding-bottom: 0px;"
      >
      </div>
      <div class="container">
        <section class="wpb-content-wrapper">
          <div class="vc_row wpb_row vc_row-fluid">
            <div class="wpb_column vc_column_container vc_col-sm-12">
              <div class="vc_column-inner">
                <div class="wpb_wrapper">
                  <Spacing
                    id="stm-spacing-results-header"
                    lg="80"
                    md="70"
                    sm="60"
                    xs="50"
                  />

                  {
                    hasError ? (
                      <ContentLoader
                        client:load
                        message="Failed to load the match center. Please try again later."
                      />
                    ) : (
                      <div class="sp-template sp-template-event-list">
                        <MatchesTabbedTable
                          fixtures={fixtures}
                          results={results}
                          initialTab="results"
                          client:load
                        />
                      </div>
                    )
                  }

                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
    <Footer />
  </div>
</Layout>

<style is:inline type="text/css">
  html:has(#wrapper.match-center-page-shell),
  body:has(#wrapper.match-center-page-shell) {
    background:
      radial-gradient(circle at top center, rgba(255, 186, 0, 0.08), transparent 30%),
      linear-gradient(180deg, #0f0d18 0%, #14111f 100%) !important;
  }

  /* Dark section background to complement the dark match cards */
  #main {
    background:
      radial-gradient(circle at top center, rgba(255, 186, 0, 0.08), transparent 30%),
      linear-gradient(180deg, #0f0d18 0%, #14111f 100%);
  }

  .match-center-page-shell {
    background:
      radial-gradient(circle at top center, rgba(255, 186, 0, 0.08), transparent 30%),
      linear-gradient(180deg, #0f0d18 0%, #14111f 100%) !important;
    min-height: 100vh;
  }

  .sp-template-event-list {
    margin-top: 20px;
    margin-bottom: 20px;
  }
</style>
