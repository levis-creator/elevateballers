---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import TopBar from "../../features/layout/components/TopBar.astro";
import Header from "../../features/layout/components/Header";
import Footer from "../../features/layout/components/Footer.astro";
import Spacing from "../../shared/components/ui/Spacing.astro";
import { getCompletedMatches } from "../../features/matches/lib/queries";
import { ResultsTable } from "../../features/matches/components/ResultsTable";
import PageLoader from "../../components/PageLoader";
import ContentLoader from "../../components/ContentLoader";

// Fetch completed matches from database
let matches: any[] = [];
let hasError = false;
try {
  const dbMatches = await getCompletedMatches();
  // Map database response to Result interface
  matches = dbMatches.map((m) => ({
    id: m.id,
    date: m.date,
    team1Name: m.team1Name || m.team1?.name || "TBD",
    team2Name: m.team2Name || m.team2?.name || "TBD",
    team1Score: m.team1Score ?? "-",
    team2Score: m.team2Score ?? "-",
    league: m.league?.name || m.leagueName || "Unknown League",
    winnerName:
      m.winner?.name ||
      (m.winnerId === m.team1Id
        ? m.team1Name
        : m.winnerId === m.team2Id
          ? m.team2Name
          : undefined),
    status: m.status,
  }));
} catch (error) {
  console.error("Error fetching match results:", error);
  hasError = true;
}
---

<Layout>
  <PageLoader client:load />
  <div id="wrapper">
    <TopBar />
    <Header client:load currentPath={Astro.url.pathname} />
    <div id="main">
      <div
        class="stm-title-box-unit transparent-header_on title_box-357"
        style="padding-top: 0; padding-bottom: 0px;"
      >
      </div>
      <div class="container">
        <section class="wpb-content-wrapper">
          <div class="vc_row wpb_row vc_row-fluid">
            <div class="wpb_column vc_column_container vc_col-sm-12">
              <div class="vc_column-inner">
                <div class="wpb_wrapper">
                  <Spacing
                    id="stm-spacing-results-header"
                    lg="50"
                    md="50"
                    sm="40"
                    xs="40"
                  />

                  <h2
                    class="heading-font"
                    style="text-align: center; margin-bottom: 20px; color: #dd3333;"
                  >
                    MATCH RESULTS
                  </h2>

                  <div
                    class="view-toggle"
                    style="text-align: center; margin-bottom: 40px;"
                  >
                    <a href="/upcoming-fixtures" class="toggle-btn"
                      >VIEW UPCOMING FIXTURES</a
                    >
                  </div>

                  {
                    hasError ? (
                      <ContentLoader
                        client:load
                        message="Failed to load results. Please try again later."
                      />
                    ) : (
                      <div class="sp-template sp-template-event-list">
                        <ResultsTable matches={matches} client:load />
                      </div>
                    )
                  }

                  <Spacing
                    id="stm-spacing-results-footer"
                    lg="50"
                    md="50"
                    sm="40"
                    xs="40"
                  />
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
    <Footer />
  </div>
</Layout>

<style is:inline type="text/css">
  .heading-font {
    font-size: 40px;
    line-height: 44px;
    margin-bottom: 20px;
    color: #dd3333 !important;
  }

  .view-toggle .toggle-btn {
    display: inline-block;
    padding: 10px 20px;
    background-color: #333;
    color: #fff;
    text-decoration: none;
    font-size: 14px;
    font-weight: bold;
    border-radius: 4px;
    transition: background-color 0.3s;
  }

  .view-toggle .toggle-btn:hover {
    background-color: #dd3333;
  }

  .sp-template-event-list {
    margin-top: 20px;
    margin-bottom: 20px;
  }

  .sp-template-event-list table.sp-event-list.sp-data-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0 5px;
  }

  .sp-template-event-list table.sp-event-list.sp-data-table thead {
    background-color: #e21e22;
    color: #fff;
  }

  .sp-template-event-list table.sp-event-list.sp-data-table thead th {
    background-color: #e21e22;
    color: #fff;
    padding: 13px 7px;
    text-align: center;
    text-transform: uppercase;
    font-weight: normal;
  }

  .sp-template-event-list table.sp-event-list.sp-data-table tbody tr td {
    background-color: #fff;
    padding: 15px 7px;
    text-align: center;
    vertical-align: middle;
    border-bottom: 1px solid #eee;
  }

  .sp-template-event-list
    table.sp-event-list.sp-data-table
    tbody
    tr:nth-child(odd)
    td {
    background-color: #f9f9f9;
  }

  .data-score div {
    display: inline-block;
    min-width: 80px;
  }

  .data-winner {
    font-style: italic;
  }
</style>
