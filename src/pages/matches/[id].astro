---
export const prerender = false;

import { usePublicV2 } from "@/lib/ui-version";

// `id` is the route param name; the value is either the public slug or the cuid.
const { id: slugOrId } = Astro.params;
if (!slugOrId) return Astro.rewrite("/404");

// v2-only route (imports only the v2 tree). Rewrite to the legacy page when the
// flag is off — URL stays /matches/<slug|id>.
if (!usePublicV2) return Astro.rewrite(`/matches-v1/${slugOrId}`);

import LayoutV2 from "@/layouts/v2/Layout.astro";
import MatchDetailPage from "@/features/matches/presentation/v2/MatchDetailPage.astro";
import { getMatchView } from "@/features/matches/domain/usecases/get-match-view";

const view = await getMatchView(slugOrId);
if (!view) return Astro.rewrite("/404");

// Consolidate SEO on the canonical slug URL when reached via the legacy cuid.
if (view.slug && slugOrId !== view.slug) return Astro.redirect(`/matches/${view.slug}/`, 301);

// Edge cache: short while live/upcoming (data changes), long once completed.
const cacheControl =
	view.state === "final"
		? "public, s-maxage=86400, stale-while-revalidate=604800"
		: view.state === "live"
			? "public, s-maxage=15, stale-while-revalidate=60"
			: "public, s-maxage=60, stale-while-revalidate=300";
Astro.response.headers.set("Cache-Control", cacheControl);

const matchup = `${view.home.name} vs ${view.away.name}`;
const title =
	view.state === "final" && view.home.score != null
		? `${view.home.name} ${view.home.score}-${view.away.score} ${view.away.name} | Final | ${view.league}`
		: view.state === "live"
			? `LIVE: ${matchup} | ${view.league}`
			: `${matchup} | ${view.dateText} | ${view.league}`;
const description =
	view.state === "final"
		? `Full box score, top performers and play-by-play for ${matchup} in the ${view.league}.`
		: view.state === "live"
			? `Follow ${matchup} live — real-time score, box score and play-by-play in the ${view.league}.`
			: `${matchup} — recent form, head-to-head and players to watch ahead of tip-off in the ${view.league}.`;
const canonical = `${Astro.url.origin}/matches/${view.slug || view.id}/`;
---

<LayoutV2 title={title} description={description} canonicalURL={canonical} type="website">
	<MatchDetailPage view={view} />
</LayoutV2>
