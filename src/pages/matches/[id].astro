---
import Layout from "../../layouts/Layout.astro";
import TopBar from "../../features/layout/components/TopBar.astro";
import Header from "../../features/layout/components/Header";
import Footer from "../../features/layout/components/Footer.astro";
import Spacing from "../../shared/components/ui/Spacing.astro";
import { getMatchWithFullDetails } from "../../features/cms/lib/queries";
import MatchDetail from "../../features/matches/components/MatchDetail";
import type { MatchWithFullDetails } from "../../features/cms/types";
import PageLoader from "../../components/PageLoader";
import ContentLoader from "../../components/ContentLoader";

export const prerender = false;

interface Props {
  id: string;
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/matches");
}

// Fetch match from database
let match: MatchWithFullDetails | null = null;
let hasError = false;
try {
  match = await getMatchWithFullDetails(id);
  if (!match) {
    return Astro.redirect("/matches");
  }
} catch (error) {
  console.error("Error fetching match:", error);
  hasError = true;
}

const team1Name = match?.team1Name || match?.team1?.name || "TBD";
const team2Name = match?.team2Name || match?.team2?.name || "TBD";
const matchLeague = match?.league?.name || match?.leagueName || "Elevate Ballers";
const matchDate = match?.date
  ? new Date(match.date).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
const pageTitle = `${team1Name} vs ${team2Name} - ${matchLeague}`;
const pageDescription = matchDate
  ? `Match details for ${team1Name} vs ${team2Name} on ${matchDate}.`
  : `Match details for ${team1Name} vs ${team2Name}.`;
const pageUrl = `${Astro.url.origin}/matches/${id}`;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={pageUrl}
  type="website"
>
  <PageLoader client:load />
  <div id="wrapper">
    <TopBar />
    <Header client:load currentPath={Astro.url.pathname} />
    <div id="main">
      <div
        class="stm-title-box-unit transparent-header_on title_box-357"
        style="padding-top: 0; padding-bottom: 0px;"
      >
      </div>
      <div class="container">
        <section class="wpb-content-wrapper">
          <div class="vc_row wpb_row vc_row-fluid">
            <div class="wpb_column vc_column_container vc_col-sm-12">
              <div class="vc_column-inner">
                <div class="wpb_wrapper">
                  <Spacing
                    id="stm-spacing-match-header"
                    lg="80"
                    md="70"
                    sm="60"
                    xs="50"
                  />

                  {
                    hasError ? (
                      <ContentLoader
                        client:load
                        message="Failed to load match details. Please try again later."
                      />
                    ) : match ? (
                      <div style="max-width: 800px; margin: 0 auto;">
                        <MatchDetail client:load match={match} />
                      </div>
                    ) : null
                  }

                  <div style="text-align: center; margin-top: 2rem;">
                    <a
                      href="/upcoming-fixtures"
                      class="btn btn-primary"
                      data-astro-prefetch
                    >
                      View All Fixtures
                    </a>
                    <a
                      href="/matches/results"
                      class="btn btn-secondary"
                      data-astro-prefetch
                      style="margin-left: 1rem;"
                    >
                      View Results
                    </a>
                  </div>

                  <Spacing
                    id="stm-spacing-match-footer"
                    lg="50"
                    md="50"
                    sm="40"
                    xs="40"
                  />
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>

  <Footer />

</Layout>

<style is:inline type="text/css">
  .sp-footer-sponsors {
    background: #f4f4f4;
    color: #363f48;
  }
  .sp-footer-sponsors .sp-sponsors .sp-sponsors-title {
    color: #363f48;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
  }

  .btn-primary {
    background-color: #dd3333;
    color: white;
  }

  .btn-primary:hover {
    background-color: #c02929;
  }

  .btn-secondary {
    background-color: #64748b;
    color: white;
  }

  .btn-secondary:hover {
    background-color: #475569;
  }
</style>
