---
export const prerender = false;

import AdminLayout from '../../../features/cms/components/AdminLayout.astro';
import RoleList from '../../../features/cms/components/RoleList';
import { requirePermissionPage } from '../../../features/rbac/auth-helpers';

const user = await requirePermissionPage(Astro.request, 'roles:read');

if (!user) {
  return Astro.redirect('/admin/login');
}
---

<AdminLayout title="Roles - Admin">
  <RoleList client:load />
</AdminLayout>
