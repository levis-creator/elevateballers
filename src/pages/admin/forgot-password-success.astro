---
export const prerender = false;
export const ssr = false;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Check Your Email - Elevate Ballers</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Rubik:regular,bold|Teko:regular,700,300,400,500,600">
  <link rel="icon" href="/images/Elevate_Icon-32x32.png" sizes="32x32">

  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }

    body {
      font-family: 'Rubik', sans-serif;
      background-color: #030712; /* gray-950 */
      color: #f3f4f6;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 3rem 1rem;
    }

    .wrapper {
      width: 100%;
      max-width: 28rem; /* matches max-w-md */
    }

    .brand {
      text-align: center;
      margin-bottom: 2rem;
    }

    .brand-logo {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 4rem;
      height: 4rem;
      border-radius: 1rem;
      background: #dc2626; /* red-600 */
      box-shadow: 0 10px 25px -5px rgba(220, 38, 38, 0.3);
      margin-bottom: 1.25rem;
    }

    .brand-logo img {
      width: 2.5rem;
      height: 2.5rem;
      object-fit: contain;
    }

    .brand-title {
      font-family: 'Teko', sans-serif;
      font-size: 2.25rem;
      font-weight: 700;
      color: #ffffff;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin: 0;
      line-height: 1;
    }

    .card {
      background: #111827; /* gray-900 */
      border: 1px solid #1f2937; /* gray-800 */
      border-radius: 1rem;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
      padding: 2rem;
      text-align: center;
    }

    .icon-circle {
      width: 3.5rem;
      height: 3.5rem;
      border-radius: 9999px;
      background: rgba(220, 38, 38, 0.1);
      border: 1px solid rgba(220, 38, 38, 0.3);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: #f87171; /* red-400 */
      margin: 0 auto 1rem;
    }

    .card h2 {
      font-family: 'Teko', sans-serif;
      color: #ffffff;
      font-size: 1.875rem;
      letter-spacing: 0.05em;
      margin: 0 0 0.75rem;
      text-transform: uppercase;
    }

    .card p {
      color: #9ca3af; /* gray-400 */
      font-size: 0.875rem;
      line-height: 1.5;
      margin: 0 0 0.5rem;
    }

    .card p.muted {
      color: #6b7280; /* gray-500 */
      font-size: 0.8125rem;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      width: 100%;
      padding: 0.75rem 1rem;
      margin-top: 1.5rem;
      background: #dc2626;
      color: #ffffff;
      text-decoration: none;
      border-radius: 0.75rem;
      font-weight: 600;
      font-size: 0.875rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      box-shadow: 0 10px 15px -3px rgba(220, 38, 38, 0.2);
      transition: background-color 0.15s ease;
    }

    .btn-primary:hover {
      background: #b91c1c; /* red-700 */
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="brand">
      <div class="brand-logo">
        <img src="/images/Elevate_Icon-200x200.png" alt="Elevate Ballers" />
      </div>
      <h1 class="brand-title">Elevate Ballers</h1>
    </div>

    <div class="card">
      <div class="icon-circle" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </div>
      <h2>Check Your Email</h2>
      <p>If an account exists, we sent a reset link to your inbox.</p>
      <p class="muted">Be sure to check your spam or junk folder.</p>
      <a class="btn-primary" href="/admin/login">Back to Login</a>
    </div>
  </div>
</body>
</html>
