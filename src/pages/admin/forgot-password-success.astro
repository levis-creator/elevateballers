---
export const prerender = false;

import { usePublicAdminV2 } from '@/lib/admin-ui-version';
import ForgotPasswordSuccessPage from '../../features/auth/presentation/v2/ForgotPasswordSuccessPage.astro';

// Admin redesign is flag-gated SEPARATELY from the public site
// (PUBLIC_ADMIN_UI_VERSION). When off, serve the legacy confirmation at the same
// URL — separate route keeps each UI's CSS isolated (see ui-version notes).
if (!usePublicAdminV2) return Astro.rewrite('/admin/forgot-password-success-v1');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Check Your Email - Elevate Ballers</title>
  <link rel="icon" href="/images/Elevate_Icon-32x32.png" sizes="32x32">
</head>
<body>
  <ForgotPasswordSuccessPage />
</body>
</html>
