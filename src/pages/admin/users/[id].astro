---
export const prerender = false;
export const ssr = false;

import AdminLayout from "../../../features/cms/components/AdminLayout.astro";
import UserEditor from "../../../features/cms/components/UserEditor";

const { id } = Astro.params;
---

<AdminLayout
    title="Edit User - Admin"
    permissionsAll={['users:update', 'users:manage_roles', 'roles:read']}
>
    <UserEditor userId={id} client:load />
</AdminLayout>
