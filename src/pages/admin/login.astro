---
export const prerender = false;

import AdminLoginPage from '../../features/auth/presentation/v2/AdminLoginPage.astro';
import { checkAuth } from '../../features/cms/lib/auth-astro';

try {
  const user = await checkAuth(Astro.request);
  if (user) {
    return Astro.redirect('/admin', 302);
  }
} catch (error) {
  console.error('Auth check error in login page (non-fatal):', error);
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Admin Login - Elevate Ballers CMS</title>
  <link rel="icon" href="/images/Elevate_Icon-32x32.png" sizes="32x32">
</head>
<body>
  <AdminLoginPage />
</body>
</html>
