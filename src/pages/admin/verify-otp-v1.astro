---
export const prerender = false;
export const ssr = false;

// v1 (legacy) admin OTP on its OWN route. `/admin/verify-otp` internally
// rewrites here (URL stays /admin/verify-otp) when PUBLIC_ADMIN_UI_VERSION !==
// 'v2'. Separate route keeps the legacy admin CSS/fonts off the v2 OTP page.
// Guarded: when the v2 admin UI is live this must not serve a second copy.
import { usePublicAdminV2 } from '@/lib/admin-ui-version';
if (usePublicAdminV2) return Astro.rewrite('/404');

import OtpForm from '../../features/cms/presentation/components/OtpForm';
import { checkAuth } from '../../features/cms/lib/auth-astro';

try {
  const user = await checkAuth(Astro.request);
  if (user) {
    return Astro.redirect('/admin', 302);
  }
} catch (error) {
  console.error('Auth check error in verify-otp page (non-fatal):', error);
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Verify Login - Elevate Ballers CMS</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Rubik:regular,bold|Teko:regular,700,300,400,500,600">
  <link rel="icon" href="/images/Elevate_Icon-32x32.png" sizes="32x32">
</head>
<body>
  <OtpForm client:load />
</body>
</html>
