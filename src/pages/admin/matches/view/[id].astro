---
export const prerender = false;
export const ssr = false;

import AdminLayout from '../../../../features/cms/components/AdminLayout.astro';
import MatchDetailView from '../../../../features/cms/components/MatchDetailView';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/matches', 302);
}
---

<AdminLayout title="Match Details - Admin" permission="matches:read">
  <MatchDetailView matchId={id} client:load />
</AdminLayout>

