---
export const prerender = false;
export const ssr = false;

export async function getStaticPaths() {
  return [];
}

import AdminLayout from '@/features/admin-layout/presentation/components/AdminLayout.astro';
import MatchDetailView from '../../../../features/matches/presentation/components/MatchDetailView';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/matches', 302);
}
---

<AdminLayout title="Match Details - Admin" permission="matches:read">
  <MatchDetailView matchId={id} client:load />
</AdminLayout>

