---
export const prerender = false;
export const ssr = false;

import AdminLayout from '../../../features/cms/components/AdminLayout.astro';
import MatchList from '../../../features/cms/components/MatchList';
import { requirePermissionPage } from '../../../features/rbac/auth-helpers';

const user = await requirePermissionPage(Astro.request, 'matches:read');
if (!user) {
  return Astro.redirect('/admin/login', 302);
}
---

<AdminLayout title="Matches Management - Admin">
  <MatchList client:load />
</AdminLayout>

