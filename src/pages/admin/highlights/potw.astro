---
export const prerender = false;
export const ssr = false;

import AdminLayout from "../../../features/cms/components/AdminLayout.astro";
import POTWManager from "../../../features/cms/components/POTWManager";
import { requirePermissionPage } from "../../../features/rbac/auth-helpers";

const user = await requirePermissionPage(Astro.request, 'highlights:read');
if (!user) {
    return Astro.redirect("/admin/login", 302);
}
---

<AdminLayout title="Player of the Week - Admin">
    <POTWManager client:load />
</AdminLayout>
