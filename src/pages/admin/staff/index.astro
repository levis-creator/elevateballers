---
export const prerender = false;
export const ssr = false;

import AdminLayout from '../../../features/cms/components/AdminLayout.astro';
import StaffList from '../../../features/cms/components/StaffList';
import { requirePermissionPage } from '../../../features/rbac/auth-helpers';

const user = await requirePermissionPage(Astro.request, 'staff:read');
if (!user) {
  return Astro.redirect('/admin/login', 302);
}
---

<AdminLayout title="Staff Management - Admin">
  <StaffList client:load />
</AdminLayout>

