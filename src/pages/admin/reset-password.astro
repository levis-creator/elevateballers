---
export const prerender = false;

import { usePublicAdminV2 } from '@/lib/admin-ui-version';
import ResetPasswordPage from '../../features/auth/presentation/v2/ResetPasswordPage.astro';
import { checkAuth } from '../../features/cms/lib/auth-astro';

// Admin redesign is flag-gated SEPARATELY from the public site
// (PUBLIC_ADMIN_UI_VERSION). When off, serve the legacy reset page at the same
// URL — separate route keeps each UI's CSS isolated (see ui-version notes).
if (!usePublicAdminV2) return Astro.rewrite('/admin/reset-password-v1');

try {
  const user = await checkAuth(Astro.request);
  if (user) {
    return Astro.redirect('/admin', 302);
  }
} catch (error) {
  console.error('Auth check error in reset-password page (non-fatal):', error);
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Reset Password - Elevate Ballers CMS</title>
  <link rel="icon" href="/images/Elevate_Icon-32x32.png" sizes="32x32">
</head>
<body>
  <ResetPasswordPage />
</body>
</html>
