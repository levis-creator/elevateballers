---
export const prerender = false;

import AdminLayout from '../../features/cms/components/AdminLayout.astro';
---

<AdminLayout title="API Documentation" permission="audit_logs:read">
  <div class="api-docs-wrapper">
    <div id="swagger-ui"></div>
  </div>

  <!-- Swagger UI via CDN — no npm dep required -->
  <link
    rel="stylesheet"
    href="https://unpkg.com/swagger-ui-dist@5/swagger-ui.css"
  />
  <script src="https://unpkg.com/swagger-ui-dist@5/swagger-ui-bundle.js" is:inline></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', function () {
      SwaggerUIBundle({
        url: '/api/openapi.yaml',
        dom_id: '#swagger-ui',
        presets: [SwaggerUIBundle.presets.apis, SwaggerUIBundle.SwaggerUIStandalonePreset],
        layout: 'BaseLayout',
        deepLinking: true,
        displayRequestDuration: true,
        filter: true,
        persistAuthorization: true,
        tryItOutEnabled: true,
      });
    });
  </script>
</AdminLayout>

<style>
  .api-docs-wrapper {
    padding: 0;
    background: #fff;
    min-height: 100vh;
  }

  /* Override Swagger UI top bar to match admin theme */
  .swagger-ui .topbar {
    display: none;
  }
</style>
