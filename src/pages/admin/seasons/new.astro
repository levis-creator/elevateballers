---
export const prerender = false;
import { checkAuth } from '@/features/auth/lib/auth-astro';
import { hasPermission } from '../../../features/rbac/data/datasources/permissions';

const user = await checkAuth(Astro.request);
if (!user) {
  return Astro.redirect('/admin/login', 302);
}

const allowed = await hasPermission(user.id, 'seasons:create');
if (!allowed) {
  return Astro.redirect('/unauthorized', 302);
}

// Redirect to leagues page (seasons are managed from leagues)
return Astro.redirect('/admin/leagues', 302);
---

