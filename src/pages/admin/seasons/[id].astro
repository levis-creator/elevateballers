---
export const prerender = false;
export const ssr = false;

import AdminLayout from '../../../features/cms/components/AdminLayout.astro';
import SeasonEditor from '../../../features/cms/components/SeasonEditor';
import SeasonFormPage from '../../../features/seasons/presentation/v2/SeasonFormPage';
import { usePublicAdminV2 } from '@/lib/admin-ui-version';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/seasons', 302);
}
---

<AdminLayout title="Edit Season - Admin" permission="seasons:update">
  {usePublicAdminV2 ? <SeasonFormPage seasonId={id} client:load /> : <SeasonEditor seasonId={id} client:load />}
</AdminLayout>
