---
export const prerender = false;
import { checkAuth } from '../../../features/cms/lib/auth-astro';
import { hasPermission } from '../../../features/rbac/permissions';
import { getSeasonById } from '../../../features/cms/lib/queries';

const user = await checkAuth(Astro.request);
if (!user) {
  return Astro.redirect('/admin/login', 302);
}

const allowed = await hasPermission(user.id, 'seasons:read');
if (!allowed) {
  return Astro.redirect('/unauthorized', 302);
}

const { id } = Astro.params;

// Redirect a season to one of its leagues (seasons are many-to-many now).
let redirectUrl = '/admin/leagues';
if (id) {
  const season = await getSeasonById(id);
  const leagueId = season?.leagueSeasons?.[0]?.leagueId;
  if (leagueId) {
    redirectUrl = `/admin/leagues/${leagueId}`;
  }
}

return Astro.redirect(redirectUrl, 302);
---

