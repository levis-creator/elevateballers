---
export const prerender = false;
export const ssr = false;

import AdminLayout from '../../../features/cms/components/AdminLayout.astro';
import SeasonEditor from '../../../features/cms/components/SeasonEditor';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/seasons', 302);
}
---

<AdminLayout title="Edit Season - Admin" permission="seasons:update">
  <SeasonEditor seasonId={id} client:load />
</AdminLayout>
