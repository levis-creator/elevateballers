---
export const prerender = false;
export const ssr = false;

import AdminLayout from '../../../../features/cms/components/AdminLayout.astro';
import SeasonMatchesList from '../../../../features/cms/components/SeasonMatchesList';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/leagues', 302);
}
---

<AdminLayout title="Season Matches - Admin" permission="matches:read">
  <SeasonMatchesList seasonId={id} client:load />
</AdminLayout>
