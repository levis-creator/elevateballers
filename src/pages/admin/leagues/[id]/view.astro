---
export const prerender = false;
export const ssr = false;

import AdminLayout from '@/features/admin-layout/presentation/components/AdminLayout.astro';
import LeagueEditor from '../../../../features/leagues/components/LeagueEditor';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/leagues', 302);
}
---

<AdminLayout title="View League - Admin" permission="leagues:read">
  <LeagueEditor leagueId={id} mode="view" client:load />
</AdminLayout>
