---
export const prerender = false;
export const ssr = false;

import AdminLayout from '../../../../features/cms/components/AdminLayout.astro';
import LeagueEditor from '../../../../features/cms/components/LeagueEditor';
import LeagueDetailPage from '../../../../features/leagues/presentation/v2/LeagueDetailPage';
import { usePublicAdminV2 } from '@/lib/admin-ui-version';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/leagues', 302);
}
---

<AdminLayout title="League Details - Admin" permission="leagues:read">
  {usePublicAdminV2
    ? <LeagueDetailPage leagueId={id} client:load />
    : <LeagueEditor leagueId={id} mode="view" client:load />}
</AdminLayout>
