---
export const prerender = false;
export const ssr = false;

import AdminLayout from '../../../features/cms/components/AdminLayout.astro';
import LeagueEditor from '../../../features/cms/components/LeagueEditor';
import LeagueEditorPage from '../../../features/leagues/presentation/v2/LeagueEditorPage';
import { usePublicAdminV2 } from '@/lib/admin-ui-version';

const { id } = Astro.params;
---

<AdminLayout title="Edit League - Admin" permission="leagues:update">
  {usePublicAdminV2
    ? <LeagueEditorPage leagueId={id} client:load />
    : <LeagueEditor leagueId={id} client:load />}
</AdminLayout>

