---
import AdminLayout from '../../../features/cms/components/AdminLayout.astro';
import BannerSettingsEditorWithPermissions from '../../../features/cms/components/BannerSettingsEditorWithPermissions';
import AboutPageEditorWithPermissions from '../../../features/cms/components/AboutPageEditorWithPermissions';
---

<AdminLayout 
  title="Settings - Elevate Ballers CMS"
  permissionsAny={['site_settings:manage', 'site_settings:read']}
>
  <div class="mb-8">
    <h1 class="text-4xl font-bold font-heading text-gray-900 flex items-center gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
      Site Settings
    </h1>
    <p class="text-gray-500 mt-2 text-lg">Manage configuration and appearance settings for the site.</p>
  </div>

  <div class="space-y-8">
    <BannerSettingsEditorWithPermissions client:load />
    <AboutPageEditorWithPermissions client:load />
  </div>
</AdminLayout>
