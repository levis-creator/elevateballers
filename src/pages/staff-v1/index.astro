---
// Legacy (v1) league-staff directory. `/staff` rewrites here when
// PUBLIC_UI_VERSION !== 'v2'. Guard so it isn't served directly under v2.
import { usePublicV2 } from "@/lib/ui-version";
if (usePublicV2) return Astro.rewrite("/404");

export const prerender = false;

// Edge cache staff directory — changes rarely
Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=300, stale-while-revalidate=600'
);

import Layout from "../../layouts/Layout.astro";
import TopBar from "../../features/layout/components/TopBar.astro";
import Header from "../../features/layout/components/Header";
import Footer from "../../features/layout/components/Footer.astro";
import PageLoader from "../../components/PageLoader";
import Spacing from "../../shared/components/ui/Spacing.astro";
import { getLeagueStaff } from "../../features/cms/lib/queries";
import PersonCard from "../../features/staff/presentation/components/PersonCard.astro";

let staff: any[] = [];
try {
  staff = await getLeagueStaff();
} catch (error) {
  console.error("Error fetching league staff:", error);
}

const groupedStaff = staff.reduce((groups: Record<string, any[]>, member) => {
  const department = member.department || "Operations";
  groups[department] = groups[department] || [];
  groups[department].push(member);
  return groups;
}, {});
const departments = Object.keys(groupedStaff).sort((a, b) => a.localeCompare(b));

const pageTitle = "League Staff - Elevate Ballers";
const pageDescription =
  "Meet the league staff powering Elevate Ballers operations, officiating, statistics, media and events.";
const pageUrl = `${Astro.url.origin}/staff/`;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={pageUrl}
  type="website"
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": ["WebPage", "CollectionPage"],
          "@id": pageUrl,
          url: pageUrl,
          name: pageTitle,
          isPartOf: { "@id": `${Astro.url.origin}/#website` },
          description: pageDescription,
          breadcrumb: { "@id": `${pageUrl}#breadcrumb` },
          inLanguage: "en-US",
        },
        {
          "@type": "BreadcrumbList",
          "@id": `${pageUrl}#breadcrumb`,
          itemListElement: [
            {
              "@type": "ListItem",
              position: 1,
              name: "Home",
              item: `${Astro.url.origin}/`,
            },
            { "@type": "ListItem", position: 2, name: "League Staff" },
          ],
        },
      ],
    })}
  />
  <PageLoader client:load />
  <div id="wrapper">
    <TopBar />
    <Header client:load currentPath={Astro.url.pathname} />
    <div id="main">
      <div
        class="stm-title-box-unit transparent-header_on title_box-357"
        style="padding-top: 0; padding-bottom: 0px;"
      ></div>
      <div class="container">
        <section class="wpb-content-wrapper">
          <div class="vc_row wpb_row vc_row-fluid">
            <div class="wpb_column vc_column_container vc_col-sm-12">
              <div class="vc_column-inner">
                <div class="wpb_wrapper">
                  <Spacing
                    id="stm-spacing-staff-header"
                    lg="80"
                    md="70"
                    sm="60"
                    xs="50"
                  />

                  <h1 class="heading-font" style="text-align: center; margin-bottom: 16px; color: #dd3333;">
                    LEAGUE STAFF
                  </h1>
                  <p class="league-staff-intro">
                    Organisation-wide staff are listed here. Team coaches and managers are shown on their team pages.
                  </p>

                  {departments.length > 0 ? (
                    <div class="league-staff-groups">
                      {departments.map((department) => (
                        <section class="league-staff-group">
                          <h2>{department}</h2>
                          <div class="league-staff-grid">
                            {groupedStaff[department].map((member: any) => (
                              <PersonCard
                                name={member.name}
                                role={member.role}
                                photo={member.photo}
                                email={member.email}
                              />
                            ))}
                          </div>
                        </section>
                      ))}
                    </div>
                  ) : (
                    <p class="no-data" style="text-align: center;">
                      League staff profiles are being prepared.
                    </p>
                  )}
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
    <Footer />
  </div>
</Layout>

<style>
  .league-staff-intro {
    max-width: 620px;
    margin: 0 auto 44px;
    text-align: center;
    color: #6f665c;
    font-size: 15px;
    line-height: 1.6;
  }

  .league-staff-groups {
    display: grid;
    gap: 42px;
  }

  .league-staff-group h2 {
    margin: 0 0 18px;
    color: #141009;
    font-family: Teko, sans-serif;
    font-size: 30px;
    font-weight: 700;
    text-transform: uppercase;
  }

  .league-staff-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  @media (max-width: 960px) {
    .league-staff-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 600px) {
    .league-staff-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
