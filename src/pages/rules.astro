---
export const prerender = false;

// Edge cache — rules rarely change.
Astro.response.headers.set("Cache-Control", "public, s-maxage=600, stale-while-revalidate=1200");

import { usePublicV2 } from "@/lib/ui-version";

// v2-only route. Rewrite to the legacy page when the flag is off — URL stays /rules.
if (!usePublicV2) return Astro.rewrite("/rules-v1");

import LayoutV2 from "@/layouts/v2/Layout.astro";
import RulesPage from "@/features/rules/presentation/v2/RulesPage.astro";
---

<LayoutV2
	title="League Rules & Regulations - Elevate Ballers"
	description="The official Elevate Ballers League rules and regulations — registration, teams and equipment, game procedures, conduct, officials, protests, and classification. Based on FIBA 2024."
	canonicalURL={`${Astro.url.origin}/rules/`}
	type="website"
>
	<RulesPage />
</LayoutV2>
