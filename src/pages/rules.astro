---
import Layout from "../layouts/Layout.astro";
import TopBar from "../features/layout/components/TopBar.astro";
import Header from "../features/layout/components/Header";
import Footer from "../features/layout/components/Footer.astro";
import PageLoader from "../components/PageLoader";
import { getAllSiteSettings } from "../features/cms/lib/queries";

const DEFAULT_RULES_SETTINGS = {
  title: 'League Rules & Regulations',
  intro:
    'Read the official Elevate Ballers rules and regulations. You can view the document online or download the latest PDF.',
  pdfUrl: '/documents/elevate-ballers-league-rules-2026.pdf',
  downloadLabel: 'Download Rules PDF',
};

let rulesTitle = DEFAULT_RULES_SETTINGS.title;
let rulesIntro = DEFAULT_RULES_SETTINGS.intro;
let rulesPdfUrl = DEFAULT_RULES_SETTINGS.pdfUrl;
let rulesDownloadLabel = DEFAULT_RULES_SETTINGS.downloadLabel;

try {
  const settings = await getAllSiteSettings('rules');
  const settingsMap = settings.reduce((acc, setting) => {
    acc[setting.key] = setting.value;
    return acc;
  }, {} as Record<string, string>);

  rulesTitle = settingsMap.rules_page_title || rulesTitle;
  rulesIntro = settingsMap.rules_page_intro || rulesIntro;
  rulesPdfUrl = settingsMap.rules_pdf_url || rulesPdfUrl;
  rulesDownloadLabel = settingsMap.rules_download_label || rulesDownloadLabel;
} catch (error) {
  console.error('Error fetching rules page settings:', error);
}

const normalizedPdfUrl = rulesPdfUrl.trim();
const pdfEmbedUrl = normalizedPdfUrl
  ? `${normalizedPdfUrl}${normalizedPdfUrl.includes('#') ? '&' : '#'}toolbar=1&navpanes=0`
  : '';
---

<Layout
  title={`${rulesTitle} | Elevate Ballers`}
  description={rulesIntro}
>
  <PageLoader client:load />

  <div id="wrapper">
    <TopBar />
    <Header client:load currentPath={Astro.url.pathname} />

    <div id="main">
      <section class="rules-page">
        <div class="container">
          <div class="rules-shell">
            <div class="rules-copy">
              <p class="rules-eyebrow">Official Documents</p>
              <h1 class="heading-font">{rulesTitle}</h1>
              <p>{rulesIntro}</p>

              {normalizedPdfUrl ? (
                <div class="rules-actions">
                  <a
                    href={normalizedPdfUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="rules-button"
                  >
                    {rulesDownloadLabel}
                  </a>
                </div>
              ) : (
                <div class="rules-empty">
                  A PDF has not been configured for this page yet. Please check back soon.
                </div>
              )}
            </div>

            {normalizedPdfUrl && (
              <div class="rules-viewer">
                <iframe
                  src={pdfEmbedUrl}
                  title={rulesTitle}
                  loading="lazy"
                  class="rules-frame"
                />

                <p class="rules-fallback">
                  If the document does not load in your browser,
                  <a href={normalizedPdfUrl} target="_blank" rel="noopener noreferrer"> open the PDF directly</a>.
                </p>
              </div>
            )}
          </div>
        </div>
      </section>
    </div>

    <Footer />
  </div>

  <script is:inline type="speculationrules">
    {
      "prefetch": [
        {
          "source": "document",
          "where": {
            "and": [
              { "href_matches": "/*" },
              {
                "not": {
                  "href_matches": [
                    "/wp-*.php",
                    "/wp-admin/*",
                    "/wp-content/uploads/*",
                    "/wp-content/*",
                    "/wp-content/plugins/*",
                    "/wp-content/themes/elevate/*",
                    "/*\\?(.+)"
                  ]
                }
              },
              { "not": { "selector_matches": "a[rel~=\"nofollow\"]" } },
              { "not": { "selector_matches": ".no-prefetch, .no-prefetch a" } }
            ]
          },
          "eagerness": "conservative"
        }
      ]
    }
  </script>

  <style is:inline>
    .rules-page {
      padding: 72px 0 80px;
      background:
        radial-gradient(circle at top left, rgba(221, 51, 51, 0.12), transparent 32%),
        linear-gradient(180deg, #f7f8fb 0%, #ffffff 35%);
    }

    .rules-shell {
      display: grid;
      gap: 28px;
    }

    .rules-copy,
    .rules-viewer {
      background: #fff;
      border: 1px solid rgba(54, 63, 72, 0.12);
      border-radius: 20px;
      box-shadow: 0 20px 50px rgba(17, 24, 39, 0.08);
    }

    .rules-copy {
      padding: 32px;
    }

    .rules-eyebrow {
      margin: 0 0 10px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #dd3333;
    }

    .rules-copy h1 {
      margin: 0 0 16px;
      color: #1f2937;
      font-size: clamp(2rem, 5vw, 3.5rem);
      line-height: 1;
    }

    .rules-copy p {
      margin: 0;
      font-size: 16px;
      line-height: 1.8;
      color: #4b5563;
    }

    .rules-actions {
      margin-top: 24px;
    }

    .rules-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0 20px;
      border-radius: 999px;
      background: #dd3333;
      color: #fff;
      font-weight: 700;
      text-decoration: none;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
      box-shadow: 0 14px 28px rgba(221, 51, 51, 0.24);
    }

    .rules-button:hover {
      color: #fff;
      background: #c62828;
      transform: translateY(-1px);
    }

    .rules-empty {
      margin-top: 24px;
      padding: 16px 18px;
      border-radius: 14px;
      background: #fff7ed;
      color: #9a3412;
      font-size: 14px;
      font-weight: 600;
    }

    .rules-viewer {
      padding: 14px;
    }

    .rules-frame {
      display: block;
      width: 100%;
      min-height: 78vh;
      border: 0;
      border-radius: 14px;
      background: #f3f4f6;
    }

    .rules-fallback {
      margin: 12px 6px 4px;
      font-size: 14px;
      color: #6b7280;
    }

    .rules-fallback a {
      color: #dd3333;
      font-weight: 600;
    }

    @media (max-width: 767px) {
      .rules-page {
        padding: 48px 0 56px;
      }

      .rules-copy {
        padding: 24px;
      }

      .rules-frame {
        min-height: 70vh;
      }
    }
  </style>
</Layout>
