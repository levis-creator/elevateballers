---
export const prerender = false;

Astro.response.headers.set("Cache-Control", "public, s-maxage=300, stale-while-revalidate=600");

import { usePublicV2 } from "@/lib/ui-version";

// v2-only route. Rewrite to the legacy page when the flag is off — URL stays /staff.
if (!usePublicV2) return Astro.rewrite("/staff-v1");

import LayoutV2 from "@/layouts/v2/Layout.astro";
import StaffPage from "@/features/staff/presentation/v2/StaffPage.astro";
---

<LayoutV2
	title="Our Staff - Elevate Ballers | Organisers, Officials & Volunteers"
	description="Meet the people behind Elevate Ballers — the organisers, referees, table officials and volunteers who run Kenya's premier basketball league."
	canonicalURL={`${Astro.url.origin}/staff/`}
	type="website"
>
	<StaffPage />
</LayoutV2>
