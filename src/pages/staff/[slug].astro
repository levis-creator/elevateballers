---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import TopBar from '../../features/layout/components/TopBar.astro';
import Header from '../../features/layout/components/Header';
import Footer from '../../features/layout/components/Footer.astro';
import PageLoader from '../../components/PageLoader';
import Spacing from '../../shared/components/ui/Spacing.astro';
import { Image } from 'astro:assets';
import { getStaffBySlug } from '../../features/cms/lib/queries';
import { getDisplayImageUrl } from '../../lib/asset-url';

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect('/404', 302);
}

let staff;
try {
  staff = await getStaffBySlug(slug);
  if (!staff || !staff.approved) {
    return Astro.redirect('/404', 302);
  }
} catch (error) {
  console.error('Error fetching staff:', error);
  return Astro.redirect('/404', 302);
}

const fullName = `${staff.firstName} ${staff.lastName}`.trim() || 'Staff Member';
const pageTitle = `${fullName} - Staff - Elevate Ballers`;
const pageDescription = staff.bio || `View ${fullName}'s profile and team assignments.`;
const pageUrl = `${Astro.url.origin}/staff/${slug}/`;
const pageImageSource =
  getDisplayImageUrl(staff.image, Astro.url.origin) ||
  "/images/Elevate_Icon-200x200.png";
const pageImage = pageImageSource.startsWith("http")
  ? pageImageSource
  : new URL(pageImageSource, Astro.url.origin).toString();

const formatRole = (role: string): string =>
  role
    .split('_')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
    .join(' ');

const approvedTeams = (staff.teams || []).filter((teamStaff: any) => teamStaff.team?.approved);
---

<Layout
  title={pageTitle}
  description={pageDescription}
  image={pageImage}
  canonicalURL={pageUrl}
  type="profile"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebPage",
        "@id": pageUrl,
        "url": pageUrl,
        "name": pageTitle,
        "isPartOf": { "@id": `${Astro.url.origin}/#website` },
        "description": pageDescription,
        "breadcrumb": { "@id": `${pageUrl}#breadcrumb` },
        "inLanguage": "en-US"
      },
      {
        "@type": "BreadcrumbList",
        "@id": `${pageUrl}#breadcrumb`,
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": `${Astro.url.origin}/` },
          { "@type": "ListItem", "position": 2, "name": "Staff", "item": `${Astro.url.origin}/staff` },
          { "@type": "ListItem", "position": 3, "name": fullName }
        ]
      },
      {
        "@type": "Person",
        "name": fullName,
        "jobTitle": formatRole(staff.role),
        "image": pageImage,
        "url": pageUrl
      }
    ]
  })} />

  <PageLoader client:load />
  <div id="wrapper">
    <TopBar />
    <Header client:load currentPath={Astro.url.pathname} />
    <div id="main">
      <div
        class="stm-title-box-unit transparent-header_on title_box-357"
        style="padding-top: 0; padding-bottom: 0px;"
      ></div>
      <div class="container">
        <section class="wpb-content-wrapper">
          <div class="vc_row wpb_row vc_row-fluid">
            <div class="wpb_column vc_column_container vc_col-sm-12">
              <div class="vc_column-inner">
                <div class="wpb_wrapper">
                  <Spacing
                    id="stm-spacing-staff-header"
                    lg="80"
                    md="70"
                    sm="60"
                    xs="50"
                  />

                  <div class="staff-profile-header">
                    <div class="staff-profile-content">
                      {
                        staff.image ? (
                          <div class="staff-image-container">
                            <Image
                              src={getDisplayImageUrl(staff.image, Astro.url.origin)!}
                              alt={fullName}
                              width={180}
                              height={180}
                            />
                          </div>
                        ) : (
                          <div class="staff-image-placeholder">
                            <span class="staff-initials">
                              {fullName
                                .split(' ')
                                .map((n) => n[0])
                                .join('')
                                .substring(0, 2)
                                .toUpperCase()}
                            </span>
                          </div>
                        )
                      }
                      <div class="staff-header-info">
                        <h1 class="staff-title">{fullName}</h1>
                        <div class="staff-role">{formatRole(staff.role)}</div>
                        {(staff.email || staff.phone) && (
                          <div class="staff-contact">
                            {staff.email && <a href={`mailto:${staff.email}`}>{staff.email}</a>}
                            {staff.phone && <a href={`tel:${staff.phone}`}>{staff.phone}</a>}
                          </div>
                        )}
                      </div>
                    </div>
                  </div>

                  <Spacing
                    id="stm-spacing-staff-bio"
                    lg="50"
                    md="40"
                    sm="30"
                    xs="20"
                  />

                  {staff.bio && (
                    <div class="staff-bio-section">
                      <h3 class="section-title">Bio</h3>
                      <p class="staff-bio">{staff.bio}</p>
                    </div>
                  )}

                  <Spacing
                    id="stm-spacing-staff-teams"
                    lg="50"
                    md="40"
                    sm="30"
                    xs="20"
                  />

                  <div class="staff-teams-section">
                    <h3 class="section-title">Teams</h3>
                    {approvedTeams.length > 0 ? (
                      <ul class="staff-teams-list">
                        {approvedTeams.map((teamStaff: any) => (
                          <li class="staff-team-item">
                            <a href={`/teams/${teamStaff.team.slug}`}>
                              {teamStaff.team.name}
                            </a>
                            <span class="staff-team-role">
                              {formatRole(teamStaff.role)}
                            </span>
                          </li>
                        ))}
                      </ul>
                    ) : (
                      <p class="no-data">No team assignments listed.</p>
                    )}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
    <Footer />
  </div>
</Layout>
