---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import TopBar from "../../features/layout/components/TopBar.astro";
import Header from "../../features/layout/components/Header";
import Footer from "../../features/layout/components/Footer.astro";
import { getTeamsPaginated } from "../../features/cms/lib/queries";
import { resolveAssetUrl, getDisplayImageUrl } from "../../lib/asset-url";
import Spacing from "../../shared/components/ui/Spacing.astro";
import PageLoader from "../../components/PageLoader";
import ContentLoader from "../../components/ContentLoader";

const PER_PAGE = 12;
const pageParam = Astro.url.searchParams.get("page");
const currentPage = Math.max(1, parseInt(pageParam || "1", 10) || 1);
const searchQuery = Astro.url.searchParams.get("search") ?? "";

let teams: Awaited<ReturnType<typeof getTeamsPaginated>>["teams"] = [];
let totalCount = 0;
let totalPages = 1;
let currentPageRes = 1;
let hasError = false;
try {
    const result = await getTeamsPaginated(
        currentPage,
        PER_PAGE,
        false,
        searchQuery || undefined,
    );
    teams = result.teams;
    totalCount = result.totalCount;
    totalPages = result.totalPages;
    currentPageRes = result.currentPage;
} catch (error) {
    console.error("Error fetching teams:", error);
    hasError = true;
}

function teamsPageUrl(page: number, search: string): string {
    const base = `${Astro.url.origin}/teams`;
    if (page <= 1 && !search) return `${base}/`;
    const params = new URLSearchParams();
    if (page > 1) params.set("page", String(page));
    if (search) params.set("search", search);
    return params.toString() ? `${base}?${params.toString()}` : `${base}/`;
}

// SEO Meta Tags (use clamped page from result)
const pageTitle =
    currentPageRes === 1 && !searchQuery
        ? "Teams - Elevate Ballers"
        : searchQuery
          ? `Teams - "${searchQuery}" - Elevate Ballers`
          : `Teams - Page ${currentPageRes} - Elevate Ballers`;
const pageDescription = "View all teams in the Elevate Ballers league";
const pageUrl = teamsPageUrl(currentPageRes, searchQuery);
const baseTeamsUrl = `${Astro.url.origin}/teams/`;
const hasFilters = currentPageRes > 1 || Boolean(searchQuery);
const canonicalURL = baseTeamsUrl;
const robots = hasFilters ? "noindex,follow" : undefined;
const schemaUrl = hasFilters ? canonicalURL : pageUrl;
const startItem = totalCount === 0 ? 0 : (currentPageRes - 1) * PER_PAGE + 1;
const endItem = Math.min(currentPageRes * PER_PAGE, totalCount);
// Truncated page numbers for pagination
const paginationPages: (number | "...")[] = [];
if (totalPages <= 7) {
    for (let i = 1; i <= totalPages; i++) paginationPages.push(i);
} else {
    paginationPages.push(1);
    if (currentPageRes > 3) paginationPages.push("...");
    const start = Math.max(2, currentPageRes - 1);
    const end = Math.min(totalPages - 1, currentPageRes + 1);
    for (let i = start; i <= end; i++) paginationPages.push(i);
    if (currentPageRes < totalPages - 2) paginationPages.push("...");
    paginationPages.push(totalPages);
}
// Pagination rel links (only for pure page navigation, not search)
const prevURL = !searchQuery && currentPageRes > 1
    ? teamsPageUrl(currentPageRes - 1, "")
    : undefined;
const nextURL = !searchQuery && currentPageRes < totalPages
    ? teamsPageUrl(currentPageRes + 1, "")
    : undefined;
---

<Layout
    title={pageTitle}
    description={pageDescription}
    canonicalURL={canonicalURL}
    type="website"
    robots={robots}
    prevURL={prevURL}
    nextURL={nextURL}
>

    <script
        type="application/ld+json"
        is:inline
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@graph": [
                {
                    "@type": "WebPage",
                    "@id": schemaUrl,
                    url: schemaUrl,
                    name: pageTitle,
                    isPartOf: { "@id": `${Astro.url.origin}/#website` },
                    description: pageDescription,
                    breadcrumb: { "@id": `${schemaUrl}#breadcrumb` },
                    inLanguage: "en-US",
                },
                {
                    "@type": "BreadcrumbList",
                    "@id": `${schemaUrl}#breadcrumb`,
                    itemListElement: [
                        {
                            "@type": "ListItem",
                            position: 1,
                            name: "Home",
                            item: `${Astro.url.origin}/`,
                        },
                        { "@type": "ListItem", position: 2, name: "Teams" },
                    ],
                },
            ],
        })}
    />

    <PageLoader client:load />
    <div id="wrapper" class="teams-page-shell">
        <TopBar />
        <Header client:load currentPath={Astro.url.pathname} />
        <div id="main">
            <div
                class="stm-title-box-unit transparent-header_on title_box-357"
                style="padding-top: 0; padding-bottom: 0px;"
            >
            </div>
            <div class="container">
                <section class="wpb-content-wrapper">
                    <div class="vc_row wpb_row vc_row-fluid">
                        <div
                            class="wpb_column vc_column_container vc_col-sm-12"
                        >
                            <div class="vc_column-inner">
                                <div class="wpb_wrapper">
                                    <Spacing
                                        id="stm-spacing-teams-header"
                                        lg="80"
                                        md="70"
                                        sm="60"
                                        xs="50"
                                    />

                                    <section class="teams-hero">
                                        <div class="teams-hero-copy">
                                            <p class="teams-eyebrow">
                                                Club Directory
                                            </p>
                                            <h1 class="teams-hero-title heading-font">
                                                TEAMS
                                            </h1>
                                            <p class="teams-hero-description">
                                                Explore every club in Elevate
                                                Ballers through a more
                                                competitive, scoreboard-inspired
                                                directory built to feel at home
                                                beside results and standings.
                                            </p>
                                        </div>
                                        <div class="teams-hero-stats">
                                            <div class="teams-stat-card">
                                                <span class="teams-stat-label">
                                                    Clubs listed
                                                </span>
                                                <strong class="teams-stat-value">
                                                    {totalCount}
                                                </strong>
                                            </div>
                                            <div class="teams-stat-card">
                                                <span class="teams-stat-label">
                                                    Current page
                                                </span>
                                                <strong class="teams-stat-value">
                                                    {currentPageRes}/{totalPages}
                                                </strong>
                                            </div>
                                        </div>
                                    </section>

                                    <form
                                        class="teams-search-form"
                                        method="get"
                                        action="/teams"
                                    >
                                        <div class="teams-search-header">
                                            <div>
                                                <p class="teams-section-kicker">
                                                    Search
                                                </p>
                                                <h2 class="teams-section-title heading-font">
                                                    Find a Club
                                                </h2>
                                            </div>
                                            <p class="teams-search-summary">
                                                Showing {startItem}-{endItem} of{" "}
                                                {totalCount} teams
                                            </p>
                                        </div>
                                        <label
                                            for="teams-search-input"
                                            class="teams-search-label"
                                            >Search teams</label
                                        >
                                        <div class="teams-search-row">
                                            <input
                                                id="teams-search-input"
                                                type="search"
                                                name="search"
                                                value={searchQuery}
                                                placeholder="Search by name..."
                                                class="teams-search-input"
                                                aria-label="Search teams by name"
                                            />
                                            <button
                                                type="submit"
                                                class="teams-search-button"
                                                >Search</button
                                            >
                                            {
                                                searchQuery && (
                                                    <a
                                                        href="/teams"
                                                        class="teams-search-clear"
                                                    >
                                                        Clear
                                                    </a>
                                                )
                                            }
                                        </div>
                                    </form>

                                    {
                                        hasError ? (
                                            <ContentLoader
                                                client:load
                                                message="Failed to load teams. Please try again later."
                                            />
                                        ) : teams.length === 0 ? (
                                            <div class="no-teams-message">
                                                {searchQuery ? (
                                                    <p>
                                                        No teams found for "
                                                        {searchQuery}".{" "}
                                                        <a href="/teams">
                                                            Clear search
                                                        </a>
                                                    </p>
                                                ) : (
                                                    <p>
                                                        No teams available at
                                                        this time.
                                                    </p>
                                                )}
                                            </div>
                                        ) : (
                                            <div class="teams-grid">
                                                {teams.map((team) => (
                                                    <div class="team-card">
                                                        <a
                                                            href={`/teams/${team.slug}`}
                                                            class="team-card-link"
                                                        >
                                                            <div class="team-card-topline">
                                                                <span class="team-card-chip">
                                                                    Team
                                                                </span>
                                                                <span class="team-card-arrow">
                                                                    Explore
                                                                </span>
                                                            </div>
                                                            <div class="team-card-main">
                                                                {resolveAssetUrl(
                                                                    team.logo,
                                                                ) ? (
                                                                    <div class="team-logo">
                                                                        <img
                                                                            src={
                                                                                getDisplayImageUrl(
                                                                                    team.logo,
                                                                                    Astro
                                                                                        .url
                                                                                        .origin,
                                                                                )!
                                                                            }
                                                                            alt={`${team.name} logo`}
                                                                        />
                                                                    </div>
                                                                ) : (
                                                                    <div class="team-logo-placeholder">
                                                                        <span class="team-logo-text">
                                                                            {team.name
                                                                                .charAt(
                                                                                    0,
                                                                                )
                                                                                .toUpperCase()}
                                                                        </span>
                                                                    </div>
                                                                )}
                                                            </div>
                                                            <div class="team-info">
                                                                <h3 class="team-name">
                                                                    {team.name}
                                                                </h3>
                                                                <p class="team-description">
                                                                    {team.description?.trim()
                                                                        ? team.description
                                                                              .trim()
                                                                              .slice(
                                                                                  0,
                                                                                  110,
                                                                              )
                                                                        : "Roster, club identity, and squad profile available on the full team page."}
                                                                    {team.description &&
                                                                    team.description
                                                                        .trim()
                                                                        .length >
                                                                        110
                                                                        ? "..."
                                                                        : ""}
                                                                </p>
                                                                <div class="team-stats">
                                                                    <span class="team-player-count">
                                                                        <i
                                                                            class="fa fa-users"
                                                                            aria-hidden="true"
                                                                        />
                                                                        {
                                                                            team
                                                                                ._count
                                                                                .players
                                                                        }{" "}
                                                                        {team
                                                                            ._count
                                                                            .players ===
                                                                        1
                                                                            ? "Player"
                                                                            : "Players"}
                                                                    </span>
                                                                    <span class="team-card-divider">
                                                                        /
                                                                    </span>
                                                                    <span class="team-roster-link">
                                                                        View roster
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </a>
                                                    </div>
                                                ))}
                                            </div>
                                        )
                                    }

                                    {
                                        !hasError && totalCount > 0 && (
                                            <div class="teams-pagination-wrapper">
                                                <p class="teams-pagination-summary">
                                                    Page {currentPageRes} of{" "}
                                                    {totalPages}
                                                </p>
                                                {totalPages > 1 && (
                                                    <nav
                                                        class="teams-pagination"
                                                        aria-label="Teams pagination"
                                                    >
                                                        <ul class="teams-pagination-list">
                                                            <li>
                                                                {currentPageRes >
                                                                1 ? (
                                                                    <a
                                                                        class="teams-pagination-link"
                                                                        href={teamsPageUrl(
                                                                            currentPageRes -
                                                                                1,
                                                                            searchQuery,
                                                                        )}
                                                                        aria-label="Previous page"
                                                                    >
                                                                        Previous
                                                                    </a>
                                                                ) : (
                                                                    <span
                                                                        class="teams-pagination-link teams-pagination-link--disabled"
                                                                        aria-disabled="true"
                                                                    >
                                                                        Previous
                                                                    </span>
                                                                )}
                                                            </li>
                                                            {paginationPages.map((p) => (
                                                            <li>
                                                                {p === "..." ? (
                                                                    <span class="teams-pagination-link teams-pagination-link--disabled">
                                                                        &hellip;
                                                                    </span>
                                                                ) : p === currentPageRes ? (
                                                                    <span
                                                                        class="teams-pagination-link teams-pagination-link--current"
                                                                        aria-current="page"
                                                                    >
                                                                        {p}
                                                                    </span>
                                                                ) : (
                                                                    <a
                                                                        class="teams-pagination-link"
                                                                        href={teamsPageUrl(p, searchQuery)}
                                                                    >
                                                                        {p}
                                                                    </a>
                                                                )}
                                                            </li>
                                                        ))}
                                                            <li>
                                                                {currentPageRes <
                                                                totalPages ? (
                                                                    <a
                                                                        class="teams-pagination-link"
                                                                        href={teamsPageUrl(
                                                                            currentPageRes +
                                                                                1,
                                                                            searchQuery,
                                                                        )}
                                                                        aria-label="Next page"
                                                                    >
                                                                        Next
                                                                    </a>
                                                                ) : (
                                                                    <span
                                                                        class="teams-pagination-link teams-pagination-link--disabled"
                                                                        aria-disabled="true"
                                                                    >
                                                                        Next
                                                                    </span>
                                                                )}
                                                            </li>
                                                        </ul>
                                                    </nav>
                                                )}
                                            </div>
                                        )
                                    }

                                    <Spacing
                                        id="stm-spacing-teams-footer"
                                        lg="50"
                                        md="50"
                                        sm="40"
                                        xs="40"
                                    />
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </div>

    <Footer />


    <style>
        /* Teams Page Styles */
        :global(body:has(#wrapper.teams-page-shell)),
        :global(html:has(#wrapper.teams-page-shell)) {
            background:
                radial-gradient(
                    circle at top,
                    rgba(221, 51, 51, 0.16),
                    transparent 28%
                ),
                linear-gradient(180deg, #12101c 0%, #171326 50%, #14111f 100%);
        }

        #wrapper.teams-page-shell,
        #wrapper.teams-page-shell #main {
            background: transparent;
        }

        :global(body:has(#wrapper.teams-page-shell) .stm-footer) {
            background-color: transparent !important;
            background-image: none !important;
        }

        .teams-hero {
            display: grid;
            grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.95fr);
            gap: 1.5rem;
            align-items: stretch;
            margin-bottom: 2rem;
        }

        .teams-hero-copy,
        .teams-hero-stats,
        .teams-search-form,
        .teams-pagination-wrapper,
        .no-teams-message {
            border: 1px solid rgba(226, 232, 240, 0.18);
            border-radius: 28px;
            background:
                linear-gradient(
                    180deg,
                    rgba(27, 22, 41, 0.98) 0%,
                    rgba(21, 18, 33, 0.98) 100%
                );
            box-shadow: 0 24px 50px rgba(4, 6, 18, 0.3);
        }

        .teams-hero-copy {
            padding: 2rem;
        }

        .teams-eyebrow,
        .teams-section-kicker {
            margin: 0 0 0.65rem 0;
            font-family: "Rubik", sans-serif;
            font-size: 0.78rem;
            font-weight: 800;
            letter-spacing: 0.28em;
            text-transform: uppercase;
            color: #f8b71d;
        }

        .teams-hero-title {
            margin: 0;
            font-size: clamp(3rem, 6vw, 4.6rem);
            line-height: 0.92;
            color: #fff6eb;
        }

        .teams-hero-description,
        .teams-search-summary,
        .team-description,
        .teams-pagination-summary,
        .no-teams-message,
        .no-teams-message a {
            font-family: "Rubik", sans-serif;
            color: #9fb0d1;
        }

        .teams-hero-description {
            margin: 1rem 0 0 0;
            max-width: 42rem;
            font-size: 1rem;
            line-height: 1.8;
        }

        .teams-hero-stats {
            padding: 1rem;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.85rem;
        }

        .teams-stat-card {
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            min-height: 150px;
            padding: 1.2rem;
            border-radius: 22px;
            background: rgba(14, 12, 22, 0.9);
            border: 1px solid rgba(226, 232, 240, 0.08);
        }

        .teams-stat-label {
            font-family: "Rubik", sans-serif;
            font-size: 0.76rem;
            font-weight: 700;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #8ba0c7;
        }

        .teams-stat-value {
            margin-top: 0.6rem;
            font-family: "Teko", sans-serif;
            font-size: 2.6rem;
            line-height: 1;
            color: #fff;
            letter-spacing: 0.04em;
        }

        .teams-search-header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 1rem;
        }

        .teams-section-title {
            margin: 0;
            color: #fff;
            font-size: clamp(2rem, 3vw, 2.8rem);
            line-height: 1;
        }

        .teams-search-summary,
        .teams-pagination-summary {
            margin: 0;
            font-size: 0.95rem;
        }

        .no-teams-message {
            text-align: center;
            padding: 3rem 2rem;
            font-size: 16px;
        }

        .teams-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .team-card {
            border-radius: 28px;
            overflow: hidden;
            background:
                linear-gradient(
                    180deg,
                    rgba(24, 20, 37, 0.98) 0%,
                    rgba(17, 14, 27, 0.98) 100%
                );
            border: 1px solid rgba(226, 232, 240, 0.12);
            box-shadow: 0 22px 44px rgba(8, 10, 23, 0.28);
            transition:
                transform 0.3s ease,
                box-shadow 0.3s ease,
                border-color 0.3s ease;
        }

        .team-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 28px 52px rgba(8, 10, 23, 0.34);
            border-color: rgba(248, 183, 29, 0.34);
        }

        .team-card:has(.team-card-link:focus-visible) {
            transform: translateY(-5px);
            border-color: rgba(248, 183, 29, 0.5);
            box-shadow:
                0 28px 52px rgba(8, 10, 23, 0.34),
                0 0 0 3px rgba(248, 183, 29, 0.25);
        }

        .team-card-link:focus-visible {
            outline: none;
        }

        .team-card-link {
            display: flex;
            flex-direction: column;
            text-decoration: none;
            color: #fff;
            height: 100%;
        }

        .team-card-topline {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1.1rem 1.25rem 0 1.25rem;
        }

        .team-card-chip,
        .team-card-arrow {
            font-family: "Rubik", sans-serif;
            font-size: 0.76rem;
            font-weight: 800;
            letter-spacing: 0.18em;
            text-transform: uppercase;
        }

        .team-card-chip {
            color: #161321;
            background: #ffc53d;
            border-radius: 999px;
            padding: 0.36rem 0.72rem;
        }

        .team-card-arrow {
            color: #9fb0d1;
        }

        .team-card-main {
            padding: 1rem 1.25rem 0 1.25rem;
        }

        .team-logo,
        .team-logo-placeholder {
            width: 100%;
            height: 220px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 24px;
            padding: 1.75rem;
            overflow: hidden;
            background:
                radial-gradient(
                    circle at top,
                    rgba(248, 183, 29, 0.12),
                    transparent 26%
                ),
                linear-gradient(180deg, #221d35, #161321);
        }

        .team-logo img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        .team-logo-placeholder {
            background: linear-gradient(135deg, #dd3333 0%, #b82828 100%);
        }

        .team-logo-text {
            font-size: 72px;
            font-weight: 700;
            color: #fff;
            font-family: "Teko", sans-serif;
        }

        .team-info {
            padding: 1.35rem 1.25rem 1.25rem 1.25rem;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .team-name {
            font-family: "Teko", sans-serif;
            font-size: 2.05rem;
            line-height: 0.95;
            color: #fff;
            margin: 0 0 0.8rem 0;
            font-weight: 700;
            text-transform: uppercase;
        }

        .team-description {
            font-size: 0.95rem;
            line-height: 1.65;
            margin: 0 0 1.2rem 0;
        }

        .team-stats {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding-top: 1rem;
            border-top: 1px solid rgba(226, 232, 240, 0.12);
            margin-top: auto;
            flex-wrap: wrap;
        }

        .team-player-count,
        .team-roster-link,
        .team-card-divider {
            font-family: "Rubik", sans-serif;
            font-size: 0.88rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .team-player-count,
        .team-card-divider {
            color: #9fb0d1;
        }

        .team-roster-link {
            color: #fff5df;
            font-weight: 600;
        }

        .team-player-count i {
            color: #f8b71d;
        }

        .teams-pagination-wrapper {
            margin-top: 2.5rem;
            padding: 1.2rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .teams-pagination-list {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .teams-pagination-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 2.25rem;
            height: 2.7rem;
            padding: 0 0.85rem;
            font-family: "Rubik", sans-serif;
            font-size: 14px;
            font-weight: 700;
            color: #f7f1e6;
            background: rgba(20, 17, 31, 0.96);
            border: 1px solid rgba(226, 232, 240, 0.12);
            border-radius: 14px;
            text-decoration: none;
            transition:
                background 0.2s,
                border-color 0.2s,
                color 0.2s;
        }

        .teams-pagination-link:hover:not(.teams-pagination-link--disabled):not(
                .teams-pagination-link--current
            ) {
            background: rgba(31, 26, 46, 0.98);
            border-color: rgba(248, 183, 29, 0.34);
        }

        .teams-pagination-link:focus-visible {
            outline: none;
            border-color: rgba(248, 183, 29, 0.5);
            box-shadow: 0 0 0 3px rgba(248, 183, 29, 0.25);
        }

        .teams-pagination-link--current {
            background: #f7f1e6;
            border-color: #f7f1e6;
            color: #161321;
            cursor: default;
        }

