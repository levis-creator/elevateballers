---
import Layout from "../layouts/Layout.astro";
import TopBar from "../features/layout/components/TopBar.astro";
import Header from "../features/layout/components/Header";
import Footer from "../features/layout/components/Footer.astro";
import Spacing from "../shared/components/ui/Spacing.astro";
import PageLoader from "../components/PageLoader";
import { getAllSiteSettings, getPublicStaff } from "../features/cms/lib/queries";
import { resolveAssetUrl } from "../lib/asset-url";

const DEFAULT_CONTENT = `Elevate Ballers is a premier basketball league dedicated to promoting excellence, sportsmanship, and community engagement through competitive basketball. Founded with a vision to elevate the game and the community, we have been serving basketball enthusiasts of all ages and skill levels.

Our mission is to provide a platform for athletes to showcase their skills, develop their talents, and compete at the highest level while fostering a sense of community and sportsmanship. We believe that basketball is more than just a game—it's a vehicle for personal growth, teamwork, and community building.

We offer multiple leagues including Ballers League, Junior Ballers, Senior Ballers, Women's League, and Veterans divisions. Each league is designed to provide competitive opportunities while maintaining a focus on skill development and fair play.

Our state-of-the-art facilities at Pepo Lane, off Dagoretti Road, provide the perfect environment for training and competition. With multiple courts and professional coaching staff, we ensure that every player has the opportunity to reach their full potential.

At Elevate Ballers, we are committed to creating an inclusive environment where everyone can participate, learn, and grow. Whether you're a seasoned player or just starting out, we welcome you to join our basketball family.`;

let aboutTitle = "ABOUT";
let aboutContent = DEFAULT_CONTENT;

try {
  const settings = await getAllSiteSettings("about");
  const titleSetting = settings.find((s: any) => s.key === "about_page_title");
  const contentSetting = settings.find((s: any) => s.key === "about_page_content");
  if (titleSetting?.value) aboutTitle = titleSetting.value;
  if (contentSetting?.value) aboutContent = contentSetting.value;
} catch (e) {
  // fall back to defaults
}

let staffMembers: any[] = [];
try {
  staffMembers = await getPublicStaff();
} catch (e) {
  // non-critical — just hide the section
}

// Detect if content is HTML (from rich text editor) or plain text (legacy)
const isHtml = aboutContent.trim().startsWith('<');
const paragraphs = isHtml ? [] : aboutContent.split(/\n\n+/).map((p: string) => p.trim()).filter(Boolean);
---

<Layout
  title="About Elevate - Our Mission, Vision & Basketball Community"
  description="Learn about Elevate Ballers, our mission to elevate the game of basketball, and the inclusive community we've built for players of all skill levels."
  canonicalURL={`${Astro.url.origin}/about-club/`}
  type="website"
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "AboutPage",
          "@id": `${Astro.url.origin}/about-club/`,
          url: `${Astro.url.origin}/about-club/`,
          name: "About Elevate - Our Mission, Vision & Basketball Community",
          isPartOf: { "@id": `${Astro.url.origin}/#website` },
          description:
            "Learn about Elevate Ballers, our mission to elevate the game of basketball, and the inclusive community we've built for players of all skill levels.",
          about: { "@id": `${Astro.url.origin}/#organization` },
          breadcrumb: { "@id": `${Astro.url.origin}/about-club/#breadcrumb` },
          inLanguage: "en-US",
        },
        {
          "@type": "BreadcrumbList",
          "@id": `${Astro.url.origin}/about-club/#breadcrumb`,
          itemListElement: [
            {
              "@type": "ListItem",
              position: 1,
              name: "Home",
              item: `${Astro.url.origin}/`,
            },
            { "@type": "ListItem", position: 2, name: "About" },
          ],
        },
        {
          "@type": "SportsOrganization",
          "@id": `${Astro.url.origin}/#organization`,
          name: "Elevate Ballers",
          url: `${Astro.url.origin}/`,
          sport: "Basketball",
          description:
            "Premier basketball league dedicated to promoting excellence, sportsmanship, and community engagement.",
          address: {
            "@type": "PostalAddress",
            streetAddress: "Pepo Lane, off Dagoretti Road",
            addressCountry: "KE",
          },
          email: "ballers@elevateballers.com",
        },
      ],
    })}
  />
  <PageLoader client:load />
  <div id="wrapper">
    <TopBar />
    <Header client:load currentPath={Astro.url.pathname} />
    <div id="main">
      <div
        class="stm-title-box-unit transparent-header_on title_box-357"
        style="padding-top: 0; padding-bottom: 0px;"
      >
      </div>
      <div class="container">
        <section class="wpb-content-wrapper">
          <div class="vc_row wpb_row vc_row-fluid">
            <div class="wpb_column vc_column_container vc_col-sm-12">
              <div class="vc_column-inner">
                <div class="wpb_wrapper">
                  <Spacing
                    id="stm-spacing-about-header"
                    lg="80"
                    md="70"
                    sm="60"
                    xs="50"
                  />

                  <h1
                    class="heading-font"
                    style="text-align: center; margin-bottom: 50px; color: #dd3333;"
                  >
                    {aboutTitle}
                  </h1>

                  <div
                    class="about-content"
                    style="max-width: 900px; margin: 0 auto;"
                  >
                    <div
                      class="normal_font"
                      style="line-height: 1.8; color: #363f48;"
                    >
                      {isHtml
                        ? <Fragment set:html={aboutContent} />
                        : paragraphs.map((p: string) => (
                            <p style="margin-bottom: 20px;">{p}</p>
                          ))
                      }
                    </div>
                  </div>

                  {staffMembers.length > 0 && (
                    <>
                      <Spacing id="stm-spacing-staff-title" lg="60" md="50" sm="40" xs="30" />
                      <h2 class="heading-font" style="text-align: center; margin-bottom: 40px; color: #dd3333;">
                        MEET THE DIRECTORS
                      </h2>
                      <div class="directors-grid">
                        {staffMembers.map((member) => {
                          const imageUrl = resolveAssetUrl(member.image);
                          const initials = `${member.firstName.charAt(0)}${member.lastName.charAt(0)}`.toUpperCase();
                          const roleLabel = member.role?.split('_').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join(' ') || '';
                          return (
                            <a class="director-card" href={member.slug ? `/staff/${member.slug}` : undefined}>
                              <div class="director-photo-wrap">
                                {imageUrl
                                  ? <img src={imageUrl} alt={`${member.firstName} ${member.lastName}`} loading="lazy" />
                                  : <div class="director-initials">{initials}</div>
                                }
                              </div>
                              <div class="director-info">
                                <div class="director-name">{member.firstName} {member.lastName}</div>
                                <div class="director-role">{roleLabel}</div>
                              </div>
                            </a>
                          );
                        })}
                      </div>
                    </>
                  )}

                  <Spacing
                    id="stm-spacing-about-footer"
                    lg="50"
                    md="50"
                    sm="40"
                    xs="40"
                  />
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
    <Footer />

  </div>
  <!--main-->
  <!--wrapper-->

  <div class="rev-close-btn">
    <span class="close-left"></span>
    <span class="close-right"></span>
  </div>

  <script is:inline>
    window.RS_MODULES = window.RS_MODULES || {};
    window.RS_MODULES.modules = window.RS_MODULES.modules || {};
    window.RS_MODULES.waiting = window.RS_MODULES.waiting || [];
    window.RS_MODULES.defered = true;
    window.RS_MODULES.moduleWaiting = window.RS_MODULES.moduleWaiting || {};
    window.RS_MODULES.type = "compiled";
  </script>
  <script is:inline type="speculationrules">
    {
      "prefetch": [
        {
          "source": "document",
          "where": {
            "and": [
              { "href_matches": "/*" },
              {
                "not": {
                  "href_matches": [
                    "/wp-*.php",
                    "/wp-admin/*",
                    "/wp-content/uploads/*",
                    "/wp-content/*",
                    "/wp-content/plugins/*",
                    "/wp-content/themes/elevate/*",
                    "/*\\?(.+)"
                  ]
                }
              },
              { "not": { "selector_matches": "a[rel~=\"nofollow\"]" } },
              { "not": { "selector_matches": ".no-prefetch, .no-prefetch a" } }
            ]
          },
          "eagerness": "conservative"
        }
      ]
    }
  </script>

  <style is:inline type="text/css">
    .sp-footer-sponsors {
      background: #f4f4f4;
      color: #363f48;
    }
    .sp-footer-sponsors .sp-sponsors .sp-sponsors-title {
      color: #363f48;
    }

    /* Smooth scroll behavior - Matching homepage */
    html {
      scroll-behavior: smooth;
    }

    /* About page specific styles */
    .wpb_wrapper h2.heading-font {
      font-size: 40px;
      line-height: 44px;
      margin-bottom: 50px;
      color: #dd3333 !important;
    }

    .about-content {
      font-size: 16px;
      line-height: 1.8;
    }

    .about-content p {
      margin-bottom: 20px;
      color: #363f48;
    }

    .directors-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 2rem;
      max-width: 900px;
      margin: 0 auto;
    }

    .director-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      text-decoration: none;
      color: inherit;
      transition: transform 0.2s ease;
    }

    .director-card:hover {
      transform: translateY(-4px);
    }

    .director-photo-wrap {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      overflow: hidden;
      background: #f0f0f0;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      border: 3px solid #dd3333;
    }

    .director-photo-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .director-initials {
      font-size: 2rem;
      font-weight: 700;
      color: #dd3333;
      font-family: var(--font-heading, 'Teko', sans-serif);
    }

    .director-name {
      font-family: var(--font-heading, 'Teko', sans-serif);
      font-size: 1.2rem;
      font-weight: 700;
      color: #363f48;
      line-height: 1.2;
    }

    .director-role {
      font-size: 0.85rem;
      color: #dd3333;
      font-weight: 600;
      margin-top: 4px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    @media (max-width: 480px) {
      .directors-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }
    }
  </style>

  <div class="sp-header-sponsors" style="margin-top: 10px; margin-right: 10px;">
    <div class="sportspress"><div class="sp-sponsors"></div></div>
  </div>

  <script is:inline type="text/javascript">
    jQuery(document).ready(function ($) {
      $(".sp-header").prepend($(".sp-header-sponsors"));
    });
  </script>

  <style is:inline type="text/css">
    /* Hide reCAPTCHA V3 badge */
    .grecaptcha-badge {
      visibility: hidden !important;
    }
  </style>

  <script is:inline type="text/javascript" id="sportspress-js-extra">
    /* <![CDATA[ */
    var localized_strings = {
      days: "days",
      hrs: "hrs",
      mins: "mins",
      secs: "secs",
      previous: "Previous",
      next: "Next",
    };
    //# sourceURL=sportspress-js-extra
    /* ]]> */
  </script>

  <!-- waypoints script removed -->

  <script
    is:inline
    type="text/javascript"
    src="/js1/js_composer_front.min.js"
    id="wpb_composer_front_js-js"></script>
</Layout>
<!-- wrapper -->
