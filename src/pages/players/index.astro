---
export const prerender = false;

Astro.response.headers.set("Cache-Control", "public, s-maxage=120, stale-while-revalidate=300");

import { usePublicV2 } from "@/lib/ui-version";

// v2-only route. Rewrite to the legacy page when the flag is off — URL stays /players.
if (!usePublicV2) return Astro.rewrite("/players-v1");

import LayoutV2 from "@/layouts/v2/Layout.astro";
import PlayersDirectoryPage from "@/features/player/presentation/v2/PlayersDirectoryPage.astro";
---

<LayoutV2
	title="Players Directory - Elevate Ballers | Rosters, Positions & Stats"
	description="Meet the players of Elevate Ballers. Search the full roster by team and position, and see points, rebounds and assists per game for every athlete."
	canonicalURL={`${Astro.url.origin}/players/`}
	type="website"
>
	<PlayersDirectoryPage />
</LayoutV2>
