---
export const prerender = false;

Astro.response.headers.set("Cache-Control", "public, s-maxage=120, stale-while-revalidate=300");

import { usePublicV2 } from "@/lib/ui-version";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404", 302);

// v2-only route (imports only the v2 tree). Rewrite to the legacy page when the
// flag is off — URL stays /players/<slug|id>.
if (!usePublicV2) return Astro.rewrite(`/players-v1/${slug}`);

import LayoutV2 from "@/layouts/v2/Layout.astro";
import PlayerDetailPage from "@/features/player/presentation/v2/PlayerDetailPage.astro";
import { getPlayerView } from "@/features/player/domain/usecases/get-player-view";

const view = await getPlayerView(slug);
if (!view) return Astro.redirect("/404", 302);

// Consolidate SEO on the canonical slug URL when reached via the legacy id.
if (view.slug && slug !== view.slug) return Astro.redirect(`/players/${view.slug}/`, 301);

const name = `${view.hero.first} ${view.hero.last}`.trim();
const seoTitle = `${name} - Players - Elevate Ballers`;
const seoDescription = `${name} — ${view.hero.team}${view.hero.league ? ` (${view.hero.league})` : ""}. Season averages, per-game splits, game log, shooting and season highs.`;
---

<LayoutV2 title={seoTitle} description={seoDescription} canonicalURL={`${Astro.url.origin}/players/${view.slug || slug}/`} type="website">
	<PlayerDetailPage view={view} />
</LayoutV2>
