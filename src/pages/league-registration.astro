---
export const prerender = false;

import { usePublicV2 } from "@/lib/ui-version";

// v2-only route. Rewrite to the legacy page when the flag is off — URL stays
// /league-registration.
if (!usePublicV2) return Astro.rewrite("/league-registration-v1");

import LayoutV2 from "@/layouts/v2/Layout.astro";
import RegistrationPage from "@/features/registration/presentation/v2/RegistrationPage.astro";
---

<LayoutV2
	title="League Registration - Elevate Ballers | Register a Team or Player"
	description="Register your team or sign up as a player for the Elevate Ballers season. Tryouts run year-round for late entries — join Kenya's premier basketball league."
	canonicalURL={`${Astro.url.origin}/league-registration/`}
	type="website"
>
	<RegistrationPage />
</LayoutV2>
