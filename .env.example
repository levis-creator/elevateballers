# Database connection string (MySQL)
# For local development: mysql://user:password@localhost:3306/elevateballers
# For production: Use connection string from your MySQL provider (PlanetScale, Railway, cPanel, etc.)
DATABASE_URL="mysql://user:password@localhost:3306/elevateballers"

# JWT secret for authentication tokens
# Generate a strong random string: openssl rand -base64 32
# IMPORTANT: Use different secrets for development and production
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Environment
NODE_ENV="development"

# Email - choose one provider and configure it

# Option 1: SMTP (e.g. cPanel, Gmail, Mailtrap)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
SMTP_FROM="ElevateBallers <info@elevateballers.com>"

# Option 2: Resend
# RESEND_API_KEY="re_xxxxxxxxxxxx"
# RESEND_FROM="ElevateBallers <info@elevateballers.com>"

# Option 3: Brevo (Sendinblue)
# BREVO_API_KEY="xkeysib-xxxxxxxxxxxx"
# BREVO_FROM="ElevateBallers <info@elevateballers.com>"
# BREVO_SENDER_NAME="ElevateBallers"

# Cloudflare Turnstile bot protection
# Get keys at: https://dash.cloudflare.com/ → Turnstile
# PUBLIC_ prefix exposes the site key to the browser (required by Astro)
PUBLIC_TURNSTILE_SITE_KEY="your-turnstile-site-key"
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"
#
# Test keys for local development (always pass):
#   PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
#   TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# Deployment target (optional)
# Set to "vercel" for Vercel deployment, "cpanel" for cPanel deployment
# If not set, defaults to "cpanel" (Node.js adapter)
# DEPLOY_TARGET="cpanel"
